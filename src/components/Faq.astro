---
import { DEFAULT_LOCALE, type SiteLocale } from "../i18n/config";
import { faqContent } from "../i18n/home/faq";

const { locale = DEFAULT_LOCALE } = Astro.props as {
  locale?: SiteLocale;
};

const t = faqContent[locale];
---

<section id="faqs" aria-labelledby="faqs-title" class="border-t border-gray-200 bg-gray-50 py-16 sm:py-24 lg:py-28 dark:border-gray-800 dark:bg-gray-900">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center lg:text-left lg:mx-0">
      <h2 id="faqs-title" class="text-3xl font-medium tracking-tight text-gray-900 sm:text-4xl dark:text-white">
        {t.title}
      </h2>
      <p class="mt-3 text-base text-gray-600 sm:text-lg dark:text-gray-300">
        {t.intro}
      </p>
    </div>

    <ul role="list" class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-6 sm:mt-16 lg:mx-0 lg:max-w-none lg:grid-cols-2 lg:gap-8">
      <li>
        <ul role="list" class="space-y-4 sm:space-y-5">
          {t.leftColumn.map((item) => (
            <li>
              <details class="faq-item group overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm hover:shadow-md dark:border-gray-700 dark:bg-black/30">
                <summary class="flex w-full cursor-pointer select-none list-none items-center justify-between gap-4 px-3 py-3 text-base font-semibold text-gray-900 sm:px-5 sm:py-5 sm:text-base lg:text-lg dark:text-white">
                  <span>{item.question}</span>
                  <svg class="h-5 w-5 shrink-0 text-gray-500 -transform duration-200 group-open:rotate-180 dark:text-gray-300" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.168l3.71-3.938a.75.75 0 1 1 1.08 1.04l-4.25 4.51a.75.75 0 0 1-1.08 0l-4.25-4.51a.75.75 0 0 1 .02-1.06Z" clip-rule="evenodd" />
                  </svg>
                </summary>
                <div class="px-3 pb-3 sm:px-5 sm:pb-5">
                  <p class="text-base text-gray-700 sm:text-base dark:text-gray-300">
                    {item.answer}
                  </p>
                </div>
              </details>
            </li>
          ))}
        </ul>
      </li>

      <li>
        <ul role="list" class="space-y-4 sm:space-y-5">
          {t.rightColumn.map((item) => (
            <li>
              <details class="faq-item group overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm hover:shadow-md dark:border-gray-700 dark:bg-black/30">
                <summary class="flex w-full cursor-pointer select-none list-none items-center justify-between gap-4 px-3 py-3 text-base font-semibold text-gray-900 sm:px-5 sm:py-5 sm:text-base lg:text-lg dark:text-white">
                  <span>{item.question}</span>
                  <svg class="h-5 w-5 shrink-0 text-gray-500 -transform duration-200 group-open:rotate-180 dark:text-gray-300" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.168l3.71-3.938a.75.75 0 1 1 1.08 1.04l-4.25 4.51a.75.75 0 0 1-1.08 0l-4.25-4.51a.75.75 0 0 1 .02-1.06Z" clip-rule="evenodd" />
                  </svg>
                </summary>
                <div class="px-3 pb-3 sm:px-5 sm:pb-5">
                  <p class="text-base text-gray-700 sm:text-base dark:text-gray-300">
                    {item.answer}
                  </p>
                </div>
              </details>
            </li>
          ))}
        </ul>
      </li>
    </ul>
  </div>
</section>

<script>
  const faqSection = document.querySelector('#faqs');

  if (faqSection) {
    const items = faqSection.querySelectorAll('.faq-item');

    items.forEach((item) => {
      item.addEventListener('toggle', () => {
        if (!item.open) return;

        items.forEach((otherItem) => {
          if (otherItem !== item) {
            otherItem.open = false;
          }
        });
      });
    });
  }
</script>