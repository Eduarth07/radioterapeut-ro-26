        id="gdprAcceptBtn"
        type="button"
        class="inline-flex cursor-pointer justify-center rounded-xl border border-blue-900 bg-blue-900 px-5 py-2.5 text-sm font-medium text-white shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:bg-blue-950 hover:shadow-md focus:outline-none focus:ring-2 focus:ring-cyan-500 focus:ring-offset-2 active:translate-y-0 active:scale-[0.98] dark:border-cyan-600 dark:bg-cyan-600 dark:text-white dark:hover:bg-cyan-500 dark:focus:ring-cyan-500 dark:focus:ring-offset-[#15182B]"
      >
        Confirm și accept
      </button>
      </div>
    </div>
  </div>
</section>

<script src="https://www.google.com/recaptcha/api.js" async defer></script>

<script>
  const modal = document.querySelector('#gdprModal');
  const openButton = document.querySelector('[data-open-gdpr]');
  const closeButton = document.querySelector('[data-close-gdpr]');
  const acceptButton = document.querySelector('#gdprAcceptBtn');
  const gdprConsent = document.querySelector('#gdprConsent');
  const gdprError = document.querySelector('#gdprError');
  const captchaError = document.querySelector('#captchaError');
  const form = document.querySelector('#programareForm');
  const modalContent = document.querySelector('#gdprModalContent');
  const acceptWrap = document.querySelector('#gdprAcceptWrap');

let gdprAccepted = false;
let modalMode = 'view';
let acceptUnlocked = false;

const openModal = (mode = 'view') => {
  if (!modal) return;

  modalMode = mode;
  const requireAcceptance = mode === 'consent';

  if (requireAcceptance) {
    acceptUnlocked = false;
    acceptWrap?.classList.add('hidden');
    if (modalContent) modalContent.scrollTop = 0;
  } else {
    acceptWrap?.classList.add('hidden');
    if (modalContent) modalContent.scrollTop = 0;
  }

  modal.classList.remove('hidden');
  modal.classList.add('flex');
  document.body.classList.add('overflow-hidden');
};

  const closeModal = () => {
    if (!modal) return;
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.body.classList.remove('overflow-hidden');
    if (modalMode !== 'consent') {
      acceptWrap?.classList.add('hidden');
    }
  };

  const acceptTerms = () => {
    if (modalMode !== 'consent') return;

    gdprAccepted = true;

    if (gdprConsent) {
      gdprConsent.checked = true;
    }

    gdprError?.classList.add('hidden');
    closeModal();
  };

  openButton?.addEventListener('click', () => openModal('view'));
  closeButton?.addEventListener('click', closeModal);
  acceptButton?.addEventListener('click', acceptTerms);

  gdprConsent?.addEventListener('click', (event) => {
    if (gdprAccepted) return;

    event.preventDefault();
    openModal('consent');
  });


const revealAcceptButton = () => {
  if (modalMode !== 'consent' || !modalContent || acceptUnlocked) return;

  const scrollTop = modalContent.scrollTop;
  const scrollableHeight = modalContent.scrollHeight - modalContent.clientHeight;

  if (scrollableHeight <= 0) {
    acceptUnlocked = true;
    acceptWrap?.classList.remove('hidden');
    return;
  }

  const progress = scrollTop / scrollableHeight;

  if (progress >= 0.3) {
    acceptUnlocked = true;
    acceptWrap?.classList.remove('hidden');
  }
};

  modalContent?.addEventListener('scroll', revealAcceptButton);

  modal?.addEventListener('click', (event) => {
    if (event.target === modal) {
      closeModal();
    }
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && modal && !modal.classList.contains('hidden')) {
      closeModal();
    }
  });

  form?.addEventListener('submit', (event) => {
    if (!gdprAccepted || !gdprConsent?.checked) {
      event.preventDefault();
      gdprError?.classList.remove('hidden');
      openModal('consent');
      return;
    }

    const captchaResponse = typeof window.grecaptcha !== 'undefined'
      ? window.grecaptcha.getResponse()
      : '';

    if (!captchaResponse) {
      event.preventDefault();
      captchaError?.classList.remove('hidden');
      return;
    }

    captchaError?.classList.add('hidden');
  });
</script>