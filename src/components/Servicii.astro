---
import { DEFAULT_LOCALE, type SiteLocale } from "../i18n/config";
import { servicesContent } from "../i18n/home/services";

const { locale = DEFAULT_LOCALE } = Astro.props as {
  locale?: SiteLocale;
};

const t = servicesContent[locale];
const oncologicCards = t.oncologicCards;
const nonOncologicCards = t.nonOncologicCards;

const servicesSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": t.title,
  "description": t.description,
  "itemListElement": [
    ...oncologicCards.map((card, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "MedicalProcedure",
        "name": card.title,
        "description": card.description,
        "procedureType": "RadiationTherapy",
        "provider": { "@id": "https://radioterapeut.ro/#physician" },
      }
    })),
    ...nonOncologicCards.map((card, index) => ({
      "@type": "ListItem",
      "position": oncologicCards.length + index + 1,
      "item": {
        "@type": "MedicalProcedure",
        "name": card.title,
        "description": card.description,
        "procedureType": "NonOncologicTherapy",
        "provider": { "@id": "https://radioterapeut.ro/#physician" },
      }
    }))
  ]
};
---

<section
  id="servicii"
  aria-labelledby="servicii-title"
  class="border-t border-gray-200 dark:border-gray-800 bg-gray-100 scroll-mt-8 md:scroll-mt-0 py-18 sm:py-32 dark:bg-gray-900"
>
  <script type="application/ld+json" set:html={JSON.stringify(servicesSchema)} />

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto text-center">
      <h2 id="servicii-title" class="text-3xl font-medium tracking-tight text-gray-900 dark:text-white lg:pb-2">
        {t.title}
      </h2>

      <p class="mt-6 lg:mt-2 text-base xl:text-lg text-gray-600 dark:text-gray-300">
        {t.description}
      </p>
    </div>

    <div class="mt-8 flex justify-center">
      <div class="relative" data-services-toggle>
        <div class="grid grid-cols-2 shadow-lg shadow-gray-900/5" role="radiogroup" aria-label={t.toggleAriaLabel}>
          <button
            type="button"
            class="cursor-pointer rounded-l-lg border border-gray-300 bg-white px-[calc(theme(spacing.3)-1px)] py-[calc(theme(spacing.2)-1px)] text-base xl:text-base font-medium text-gray-700 shadow-sm shadow-gray-300/40 ease-out hover:border-gray-300 hover:bg-gray-200 dark:border-gray-700 dark:bg-gray-800 dark:text-gray-200 dark:shadow-none dark:hover:border-gray-500 dark:hover:bg-gray-700 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cyan-500 dark:focus-visible:outline-gray-300"
            role="radio"
            aria-checked="true"
            data-mode="oncologic"
            data-active="true"
          >
            {t.oncologicLabel}
          </button>

          <button
            type="button"
            class="cursor-pointer -ml-px rounded-r-lg border border-gray-300 bg-white px-[calc(theme(spacing.3)-1px)] py-[calc(theme(spacing.2)-1px)] text-base xl:text-base font-medium text-gray-700 shadow-sm shadow-gray-300/40 ease-out hover:border-gray-300 hover:bg-gray-200 dark:border-gray-700 dark:bg-gray-800 dark:text-gray-200 dark:shadow-none dark:hover:border-gray-500 dark:hover:bg-gray-700 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cyan-500 dark:focus-visible:outline-gray-300"
            role="radio"
            aria-checked="false"
            data-mode="nononcologic"
            data-active="false"
          >
            {t.nonOncologicLabel}
          </button>
        </div>

        <div
          aria-hidden="true"
          class="pointer-events-none absolute inset-0 z-10 grid grid-cols-2 overflow-hidden rounded-lg bg-cyan-500 dark:bg-cyan-700 transition-all duration-300 [clip-path:inset(0_50%_0_0)]"
          data-highlight
        >
          <div class="py-2 text-center text-base xl:text-base font-semibold text-white">{t.oncologicLabel}</div>
          <div class="py-2 text-center text-base xl:text-base font-semibold text-white -ml-px">{t.nonOncologicLabel}</div>
        </div>
      </div>
    </div>

    <div
      class="mx-auto mt-8 grid max-w-2xl grid-cols-1 items-start gap-x-8 gap-y-10 lg:max-w-none lg:grid-cols-3"
      data-panel="oncologic"
      role="tabpanel"
    >
      {oncologicCards.map((card, index) => (
        <article
          class:list={[
            "flex flex-col overflow-hidden rounded-3xl p-6 shadow-lg shadow-gray-900/5",
            card.featured
              ? "order-first bg-gray-900 lg:order-0 dark:bg-black dark:ring-1 dark:ring-white/10"
              : "bg-white dark:bg-gray-800/90 dark:ring-1 dark:ring-white/10",
          ]}
        >
          <h3 class:list={[
            "flex items-center text-base font-semibold",
            card.featured ? "text-white" : "text-gray-900 dark:text-white",
          ]}>
            <svg
              viewBox="0 0 40 40"
              aria-hidden="true"
              class:list={[
                "h-6 w-6 flex-none",
                card.featured ? "fill-cyan-500 dark:fill-cyan-700" : "fill-gray-300 dark:fill-gray-500",
              ]}
            >
              <path fill-rule="evenodd" clip-rule="evenodd" d="M20 40C8.954 40 0 31.046 0 20S8.954 0 20 0s20 8.954 20 20-8.954 20-20 20ZM4 20c0 7.264 5.163 13.321 12.02 14.704C17.642 35.03 19 33.657 19 32V8c0-1.657-1.357-3.031-2.98-2.704C9.162 6.68 4 12.736 4 20Z"></path>
            </svg>
            <span class="ml-4">{card.title}</span>
          </h3>

          <p class:list={[
            "mt-3",
            card.featured ? "text-sm text-gray-300" : "text-sm text-gray-700 dark:text-gray-300",
          ]}>
            {card.description}
          </p>

          <div class="order-last mt-6">
            <ul
              role="list"
              class:list={[
                "-my-2 divide-y text-sm",
                card.featured
                  ? "divide-gray-800 text-gray-300"
                  : "divide-gray-200 dark:divide-gray-700 text-gray-700 dark:text-gray-300",
              ]}
            >
              {card.items.map((item) => (
                <li class="flex py-2">
                  <svg viewBox="0 0 24 24" aria-hidden="true" class="h-6 w-6 flex-none text-cyan-500 dark:text-cyan-700">
                    <path d="M9.307 12.248a.75.75 0 1 0-1.114 1.004l1.114-1.004ZM11 15.25l-.557.502a.75.75 0 0 0 1.15-.043L11 15.25Zm4.844-5.041a.75.75 0 0 0-1.188-.918l1.188.918Zm-7.651 3.043 2.25 2.5 1.114-1.004-2.25-2.5-1.114 1.004Zm3.4 2.457 4.25-5.5-1.187-.918-4.25 5.5 1.188.918Z" fill="currentColor"></path>
                    <circle cx="12" cy="12" r="8.25" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></circle>
                  </svg>
                  <span class="ml-4">{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <a
            class:list={[
              "inline-flex justify-center py-2 px-3 mt-6",
              card.featured ? "btn-info-cyan" : "btn-info-dark",
            ]}
            href={card.href}
          >
            {card.cta}
          </a>
        </article>
      ))}
    </div>

    <div
      class="mx-auto mt-8 grid max-w-2xl grid-cols-1 items-start gap-x-8 gap-y-10 lg:max-w-none lg:grid-cols-2 hidden"
      data-panel="nononcologic"
      role="tabpanel"
    >
      {nonOncologicCards.map((card) => (
        <article
          class:list={[
            "flex flex-col overflow-hidden rounded-3xl p-6 shadow-lg shadow-gray-900/5",
            card.featured
              ? "bg-gray-900 dark:bg-black dark:ring-1"
              : "bg-white dark:bg-gray-800/90 dark:ring-1",
          ]}
        >
          <h3 class:list={[
            "flex items-center text-sm xl:text-base font-semibold",
            card.featured ? "text-white" : "text-gray-900 dark:text-white",
          ]}>
            <svg
              viewBox="0 0 40 40"
              aria-hidden="true"
              class:list={[
                "h-6 w-6 flex-none",
                card.featured ? "fill-cyan-500 dark:fill-cyan-700" : "fill-gray-300 dark:fill-gray-500",
              ]}
            >
              <path fill-rule="evenodd" clip-rule="evenodd" d="M20 40C8.954 40 0 31.046 0 20S8.954 0 20 0s20 8.954 20 20-8.954 20-20 20ZM4 20c0 7.264 5.163 13.321 12.02 14.704C17.642 35.03 19 33.657 19 32V8c0-1.657-1.357-3.031-2.98-2.704C9.162 6.68 4 12.736 4 20Z"></path>
            </svg>
            <span class="ml-4">{card.title}</span>
          </h3>

          <p class:list={[
            "mt-3 text-sm",
            card.featured ? "text-gray-300" : "text-gray-700 dark:text-gray-300",
          ]}>
            {card.description}
          </p>

          <div class="order-last mt-6">
            <ul
              role="list"
              class:list={[
                "-my-2 divide-y text-sm",
                card.featured
                  ? "divide-gray-800 text-gray-300"
                  : "divide-gray-200 dark:divide-gray-700 text-gray-700 dark:text-gray-300",
              ]}
            >
              {card.items.map((item) => (
                <li class="flex py-2">
                  <svg viewBox="0 0 24 24" aria-hidden="true" class="h-6 w-6 flex-none text-cyan-500 dark:text-cyan-700">
                    <path d="M9.307 12.248a.75.75 0 1 0-1.114 1.004l1.114-1.004ZM11 15.25l-.557.502a.75.75 0 0 0 1.15-.043L11 15.25Zm4.844-5.041a.75.75 0 0 0-1.188-.918l1.188.918Zm-7.651 3.043 2.25 2.5 1.114-1.004-2.25-2.5-1.114 1.004Zm3.4 2.457 4.25-5.5-1.187-.918-4.25 5.5 1.188.918Z" fill="currentColor"></path>
                    <circle cx="12" cy="12" r="8.25" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></circle>
                  </svg>
                  <span class="ml-4">{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <a
            class:list={[
              "inline-flex justify-center py-2 px-3 mt-6",
              card.featured ? "btn-info-cyan" : "btn-info-dark",
            ]}
            href={card.href}
          >
            {card.cta}
          </a>
        </article>
      ))}
    </div>

    <div class="mx-auto mt-10 max-w-7xl text-sm sm:text-base leading-relaxed text-gray-600 dark:text-gray-300" data-footnote>
      <p>{t.oncologicFootnote}</p>
    </div>

    <div class="mx-auto mt-10 max-w-7xl text-base leading-relaxed text-gray-600 dark:text-gray-300 hidden" data-nononcologic-footnote>
      <p>{t.nonOncologicFootnote}</p>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const root = document.querySelector("[data-services-toggle]");
    if (!root) return;

    const btns = root.querySelectorAll("[role='radio'][data-mode]");
    const highlight = root.querySelector("[data-highlight]");
    const section = root.closest("section");
    if (!section) return;

    const panels = {
      oncologic: section.querySelector('[data-panel="oncologic"]'),
      nononcologic: section.querySelector('[data-panel="nononcologic"]'),
    };

    const oncologicFootnote = section.querySelector("[data-footnote]");
    const nonOncologicFootnote = section.querySelector("[data-nononcologic-footnote]");

    function setMode(mode) {
      btns.forEach((b) => {
        const isActive = b.getAttribute("data-mode") === mode;
        b.setAttribute("aria-checked", isActive ? "true" : "false");
        b.setAttribute("data-active", isActive ? "true" : "false");
        b.tabIndex = isActive ? 0 : -1;
      });

      if (highlight) {
        highlight.style.clipPath =
          mode === "oncologic" ? "inset(0 50% 0 0)" : "inset(0 0 0 50%)";
      }

      Object.entries(panels).forEach(([key, el]) => {
        if (!el) return;
        el.classList.toggle("hidden", key !== mode);
      });

      if (oncologicFootnote) {
        oncologicFootnote.classList.toggle("hidden", mode !== "oncologic");
      }

      if (nonOncologicFootnote) {
        nonOncologicFootnote.classList.toggle("hidden", mode !== "nononcologic");
      }
    }

    setMode("oncologic");

    btns.forEach((btn) => {
      btn.addEventListener("click", () => setMode(btn.getAttribute("data-mode")));
      btn.addEventListener("keydown", (e) => {
        if (e.key !== "ArrowLeft" && e.key !== "ArrowRight") return;
        e.preventDefault();
        const idx = Array.from(btns).indexOf(btn);
        const next = e.key === "ArrowRight"
          ? Math.min(idx + 1, btns.length - 1)
          : Math.max(idx - 1, 0);
        btns[next].click();
        btns[next].focus();
      });
    });
  })();
</script>