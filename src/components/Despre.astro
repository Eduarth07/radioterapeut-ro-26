---
import { DEFAULT_LOCALE, type SiteLocale } from "../i18n/config";
import { aboutContent } from "../i18n/home/about";
import { Image } from "astro:assets";

// Importăm pozele din assets
import imgProfile from "../assets/d1.png"; 
import imgSecondary from "../assets/about-2-light.webp";

const { locale = DEFAULT_LOCALE } = Astro.props as {
  locale?: SiteLocale;
};

const t = aboutContent[locale];

// MAGIA E-E-A-T: Generăm o schemă detaliată pentru medic
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": t.personName,
  "jobTitle": "Medic Specialist Radioterapie",
  "description": t.intro,
  // Spunem AI-ului din ce organizații face parte medicul (ESTRO, ISRS etc.)
  "memberOf": t.affiliations.map(item => ({
    "@type": "Organization",
    "name": item.title,
    "url": item.href
  })),
  // Educație și experiență (Harvard, ESO etc.)
  "alumniOf": t.experience.map(item => ({
    "@type": "Organization",
    "name": item.org || item.title,
    "url": item.href
  }))
};
---

<section
  id="despre"
  aria-label={t.sectionAriaLabel}
  class="relative scroll-mt-12 md:scroll-mt-0 py-16 sm:py-20 lg:py-24"
>
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto text-center">
      <h2 id="despre-title" class="text-3xl font-medium tracking-tight text-gray-900 dark:text-white lg:pb-2">
        {t.sectionTitle}
      </h2>
    </div>

    <div class="mt-6 lg:mt-12 grid gap-6 lg:gap-10 lg:grid-cols-12 lg:items-stretch">
      <div class="lg:col-span-4 lg:block">
        <div class="max-h-[320px] md:max-h-[540px] overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm dark:border-white/10 dark:bg-gray-900">
          <Image
            src={imgProfile}
            alt={t.image1Alt}
            loading="lazy"
            decoding="async"
            class="h-full w-full object-cover"
          />
        </div>
      </div>

      <div class="lg:col-span-8">
        <h3 class="text-3xl font-medium tracking-tight text-gray-900 dark:text-gray-100 text-center lg:text-left">
          {t.personName}
        </h3>

        <p class="mt-4 text-base xl:text-lg leading-relaxed text-gray-600 dark:text-gray-300">
          {t.intro}
        </p>

        <div class="mt-6 lg:mt-8">
          <h4 class="text-xl font-medium text-gray-900 dark:text-cyan-500">
            {t.experienceTitle}
          </h4>

          <ul role="list" class="mt-4 space-y-4 border-l border-gray-200 pl-0 dark:border-white/10">
            {t.experience.map((item) => (
              <li class="block">
                <a
                  href={item.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group block border-l-4 border-transparent pl-3 hover:border-cyan-500"
                >
                  <div class="text-base font-medium text-gray-900 group-hover:text-cyan-700 dark:text-white dark:group-hover:text-cyan-400">
                    {item.title}
                  </div>
                  {item.org && (
                    <div class="text-base text-gray-700 dark:text-gray-200">
                      <em>{item.org}</em>
                    </div>
                  )}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <div class="mt-8 lg:mt-15 grid gap-6 lg:gap-10 lg:grid-cols-12 lg:items-center">
      <div class="order-first lg:order-last lg:col-span-6 lg:pt-5">
        <div class="overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm dark:border-white/10 dark:bg-gray-900">
          <Image
            src={imgSecondary}
            alt={t.image2Alt}
            loading="lazy"
            decoding="async"
            class="h-full w-full object-contain object-right"
          />
        </div>
      </div>

      <div class="lg:col-span-6">
        <h4 class="text-xl font-medium text-gray-900 dark:text-cyan-500">
          {t.volunteeringTitle}
        </h4>

        <ul role="list" class="mt-4 space-y-1 border-l border-gray-200 pl-0 dark:border-white/10">
          {t.volunteering.map((item) => (
            <li class="block">
              <a
                href={item.href}
                target="_blank"
                rel="noopener noreferrer"
                class="group block border-l-4 border-transparent pl-3 hover:border-cyan-500"
              >
                <div class="text-base font-medium text-gray-900 group-hover:text-cyan-700 dark:text-white dark:group-hover:text-cyan-300 cursor-pointer">
                  {item.title}
                </div>
              </a>
            </li>
          ))}
        </ul>

        <h4 class="mt-6 lg:mt-10 text-xl font-medium text-gray-900 dark:text-cyan-500">
          {t.skillsTitle}
        </h4>

        <ul role="list" class="mt-4 space-y-1 border-l border-gray-200 pl-0 dark:border-white/10">
          {t.skills.map((item) => (
            <li class="block">
              <a
                href={item.href}
                target="_blank"
                rel="noopener noreferrer"
                class="group block border-l-4 border-transparent pl-3 hover:border-cyan-500"
              >
                <div class="text-base font-medium text-gray-900 group-hover:text-cyan-700 dark:text-white dark:group-hover:text-cyan-300 cursor-pointer">
                  {item.title}
                </div>
                {item.org && (
                  <div class="text-base text-gray-700 dark:text-gray-200">
                    <em>{item.org}</em>
                  </div>
                )}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <h4 class="mt-6 text-xl font-medium text-gray-900 dark:text-cyan-500">
      {t.affiliationsTitle}
    </h4>

    <ul role="list" class="mt-4 space-y-3 border-l border-gray-200 pl-0 dark:border-white/10">
      {t.affiliations.map((item) => (
        <li class="block">
          <a
            href={item.href}
            target="_blank"
            rel="noopener noreferrer"
            class="group block border-l-4 border-transparent pl-3 hover:border-cyan-500"
          >
            <div class="text-base font-medium text-gray-900 group-hover:text-cyan-700 dark:text-white dark:group-hover:text-cyan-300 cursor-pointer">
              {item.title}
            </div>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>