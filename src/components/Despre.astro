---

<section
  id="despre"
  aria-label="Despre mine"
  class="relative scroll-mt-12 md:scroll-mt-0 py-16 sm:py-20 lg:py-24"
>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mx-auto text-center">
      <h2 id="servicii-title" class="text-3xl font-medium tracking-tight text-gray-900 dark:text-white lg:pb-2 ">
        Despre mine
      </h2>
    </div>

    <!-- Row 1: imagine stânga (desktop) + text -->
    <div class="mt-6 lg:mt-12 grid gap-6 lg:gap-10 lg:grid-cols-12 lg:items-stretch">
      <!-- Image (desktop only, ca în site-ul vechi) -->
      <div class=" lg:col-span-4 lg:block">
        <div class="max-h-[320px] md:max-h-[540px] overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm dark:border-white/10 dark:bg-gray-900">
          <img
            src="/d1.png"
            alt="Poza 1 Cirimpei Tatiana"
            loading="lazy"
            decoding="async"
            class="h-full w-full object-cover"
          />
        </div>
      </div>

      <!-- Text -->
      <div class="lg:col-span-8">
        <h3 class="text-3xl font-medium tracking-tight text-gray-900 dark:text-gray-100 text-center lg:text-left">
          Cirimpei Tatiana
        </h3>

        <p class="mt-4 text-base xl:text-lg leading-relaxed text-gray-600 dark:text-gray-300">
          {memberships}
        </p>

        <div class="mt-6 lg:mt-8">
          <h4 class="text-xl font-medium text-gray-900 dark:text-cyan-500">
            Experiență profesională
          </h4>

          <div class="mt-4 space-y-4 border-l border-gray-200 pl-4 dark:border-white/10">
            {experience.map((item) => (
              <a
                href={item.href}
                target="_blank"
                rel="noopener noreferrer"
                class="group block border-l-4 border-transparent pl-3 hover:border-cyan-500"
              >
                <div class="text-base text-gray-900 group-hover:text-cyan-700 dark:text-white dark:group-hover:text-cyan-400">
                  {item.title}
                </div>

                <div class="text-base text-gray-700 dark:text-gray-200">
                  <em>{item.org}</em>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Row 2: text (voluntariat + competențe) + imagine (dreapta pe desktop, sus pe mobile) -->
    <div class="mt-8 lg:mt-15 grid gap-6 lg:gap-10 lg:grid-cols-12 lg:items-center">
      <!-- Image: order-first on mobile, last on desktop (ca în vechi) -->
      <div class="order-first lg:order-last lg:col-span-6 lg:pt-5">
        <div class="overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm dark:border-white/10 dark:bg-gray-900">
          <img
            src="/about-2-light.webp"
            alt="Poza 2 Cirimpei Tatiana"
            loading="lazy"
            decoding="async"
            class="h-full w-full object-contain object-right"
          />
        </div>
      </div>

      <!-- Lists -->
      <div class="lg:col-span-6">
        <h4 class="text-xl font-medium text-gray-900 dark:text-cyan-500">
          Activități de voluntariat
        </h4>

        <div class="mt-4 space-y-1 border-l border-gray-200 pl-4 dark:border-white/10">
          {volunteering.map((item) => (
          <a
            href={item.href}
            target="_blank"
            rel="noopener noreferrer"
            class="group block border-l-4 border-transparent pl-3 hover:border-cyan-500"
          >
            <div class="text-base text-gray-900 group-hover:text-cyan-700 dark:text-white dark:group-hover:text-cyan-300 cursor-pointer">
              {item.title}
            </div>
          </a>
          ))}
        </div>

        <h4 class="mt-6 lg:mt-10 text-xl font-medium text-gray-900 dark:text-cyan-500">
          Certificări și competențe
        </h4>

      <div class="mt-4 space-y-1 border-l border-gray-200 pl-4 dark:border-white/10">
        {skills.map((item) => (
          <a
            href={item.href}
            target="_blank"
            rel="noopener noreferrer"
            class="group block border-l-4 border-transparent pl-3 hover:border-cyan-500"
          >
            <div class="text-base text-gray-900 group-hover:text-cyan-700 dark:text-white dark:group-hover:text-cyan-300 cursor-pointer">
              {item.title}
            </div>
            <div class="text-base text-gray-700 dark:text-gray-200">
              <em>{item.org}</em>
            </div>
          </a>
        ))}
      </div>


      </div>
      
    </div>
        <h4 class="mt-6 text-xl font-medium text-gray-900 dark:text-cyan-500">
          Afilier profesionale și participări active
        </h4>
      <div class="mt-4 space-y-3 border-l border-gray-200 pl-4 dark:border-white/10">
        {afilieri.map((item) => (
           <a
            href={item.href}
            target="_blank"
            rel="noopener noreferrer"
            class="group block border-l-4 border-transparent pl-3 hover:border-cyan-500"
          > 
            <div class="text-base text-gray-900 group-hover:text-cyan-700 dark:text-white dark:group-hover:text-cyan-300 cursor-pointer">
              {item.title}
            </div>
          </a>
        ))}
</div>
  </div>
</section>
