---
import {
  LOCALE_LABELS_BY_UI_LOCALE,
  SUPPORTED_LOCALES,
  type SiteLocale,
} from "../i18n/config";
import { getLocalePath, normalizePath } from "../i18n/paths";

const uid = `lang-${Math.random().toString(36).slice(2, 8)}`;

const {
  currentLocale = "ro",
  currentPath = "/",
  pathByLocale,
} = Astro.props as {
  currentLocale?: SiteLocale;
  currentPath?: string;
  pathByLocale?: Partial<Record<SiteLocale, string>>;
};

const normalizedPath = normalizePath(currentPath);
const uiLabels = LOCALE_LABELS_BY_UI_LOCALE[currentLocale];
const globeIcon = `
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960" class="h-6 w-6" fill="currentColor" aria-hidden="true">
    <path d="M325-111.5q-73-31.5-127.5-86t-86-127.5Q80-398 80-480.5t31.5-155q31.5-72.5 86-127t127.5-86Q398-880 480.5-880t155 31.5q72.5 31.5 127 86t86 127Q880-563 880-480.5T848.5-325q-31.5 73-86 127.5t-127 86Q563-80 480.5-80T325-111.5ZM480-162q26-36 45-75t31-83H404q12 44 31 83t45 75Zm-104-16q-18-33-31.5-68.5T322-320H204q29 50 72.5 87t99.5 55Zm208 0q56-18 99.5-55t72.5-87H638q-9 38-22.5 73.5T584-178ZM170-400h136q-3-20-4.5-39.5T300-480q0-21 1.5-40.5T306-560H170q-5 20-7.5 39.5T160-480q0 21 2.5 40.5T170-400Zm216 0h188q3-20 4.5-39.5T580-480q0-21-1.5-40.5T574-560H386q-3 20-4.5 39.5T380-480q0 21 1.5 40.5T386-400Zm268 0h136q5-20 7.5-39.5T800-480q0-21-2.5-40.5T790-560H654q3 20 4.5 39.5T660-480q0 21-1.5 40.5T654-400Zm-16-240h118q-29-50-72.5-87T584-782q18 33 31.5 68.5T638-640Zm-234 0h152q-12-44-31-83t-45-75q-26 36-45 75t-31 83Zm-200 0h118q9-38 22.5-73.5T376-782q-56 18-99.5 55T204-640Z"/>
  </svg>
`;

const flagIcons: Record<SiteLocale, string> = {
  ro: `
    <svg data-lang="ro" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" class="h-8 w-8 transition-transform duration-200 hover:scale-110" style="filter: drop-shadow(0 1px 1px rgba(0,0,0,0.4));" aria-hidden="true">
      <path style="fill:#1857b6;" d="M38.345,88.273C17.167,88.273,0,105.44,0,126.618v258.759c0,21.177,17.167,38.345,38.345,38.345h132.322V88.273H38.345z"/>
      <rect x="170.67" y="88.277" style="fill:#FFE15A;" width="170.67" height="335.45"/>
      <path style="fill:#FF4B55;" d="M473.655,88.273H341.333v335.448h132.322c21.177,0,38.345-17.167,38.345-38.345V126.618C512,105.44,494.833,88.273,473.655,88.273z"/>
    </svg>
  `,
  en: `
    <svg data-lang="en" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" class="h-8 w-8 transition-transform duration-200 hover:scale-110" style="filter: drop-shadow(0 1px 1px rgba(0,0,0,0.4));" aria-hidden="true">
      <path style="fill:#41479B;" d="M473.655,88.276H38.345C17.167,88.276,0,105.443,0,126.621V385.38c0,21.177,17.167,38.345,38.345,38.345h435.31c21.177,0,38.345-17.167,38.345-38.345V126.621C512,105.443,494.833,88.276,473.655,88.276z"/>
      <path style="fill:#F5F5F5;" d="M511.469,120.282c-3.022-18.159-18.797-32.007-37.814-32.007h-9.977l-163.54,107.147V88.276h-88.276v107.147L48.322,88.276h-9.977c-19.017,0-34.792,13.847-37.814,32.007l139.778,91.58H0v88.276h140.309L0.531,391.717c3.022,18.159,18.797,32.007,37.814,32.007h9.977l163.54-107.147v107.147h88.276V316.577l163.54,107.147h9.977c19.017,0,34.792-13.847,37.814-32.007l-139.778-91.58H512v-88.276H371.691L511.469,120.282z"/>
      <g>
        <polygon style="fill:#FF4B55;" points="282.483,88.276 229.517,88.276 229.517,229.517 0,229.517 0,282.483 229.517,282.483 229.517,423.724 282.483,423.724 282.483,282.483 512,282.483 512,229.517 282.483,229.517"/>
        <path style="fill:#FF4B55;" d="M24.793,421.252l186.583-121.114h-32.428L9.224,410.31C13.377,415.157,18.714,418.955,24.793,421.252z"/>
        <path style="fill:#FF4B55;" d="M346.388,300.138H313.96l180.716,117.305c5.057-3.321,9.277-7.807,12.287-13.075L346.388,300.138z"/>
        <path style="fill:#FF4B55;" d="M4.049,109.475l157.73,102.387h32.428L15.475,95.842C10.676,99.414,6.749,104.084,4.049,109.475z"/>
        <path style="fill:#FF4B55;" d="M332.566,211.862l170.035-110.375c-4.199-4.831-9.578-8.607-15.699-10.86L300.138,211.862H332.566z"/>
      </g>
    </svg>
  `,
  uk: `
    <svg data-lang="uk" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" class="h-8 w-8 transition-transform duration-200 hover:scale-110" style="filter: drop-shadow(0 1px 1px rgba(0,0,0,0.4));" aria-hidden="true">
      <path style="fill:#FFE15A;" d="M0,385.379c0,21.177,17.167,38.345,38.345,38.345h435.31c21.177,0,38.345-17.167,38.345-38.345V256H0V385.379z"/>
      <path style="fill:#4173CD;" d="M473.655,88.276H38.345C17.167,88.276,0,105.443,0,126.621V256h512V126.621C512,105.443,494.833,88.276,473.655,88.276z"/>
    </svg>
  `,
};

function getBadgeIcon(locale: SiteLocale) {
  const svg = flagIcons[locale];

  return svg
    .replace('class="h-8 w-8 transition-transform duration-200 hover:scale-110"', 'class="h-4 w-4"')
    .replace('style="filter: drop-shadow(0 1px 1px rgba(0,0,0,0.4));"', "");
}

const options = SUPPORTED_LOCALES.map((locale) => ({
  locale,
  label: uiLabels[locale],
  href: pathByLocale?.[locale] ?? getLocalePath(locale, normalizedPath),
  isCurrent: locale === currentLocale,
  icon: flagIcons[locale],
  badgeIcon: getBadgeIcon(locale),
}));

const currentOption = options.find((option) => option.isCurrent) ?? options[0];
const otherOptions = options.filter((option) => !option.isCurrent);
---

<div class="relative">
  <button
    id={`${uid}-button`}
    type="button"
    class="relative inline-flex h-10 w-10 items-center justify-center text-gray-700 transition-transform duration-200 hover:scale-105 dark:text-gray-300 cursor-pointer"
    aria-label={currentOption.label}
    title={currentOption.label}
    aria-expanded="false"
    aria-controls={`${uid}-menu`}
  >
    <span class="relative z-0 inline-flex" set:html={globeIcon} />

    <span
      class="pointer-events-none absolute right-[1px] top-[1px] z-10 inline-flex"
      set:html={currentOption.badgeIcon}
    />

    <span class="sr-only">{currentOption.label}</span>
  </button>


<div
  id={`${uid}-menu`}
  class="absolute left-1/2 top-full z-50 hidden w-auto -translate-x-1/2 overflow-hidden rounded-lg bg-gray-100 shadow-sm dark:bg-gray-700 "
>
  <ul class="text-sm text-gray-700 dark:text-gray-200">
    {otherOptions.map((option) => (
      <li>
        <a
          href={option.href}
          class="group flex w-full items-center justify-start gap-2 px-3 py-2 hover:bg-gray-200 hover:shadow-md dark:hover:bg-gray-600 sm:px-3 sm:py-2"
          aria-label={option.label}
        >
          <span
            class="inline-flex shrink-0 transition-transform duration-200 group-hover:scale-110"
            set:html={option.icon}
          />
          <span class="text-sm font-medium ">{option.label}</span>
          <span class="sr-only">{option.label}</span>
        </a>
      </li>
    ))}
  </ul>
</div>
</div>

<script is:inline define:vars={{ uid }}>
  (() => {
    const btn = document.getElementById(`${uid}-button`);
    const menu = document.getElementById(`${uid}-menu`);

    if (!btn || !menu) return;

    const closeMenu = () => {
      menu.classList.add("hidden");
      btn.setAttribute("aria-expanded", "false");
    };

    const openMenu = () => {
      menu.classList.remove("hidden");
      btn.setAttribute("aria-expanded", "true");
    };

    btn.addEventListener("click", (event) => {
      event.preventDefault();
      const isOpen = !menu.classList.contains("hidden");
      if (isOpen) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    document.addEventListener("mousedown", (event) => {
      const target = event.target;
      if (!(target instanceof Node)) return;
      if (btn.contains(target) || menu.contains(target)) return;
      closeMenu();
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        closeMenu();
      }
    });
  })();
</script>