---
import "../styles/global.css";
import "@fontsource-variable/inter";
import ScrollToTopButton from "../components/ScrollToTopButton.astro";
import {
  DEFAULT_LOCALE,
  LOCALE_HREFLANG,
  SITE_URL,
  type SiteLocale,
} from "../i18n/config";
import { normalizePath } from "../i18n/paths";

type AlternateLink = {
  locale: SiteLocale;
  href: string;
};

type JsonLdObject = Record<string, unknown>;

const localeToOgLocale: Record<SiteLocale, string> = {
  ro: "ro_RO",
  en: "en_US",
  uk: "uk_UA",
};

const {
  title = "Dr. Tatiana Cirimpei - Radioterapie",
  description = "Radioterapie modernă, informații pentru pacienți și trimitere către programare.",
  locale = DEFAULT_LOCALE,
  canonicalPath = "/",
  alternates = [],
  xDefaultHref,
  ogImage = "/webpreview.png",
  ogImageAlt = "Dr. Tatiana Cirimpei - Radioterapie",
  ogType = "website",
  twitterCard = "summary_large_image",
  noindex = false,
  structuredData,
} = Astro.props as {
  title?: string;
  description?: string;
  locale?: SiteLocale;
  canonicalPath?: string;
  alternates?: AlternateLink[];
  xDefaultHref?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: "website" | "article" | "profile";
  twitterCard?: "summary" | "summary_large_image";
  noindex?: boolean;
  structuredData?: JsonLdObject | JsonLdObject[];
};

const siteUrl = Astro.site ?? new URL(SITE_URL);

const normalizeAbsoluteUrl = (value: string) => {
  const url = new URL(value, siteUrl);

  if (url.pathname !== "/") {
    url.pathname = url.pathname.replace(/\/+$/, "");
  }

  return url.toString();
};

const normalizedCanonicalPath = normalizePath(canonicalPath);
const canonicalUrl = normalizeAbsoluteUrl(normalizedCanonicalPath);

const normalizedAlternates = alternates.map((item) => ({
  ...item,
  href: normalizeAbsoluteUrl(item.href),
}));

const resolvedXDefaultHref = normalizeAbsoluteUrl(
  xDefaultHref ??
    normalizedAlternates.find((item) => item.locale === DEFAULT_LOCALE)?.href ??
    canonicalUrl
);

const ogImageUrl = new URL(ogImage, siteUrl).toString();
const robotsContent = noindex ? "noindex, follow" : "index, follow";

const extraStructuredData = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];

const physicianId = new URL("/#physician", siteUrl).toString();
const homepageUrl = new URL("/", siteUrl).toString();

const baseStructuredData: JsonLdObject = {
  "@context": "https://schema.org",
  "@type": "Physician",
  "@id": physicianId,
  name: "Dr. Tatiana Cirimpei",
  medicalSpecialty: "RadiationTherapy",
  url: homepageUrl,
  image: ogImageUrl,
};

const mergedStructuredData = [baseStructuredData, ...extraStructuredData];
---

<!doctype html>
<html lang={locale} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />

    <meta name="color-scheme" content="light dark" />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: light)"
      content="#ffffff"
    />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: dark)"
      content="#0b1220"
    />

    <link rel="canonical" href={canonicalUrl} />
    {normalizedAlternates.map((item) => (
      <link
        rel="alternate"
        hreflang={LOCALE_HREFLANG[item.locale]}
        href={item.href}
      />
    ))}
    <link rel="alternate" hreflang="x-default" href={resolvedXDefaultHref} />

    <meta property="og:locale" content={localeToOgLocale[locale]} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Radioterapeut.ro" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={ogImageAlt} />

    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/android-chrome-192x192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/android-chrome-512x512.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <script
      type="application/ld+json"
      set:html={JSON.stringify(mergedStructuredData)}
    />

    <slot name="head" />

    <script is:inline>
      (() => {
        try {
          const key = "rt-theme";
          const stored = localStorage.getItem(key);
          const systemDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          const isDark = stored ? stored === "dark" : systemDark;
          document.documentElement.classList.toggle("dark", isDark);
        } catch {}
      })();
    </script>
  </head>

  <body class="min-h-screen antialiased">
    <slot />
    <ScrollToTopButton />
  </body>
</html>