---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { articles } from "../../data/articles";

export function getStaticPaths() {
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
---

<BaseLayout title={`${article.title} | Articole`} description={article.excerpt}>
  <Header />

  <main class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
    <nav aria-label="Breadcrumb" class="mb-6 text-sm text-muted">
      <a href="/" class="transition-colors hover:text-ink">Acasă</a>
      <span class="mx-2">/</span>
      <a href="/articole" class="transition-colors hover:text-ink">Articole</a>
      <span class="mx-2">/</span>
      <span class="text-ink">{article.title}</span>
    </nav>

    <article class="mx-auto max-w-4xl rounded-2xl border border-(--rt-border) bg-surface p-6 shadow-sm sm:p-8 lg:p-10">
      <header class="mb-8">
        <div class="flex flex-col gap-6 md:flex-row md:items-start">
          <img
            src={article.coverImage}
            alt={article.coverAlt}
            loading="eager"
            decoding="async"
            class="h-[195px] w-full rounded-xl object-cover md:w-[293px]"
          />

          <div class="flex-1">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand-600">{article.category}</p>
            <h1 class="mt-3 text-3xl font-semibold leading-tight text-ink sm:text-4xl">{article.title}</h1>
            <p class="mt-4 text-sm text-muted">Redactat: {article.author}</p>
            <div class="mt-2 text-sm text-muted">
              <time>{article.date}</time>
              <span aria-hidden="true" class="mx-2">•</span>
              <span>{article.readTime} citire</span>
            </div>
          </div>
        </div>
      </header>

      <div class="article-content text-base leading-relaxed text-ink" set:html={article.contentHtml} />

      <footer class="mt-10 border-t border-(--rt-border) pt-6">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
          <div class="flex flex-wrap items-center gap-2">
            <span class="text-sm text-muted">Etichete:</span>
            {article.tags.map((tag) => (
              <span class="inline-flex rounded-md bg-surface-2 px-3 py-1 text-xs font-semibold text-muted">{tag}</span>
            ))}
          </div>

          <a
            href="/articole"
            class="inline-flex rounded-lg border border-(--rt-border) px-4 py-2 text-sm font-semibold text-muted transition hover:border-brand-600 hover:text-brand-700"
          >
            ← Înapoi la articole
          </a>
        </div>
      </footer>
    </article>
  </main>

  <Footer />
</BaseLayout>

<style>
  .article-content :global(p) {
    margin-bottom: 1rem;
    color: var(--rt-ink);
  }

  .article-content :global(h3) {
    margin-top: 1.75rem;
    margin-bottom: 0.75rem;
    font-size: 1.375rem;
    line-height: 1.25;
    font-weight: 600;
    color: var(--rt-ink);
  }

  .article-content :global(h4) {
    margin-top: 1.25rem;
    margin-bottom: 0.6rem;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--rt-ink);
  }

  .article-content :global(ul) {
    margin: 0 0 1rem 1.25rem;
    list-style: disc;
  }

  .article-content :global(li) {
    margin-bottom: 0.4rem;
  }

  .article-content :global(blockquote) {
    margin: 1.6rem 0;
    border-left: 4px solid var(--rt-brand-500);
    background: var(--rt-surface-2);
    padding: 1rem 1.1rem;
    font-weight: 500;
    color: var(--rt-ink);
    border-radius: 0.5rem;
  }

  html.dark .article-content :global(p),
  html.dark .article-content :global(h3),
  html.dark .article-content :global(h4),
  html.dark .article-content :global(li),
  html.dark .article-content :global(blockquote) {
    color: var(--rt-ink);
  }
</style>
