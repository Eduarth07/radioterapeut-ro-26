---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import { getArticleLocalePaths, getArticlesForLocale } from "../../../data/articles.i18n";
import type { SiteLocale } from "../../../i18n/config";

export function getStaticPaths() {
  const articles = getArticlesForLocale("uk");
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const articlePath = `/uk/articole/${article.slug}`;
const shareUrl = new URL(articlePath, Astro.site ?? "https://radioterapeut.ro").toString();
const shareTitle = article.title;
const categoryLink = `/uk/articole?categorie=${encodeURIComponent(article.category)}`;
const articleLocalePaths = getArticleLocalePaths(article.id);
const alternates = articleLocalePaths
  ? Object.entries(articleLocalePaths).map(([locale, path]) => ({
      locale: locale as SiteLocale,
      href: new URL(path, Astro.site ?? "https://radioterapeut.ro").toString(),
    }))
  : [];

// Schema E-E-A-T pentru articol medical în limba ucraineană
const articleSchema = {
  "@context": "https://schema.org",
  "@type": ["Article", "MedicalWebPage"],
  "headline": article.title,
  "description": article.excerpt,
  "inLanguage": "uk",
  "image": new URL(article.articleImage, Astro.site ?? "https://radioterapeut.ro").toString(),
  "datePublished": article.date,
  "author": {
    "@type": "Physician",
    "name": article.author,
    "url": "https://radioterapeut.ro/uk/#despre" 
  }
};
---

<BaseLayout
  title={`${article.title} | Статті`}
  description={article.excerpt}
  locale="uk"
  canonicalPath={articlePath}
  alternates={alternates}
>
  <Header locale="uk" currentPath={articlePath} pathByLocale={articleLocalePaths} />

  <main class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

    <nav aria-label="Breadcrumb" class="mb-6 text-sm text-muted">
      <a href="/uk/" class="hover:text-ink">Головна</a>
      <span class="mx-2">/</span>
      <a href="/uk/articole" class="hover:text-ink">Статті</a>
      <span class="mx-2">/</span>
      <span class="text-gray-700 dark:text-gray-300">{article.title}</span>
    </nav>

    <article class="mx-auto max-w-4xl rounded-2xl border border-(--rt-border) bg-surface dark:border-cyan-900 p-6 shadow-sm sm:p-8 lg:p-10">
      <header class="mb-8">
        <div class="flex flex-col gap-6 md:flex-row md:items-stretch">
          <div class="h-full w-full overflow-hidden rounded-xl bg-surface-2 md:w-[293px] md:shrink-0 shadow-sm">
            <img
              src={article.articleImage}
              alt={article.coverAlt}
              loading="eager"
              fetchpriority="high" 
              decoding="async"
              class="h-[240px] w-full object-cover object-center md:h-full"
            />
          </div>

          <div class="flex flex-1 flex-col justify-center">
            <a
              href={categoryLink}
              class="inline-flex w-fit text-xs font-semibold uppercase tracking-[0.2em] text-cyan-700 hover:text-cyan-800 dark:text-cyan-500 dark:hover:text-cyan-300"
            >
              {article.category}
            </a>
            <h1 class="mt-3 text-3xl font-semibold leading-tight text-ink">{article.title}</h1>
            <p class="mt-4 text-sm text-muted">Автор: {article.author}</p>
            <div class="mt-2 text-sm text-muted">
              <time>{article.date}</time>
              <span aria-hidden="true" class="mx-2">•</span>
              <span>{article.readTime} читання</span>
            </div>
          </div>
        </div>
      </header>

      <div class="article-content text-base leading-relaxed text-ink" set:html={article.contentHtml} />

      <footer class="mt-10 border-t border-(--rt-border) pt-6">
         </footer>
    </article>
  </main>

  <Footer locale="uk" />
</BaseLayout>

<style>
  .article-content :global(p) {
    margin-bottom: 1rem;
    color: var(--rt-ink);
  }

  .article-content :global(h3) {
    margin-top: 1.75rem;
    margin-bottom: 0.75rem;
    font-size: 1.375rem;
    line-height: 1.25;
    font-weight: 600;
    color: var(--rt-ink);
  }

  .article-content :global(h4) {
    margin-top: 1.25rem;
    margin-bottom: 0.6rem;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--rt-ink);
  }

  .article-content :global(ul) {
    margin: 0 0 1rem 1.25rem;
    list-style: disc;
  }

  .article-content :global(li) {
    margin-bottom: 0.4rem;
  }

  .article-content :global(blockquote) {
    margin: 1.6rem 0;
    border-left: 4px solid var(--rt-brand-500);
    background: var(--rt-surface-2);
    padding: 1rem 1.1rem;
    font-weight: 500;
    color: var(--rt-ink);
    border-radius: 0.5rem;
  }

  html.dark .article-content :global(p),
  html.dark .article-content :global(h3),
  html.dark .article-content :global(h4),
  html.dark .article-content :global(li),
  html.dark .article-content :global(blockquote) {
    color: var(--rt-ink);
  }
</style>