---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ArticlesIndex from "../../components/ArticlesIndex.astro";
import { getAlternateLinks } from "../../i18n/paths";
---

<BaseLayout
  title="Статті | Др. Тетяна Чирімпей - Радіотерапія"
  description="Медичні статті про променеву терапію, онкологію та корисну інформацію для пацієнтів."
  locale="uk"
  canonicalPath="/uk/articole"
  alternates={getAlternateLinks("/articole")}
>
  <Header locale="uk" currentPath="/articole" />
  <ArticlesIndex locale="uk" />
  <Footer locale="uk" />
</BaseLayout>