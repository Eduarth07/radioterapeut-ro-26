---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ArticlesIndex from "../../components/ArticlesIndex.astro";
import { getAlternateLinks } from "../../i18n/paths";
---

<BaseLayout
  title="Medical Blog - Articles and Updates on Radiotherapy | Dr. Tatiana Cirimpei"
  description="Read medical articles written by Dr. Tatiana Cirimpei. Guides, news, and essential information about radiotherapy and oncology treatments for patients."
  locale="en"
  canonicalPath="/en/articole"
  alternates={getAlternateLinks("/articole")}
>
  <Header locale="en" currentPath="/articole" />
  <ArticlesIndex locale="en" />
  <Footer locale="en" />
</BaseLayout>