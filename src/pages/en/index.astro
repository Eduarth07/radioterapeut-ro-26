---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Hero from "../../components/Hero.astro";
import Servicii from "../../components/Servicii.astro";
import Despre from "../../components/Despre.astro";
import Faq from "../../components/Faq.astro";
import Programare from "../../components/Programare.astro";
import Footer from "../../components/Footer.astro";
import { getAlternateLinks } from "../../i18n/paths";
---

<BaseLayout
  title="Dr. Tatiana Cirimpei - Radiotherapy"
  description="Medical consultations and personalized radiotherapy treatments in Cluj-Napoca."
  locale="en"
  canonicalPath="/en"
  alternates={getAlternateLinks("/")}
>
  <Header locale="en" currentPath="/" />
  <Hero locale="en" />
  <Servicii locale="en" />
  <Despre locale="en" />
  <Faq locale="en" />
  <Programare locale="en" />
  <Footer locale="en" />
</BaseLayout>