---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const componentId = `rt-quiz-${Math.random().toString(36).slice(2, 9)}`;
---

<BaseLayout
  title="Evaluare Continuă Radioterapie | Dr. Cirimpei Tatiana"
  description="Modul educațional pentru medici radioterapeuți. Testează-ți cunoștințele cu grile din ghidurile ESTRO și trialurile clinice recente."
>
  <Header />

  <section class="rt-quiz" id={componentId}>
    <div class="rt-quiz__shell">
      <div class="rt-quiz__screen is-active" data-screen="start">
        <div class="rt-quiz__header-center">
          <p class="rt-quiz__eyebrow">Continuous Medical Education (CME)</p>
          <h2 class="rt-quiz__title">Modul de Evaluare Clinică</h2>
          <p class="rt-quiz__intro">
            Testul constă în <strong>10 întrebări tip grilă</strong> selectate aleatoriu dintr-o bază extinsă de date.
            Întrebările acoperă ghidurile standard ESTRO, trialuri clinice majore și concepte de radiobiologie/fizică modernă.
          </p>

          <div class="rt-quiz__start-meta">
            <div class="rt-quiz__meta-pill">10 întrebări / sesiune</div>
            <div class="rt-quiz__meta-pill">Răspuns instant</div>
            <div class="rt-quiz__meta-pill">Feedback explicativ</div>
          </div>

          <button type="button" class="rt-quiz__btn rt-quiz__btn--primary" data-action="start">
            Începe Testul
          </button>
        </div>
      </div>

      <div class="rt-quiz__screen" data-screen="quiz" hidden>
        <div class="rt-quiz__topbar">
          <div class="rt-quiz__progress-text">
            <span>Întrebarea <strong data-current-q>1</strong> din <strong data-total-q>10</strong></span>
            <span class="rt-quiz__score-live">Scor curent: <span data-live-score>0</span></span>
          </div>

          <div class="rt-quiz__progress-bar" aria-hidden="true">
            <div class="rt-quiz__progress-fill" data-progress-fill></div>
          </div>
        </div>

        <div class="rt-quiz__card">
          <div class="rt-quiz__card-header">
            <h3 class="rt-quiz__question-text" data-question-text>Încărcare întrebare...</h3>
          </div>
          
          <div class="rt-quiz__hint-box" data-hint-box hidden>
            <span class="rt-quiz__hint-icon">💡</span>
            <p><strong>Indiciu:</strong> <span data-hint-text></span></p>
          </div>

          <div class="rt-quiz__options" data-options-container role="list"></div>

          <div class="rt-quiz__feedback" data-feedback-container hidden aria-live="polite">
            <div class="rt-quiz__feedback-badge" data-feedback-badge>Corect</div>
            <p class="rt-quiz__feedback-text" data-feedback-text></p>
          </div>

          <div class="rt-quiz__actions">
            <button type="button" class="rt-quiz__btn rt-quiz__btn--outline" data-action="hint">
              Afișează Indiciul
            </button>

            <div class="rt-quiz__actions-right">
              <button type="button" class="rt-quiz__btn rt-quiz__btn--primary" data-action="next" disabled>
                Următoarea Întrebare
              </button>
            </div>
          </div>
        </div>
      </div>

      <div class="rt-quiz__screen" data-screen="result" hidden>
        <div class="rt-quiz__header-center">
          <p class="rt-quiz__eyebrow">Rezultat Final</p>
          <h2 class="rt-quiz__title" data-final-title>Evaluare Completă</h2>

          <div class="rt-quiz__score-circle">
            <svg viewBox="0 0 36 36" class="circular-chart" aria-hidden="true">
              <path
                class="circle-bg"
                d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
              />
              <path
                class="circle"
                stroke-dasharray="0, 100"
                d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
                data-score-path
              />
              <text x="18" y="20.35" class="percentage" data-final-score>0%</text>
            </svg>
          </div>

          <p class="rt-quiz__intro" data-final-message>Așteptare calcul...</p>

          <button type="button" class="rt-quiz__btn rt-quiz__btn--primary" data-action="restart">
            Încearcă un nou set de 10 întrebări
          </button>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .rt-quiz {
    --bg: #0b1220;
    --card-bg: rgba(17, 24, 39, 0.94);
    --border: rgba(148, 163, 184, 0.18);
    --border-strong: rgba(34, 211, 238, 0.5);
    --text: #f8fafc;
    --muted: #94a3b8;
    --primary: #22d3ee;
    --primary-glow: rgba(34, 211, 238, 0.5);
    --success: #10b981;
    --success-bg: rgba(16, 185, 129, 0.14);
    --danger: #ef4444;
    --danger-bg: rgba(239, 68, 68, 0.13);
    --warning: #f59e0b;
    --shadow-xl: 0 24px 64px rgba(0, 0, 0, 0.38);

    position: relative;
    overflow: hidden;
    background:
      radial-gradient(circle at top right, rgba(34, 211, 238, 0.08), transparent 24rem),
      radial-gradient(circle at bottom left, rgba(14, 165, 233, 0.06), transparent 28rem),
      linear-gradient(180deg, #0b1220 0%, #111827 100%);
    padding: 4rem 1rem;
    color: var(--text);
    font-family: system-ui, -apple-system, sans-serif;
  }

  .rt-quiz * { box-sizing: border-box; }
  .rt-quiz__shell { max-width: 900px; margin: 0 auto; min-height: 60vh; display: flex; flex-direction: column; justify-content: center; }
  .rt-quiz__screen { display: none; opacity: 0; }
  .rt-quiz__screen.is-active { display: block; opacity: 1; animation: fadeIn 0.35s ease forwards; }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .rt-quiz__header-center {
    text-align: center; max-width: 720px; margin: 0 auto; padding: 2.25rem 1.25rem;
    background: linear-gradient(180deg, rgba(15, 23, 42, 0.72), rgba(17, 24, 39, 0.72));
    border: 1px solid var(--border); border-radius: 1.75rem; box-shadow: var(--shadow-xl); backdrop-filter: blur(12px);
  }

  .rt-quiz__eyebrow {
    display: inline-flex; margin: 0 0 1rem; border: 1px solid rgba(34, 211, 238, 0.3); background: rgba(34, 211, 238, 0.1);
    padding: 0.42rem 1rem; font-size: 0.76rem; font-weight: 800; letter-spacing: 0.16em; text-transform: uppercase; color: #cffafe; border-radius: 999px;
  }
  .rt-quiz__title { font-size: clamp(2rem, 3vw, 2.85rem); line-height: 1.08; margin: 0 0 1rem; letter-spacing: -0.03em; color: #f8fafc; }
  .rt-quiz__intro { font-size: 1.05rem; line-height: 1.7; color: var(--muted); margin: 0 auto 2rem; max-width: 62ch; }
  
  .rt-quiz__start-meta { display: flex; justify-content: center; flex-wrap: wrap; gap: 0.65rem; margin-bottom: 2rem; }
  .rt-quiz__meta-pill { padding: 0.55rem 0.85rem; border-radius: 999px; background: rgba(148, 163, 184, 0.08); border: 1px solid rgba(148, 163, 184, 0.14); color: #cbd5e1; font-size: 0.92rem; font-weight: 600; }

  /* Butoane */
  .rt-quiz__btn {
    display: inline-flex; align-items: center; justify-content: center; min-height: 50px; padding: 0.9rem 1.45rem;
    font-size: 1rem; font-weight: 700; border-radius: 0.95rem; cursor: pointer; border: none; font-family: inherit;
    transition: all 0.2s ease;
  }
  .rt-quiz__btn--primary { background: linear-gradient(180deg, #67e8f9 0%, #22d3ee 100%); color: #083344; box-shadow: 0 10px 30px rgba(34, 211, 238, 0.22); }
  .rt-quiz__btn--primary:hover:not(:disabled) { background: linear-gradient(180deg, #7dd3fc 0%, #06b6d4 100%); transform: translateY(-2px); box-shadow: 0 16px 34px rgba(34, 211, 238, 0.35); }
  .rt-quiz__btn--primary:disabled { background: #334155; color: #94a3b8; cursor: not-allowed; box-shadow: none; transform: none; }
  .rt-quiz__btn--outline { background: transparent; color: var(--primary); border: 1px solid rgba(34, 211, 238, 0.34); }
  .rt-quiz__btn--outline:hover:not(:disabled) { background: rgba(34, 211, 238, 0.08); border-color: var(--primary); }

  /* Progress Bar */
  .rt-quiz__topbar { margin-bottom: 1.4rem; padding: 0 0.15rem; }
  .rt-quiz__progress-text { display: flex; justify-content: space-between; gap: 1rem; font-size: 0.96rem; color: var(--muted); margin-bottom: 0.7rem; font-weight: 600; flex-wrap: wrap; }
  .rt-quiz__progress-text strong { color: var(--text); }
  .rt-quiz__score-live { color: #67e8f9; font-weight: 800; }
  .rt-quiz__progress-bar { height: 8px; background: rgba(148, 163, 184, 0.12); border-radius: 999px; overflow: hidden; border: 1px solid rgba(148, 163, 184, 0.08); }
  .rt-quiz__progress-fill { height: 100%; background: linear-gradient(90deg, #22d3ee 0%, #67e8f9 100%); width: 0%; transition: width 0.35s ease; box-shadow: 0 0 20px rgba(34, 211, 238, 0.35); }

  /* Quiz Card */
  .rt-quiz__card {
    background: var(--card-bg); border: 1px solid var(--border); border-radius: 1.6rem; padding: 2rem;
    box-shadow: var(--shadow-xl); backdrop-filter: blur(10px);
  }
  .rt-quiz__card-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; margin-bottom: 1.65rem;}
  .rt-quiz__question-text { font-size: 1.34rem; line-height: 1.55; margin: 0; font-weight: 700; color: #f8fafc; }

  /* Panou Indiciu */
  .rt-quiz__hint-box {
    display: flex; gap: 1rem; padding: 1.2rem; background: rgba(245, 158, 11, 0.08); border: 1px solid rgba(245, 158, 11, 0.2);
    border-radius: 1rem; margin-bottom: 1.5rem; color: #fde68a; animation: fadeIn 0.3s ease;
  }
  .rt-quiz__hint-icon { font-size: 1.5rem; line-height: 1; }
  .rt-quiz__hint-box p { margin: 0; font-size: 0.95rem; line-height: 1.6; }
  .rt-quiz__hint-box strong { color: #fcd34d; }

 /* =========================================
     OPȚIUNI - STILIZARE PENTRU ELEMENTE INJECTATE PRIN JS
     ========================================= */
  :global(.rt-quiz__options) { 
    display: flex; 
    flex-direction: column; 
    gap: 1rem; 
    margin-bottom: 1.5rem; 
  }
  
  :global(.rt-quiz__option) {
    width: 100%; 
    margin: 0;
    padding: 1.1rem 1.25rem; 
    background: linear-gradient(180deg, #0f172a 0%, #111827 100%);
    border: 1px solid rgba(148, 163, 184, 0.3) !important; /* Border vizibil */
    border-radius: 0.75rem; 
    cursor: pointer;
    font-size: 1.05rem; 
    line-height: 1.5; 
    font-family: inherit;
    appearance: none; 
    -webkit-appearance: none;
    
    /* Forțare Aliniere la Stânga */
    display: flex !important; 
    flex-direction: row !important; 
    align-items: flex-start !important; 
    justify-content: flex-start !important; 
    text-align: left !important; 
    gap: 0.8rem; 
    
    color: var(--text); 
    transition: all 0.3s ease;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  }
  
  :global(.rt-quiz__option-label) { 
    display: block; 
    flex: 1; 
    color: #e5e7eb; 
    text-align: left !important;
  }

  :global(.rt-quiz__option-marker) {
    flex-shrink: 0; 
    font-size: 1.05rem; 
    font-weight: 800; 
    color: var(--primary);
    background: transparent;
    border: none;
    min-width: 1.8rem;
    transition: all 0.25s ease;
  }

  /* EFECTUL DE LUMINARE (GLOW) LA HOVER */
  :global(.rt-quiz__option:hover:not(.is-disabled)) {
    background: linear-gradient(180deg, #1e293b 0%, #0f172a 100%);
    border-color: var(--primary) !important;
    box-shadow: 0 0 15px var(--primary-glow), inset 0 0 8px rgba(34, 211, 238, 0.1);
    transform: translateY(-2px);
  }

  /* STĂRI DE RĂSPUNS */
  :global(.rt-quiz__option.is-correct) {
    border-color: var(--success) !important; 
    background: linear-gradient(180deg, rgba(16, 185, 129, 0.15) 0%, rgba(16, 185, 129, 0.05) 100%) !important;
    box-shadow: 0 0 15px rgba(16, 185, 129, 0.4) !important;
  }
  
  :global(.rt-quiz__option.is-wrong) {
    border-color: var(--danger) !important; 
    background: linear-gradient(180deg, rgba(239, 68, 68, 0.15) 0%, rgba(239, 68, 68, 0.05) 100%) !important;
    box-shadow: 0 0 15px rgba(239, 68, 68, 0.4) !important;
    opacity: 0.9;
  }
  
  :global(.rt-quiz__option.is-correct .rt-quiz__option-marker) { 
    color: var(--success) !important; 
  }
  :global(.rt-quiz__option.is-wrong .rt-quiz__option-marker) { 
    color: var(--danger) !important; 
  }
  
  :global(.rt-quiz__option.is-disabled) { 
    cursor: default; 
    transform: none; 
  }
  /* ========================================= */

  /* Feedback */
  .rt-quiz__feedback {
    padding: 1.15rem 1.2rem; border-radius: 1rem; background: linear-gradient(180deg, rgba(15, 23, 42, 0.92), rgba(17, 24, 39, 0.92));
    border-left: 4px solid var(--primary); margin-bottom: 1.5rem; animation: fadeIn 0.3s ease;
  }
  .rt-quiz__feedback.is-correct { border-left-color: var(--success); }
  .rt-quiz__feedback.is-wrong { border-left-color: var(--danger); }
  .rt-quiz__feedback-badge { display: inline-block; padding: 0.22rem 0.62rem; border-radius: 0.42rem; font-size: 0.78rem; font-weight: 800; margin-bottom: 0.55rem; text-transform: uppercase; }
  .rt-quiz__feedback.is-correct .rt-quiz__feedback-badge { background: var(--success-bg); color: var(--success); }
  .rt-quiz__feedback.is-wrong .rt-quiz__feedback-badge { background: var(--danger-bg); color: var(--danger); }
  .rt-quiz__feedback-text { margin: 0; font-size: 0.96rem; color: #dbe4ee; line-height: 1.7; }

  .rt-quiz__actions { display: flex; justify-content: space-between; align-items: center; gap: 1rem; border-top: 1px solid rgba(148, 163, 184, 0.12); padding-top: 1.5rem; }
  .rt-quiz__actions-right { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; justify-content: flex-end; }

  /* Rezultate */
  .rt-quiz__score-circle { width: 180px; margin: 2rem auto; }
  .circular-chart { display: block; margin: 0 auto; max-width: 100%; max-height: 250px; }
  .circle-bg { fill: none; stroke: rgba(148, 163, 184, 0.18); stroke-width: 2.5; }
  .circle { fill: none; stroke: var(--primary); stroke-width: 2.5; stroke-linecap: round; transition: stroke-dasharray 1.2s ease-out, stroke 0.8s ease; }
  .percentage { fill: #f8fafc; font-family: sans-serif; font-size: 0.4em; text-anchor: middle; font-weight: 800; }

  @media (max-width: 700px) {
    .rt-quiz { padding: 3rem 1rem; }
    .rt-quiz__header-center { padding: 1.6rem 1rem; }
    .rt-quiz__card { padding: 1.25rem; border-radius: 1.3rem; }
    .rt-quiz__question-text { font-size: 1.14rem; }
    

    .rt-quiz__actions { flex-direction: column; align-items: stretch; }
    .rt-quiz__actions-right { width: 100%; flex-direction: column; align-items: stretch; }
    .rt-quiz__actions .rt-quiz__btn, .rt-quiz__actions-right .rt-quiz__btn { width: 100%; }
  }
</style>

<script define:vars={{ componentId }}>
  (() => {
    const root = document.getElementById(componentId);
    if (!root) return;

    const QUESTION_COUNT = 10;

    const questionPool = [
      {
        q: "Care este doza totală curativă standard (în fracționare convențională de 2 Gy/fracțiune) recomandată pentru iradierea definitivă a cancerului de prostată cu risc intermediar/înalt?",
        opts: ["60 - 64 Gy", "76 - 78 Gy", "50.4 Gy", "45 Gy urmat de brahiterapie obligatorie"],
        correct: 1,
        hint: "Gândiți-vă la dozele mari (>74 Gy) necesare pentru controlul biochimic optim în fracționarea de bază.",
        rationale: "Ghidurile EAU/ESTRO recomandă escaladarea dozei la 76-78 Gy (sau 80 Gy în unele centre) în fracționare standard (1.8-2 Gy/zi) pentru a asigura controlul biochimic optim în cancerul de prostată."
      },
      {
        q: "În tratamentul paliativ al metastazelor osoase necomplicate, care este cel mai susținut protocol de iradiere conform dovezilor clinice actuale?",
        opts: ["30 Gy în 10 fracțiuni", "20 Gy în 5 fracțiuni", "8 Gy într-o singură fracțiune", "40 Gy în 20 fracțiuni"],
        correct: 2,
        hint: "O singură vizită la spital a demonstrat că oferă același beneficiu antialgic ca și tratamentele prelungite.",
        rationale: "Multiple meta-analize confirmă că 8 Gy într-o fracțiune oferă același grad de control al durerii ca și schemele mai lungi, fiind standardul de aur pentru paliația osoasă necomplicată."
      },
      {
        q: "Pentru cancerul pulmonar cu celule non-mici (NSCLC) stadiul I inoperabil, situat periferic, care este o schemă comună și validată de SBRT (Stereotactic Body Radiotherapy)?",
        opts: ["60 Gy în 30 fracțiuni", "54 Gy în 3 fracțiuni", "45 Gy în 15 fracțiuni", "20 Gy o singură fracțiune"],
        correct: 1,
        hint: "Se administrează o doză biologică efectivă foarte mare (BED > 100) în extrem de puține ședințe ablative (3-5).",
        rationale: "Pentru NSCLC periferic sub 5 cm, schemele tipice de SBRT sunt 54 Gy în 3 fracțiuni sau 48 Gy în 4 fracțiuni, oferind control local excelent."
      },
      {
        q: "Conform definițiilor ICRU 83, ce volum adaugă o marjă geometrică la CTV pentru a compensa incertitudinile de set-up zilnic și mișcarea organelor intern?",
        opts: ["GTV (Gross Tumor Volume)", "ITV (Internal Target Volume)", "PTV (Planning Target Volume)", "OAR (Organ At Risk)"],
        correct: 2,
        hint: "Este volumul fizic folosit direct pentru planificare (Planning) ce absoarbe toate erorile mecanice.",
        rationale: "PTV-ul este un concept geometric creat pentru a asigura că CTV-ul primește doza necesară în ciuda variațiilor de poziționare și de mișcare internă."
      },
      {
        q: "Ce doză este utilizată standard pentru Iradierea Profilactică Craniană (PCI) la pacienții cu cancer pulmonar cu celule mici (SCLC) cu boală limitată care au răspuns la tratamentul inițial?",
        opts: ["25 Gy în 10 fracțiuni", "30 Gy în 10 fracțiuni", "40 Gy în 20 fracțiuni", "8 Gy într-o fracțiune"],
        correct: 0,
        hint: "O doză profilactică moderată, administrată de obicei într-un regim de fix 2 săptămâni (10 zile lucrătoare).",
        rationale: "25 Gy în 10 fracțiuni este doza standard profilactică pentru SCLC, reducând riscul de metastaze cerebrale și limitând toxicitatea neurocognitivă."
      },
      {
        q: "Care este standardul dozei pentru iradierea pelvină externă (EBRT) în cancerul de col uterin local avansat, înainte de aplicarea brahiterapiei?",
        opts: ["45 - 50.4 Gy", "60 - 66 Gy", "70 - 74 Gy", "30 Gy"],
        correct: 0,
        hint: "Este doza clasică de ~5 săptămâni folosită pentru sterilizarea ganglionilor pelvini înainte de boost-ul pe tumoră.",
        rationale: "EBRT pelvină se administrează de obicei până la 45-50.4 Gy concomitent cu cisplatin, urmată de brahiterapie pentru escaladarea dozei la nivel tumoral."
      },
      {
        q: "În radioterapia adjuvantă standard (non-hipofracționată) a cancerului de sân pe întregul sân, care era doza clasică totală prescrisă?",
        opts: ["40 Gy în 15 fracțiuni", "50 Gy în 25 fracțiuni", "60 Gy în 30 fracțiuni", "26 Gy în 5 fracțiuni"],
        correct: 1,
        hint: "Regimul istoric convențional necesită vizita zilnică timp de 5 săptămâni întregi (25 ședințe).",
        rationale: "Înainte de adoptarea extinsă a hipofracționării, standardul larg utilizat era 50 Gy în 25 fracțiuni."
      },
      {
        q: "Ce a validat studiul FAST-Forward pentru tratamentul adjuvant al cancerului de sân incipient?",
        opts: ["Radioterapia concomitentă cu chimioterapia", "Iradierea în 5 fracțiuni (26 Gy în 1 săptămână) ca fiind non-inferioară", "Iradierea profilactică a sânului controlateral", "Brahiterapia interstițială exclusivă"],
        correct: 1,
        hint: "Acest trial britanic a scurtat dramatic tratamentul global la o singură săptămână lucrătoare.",
        rationale: "FAST-Forward a demonstrat că 26 Gy în 5 fracțiuni într-o săptămână este non-inferior față de regimurile standard mai lungi, schimbând practica clinică."
      },
      {
        q: "Studiul PACIFIC a introdus imunoterapia de consolidare cu Durvalumab în stadiul III NSCLC. Care este momentul optim de inițiere post chimio-iradiere?",
        opts: ["Concomitent cu prima ședință RT", "La peste 3 luni post-RT", "În primele 14 zile după finalizarea chimio-radioterapiei", "Doar la recidivă"],
        correct: 2,
        hint: "Efectul maxim apare când se profită imediat de inflamația imună produsă de radioterapie, fără amânare.",
        rationale: "Beneficiul maxim apare când imunoterapia este inițiată rapid după chimio-radioterapie, ideal în primele 14 zile."
      },
      {
        q: "În managementul cancerului rectal, paradigma TNT (Total Neoadjuvant Therapy) propusă de studiul RAPIDO implică:",
        opts: ["Chimioterapie post-operatorie prelungită", "Radioterapie scurtă (5x5 Gy) urmată de chimioterapie sistemică și apoi chirurgie", "Chirurgie upfront urmată de RT", "Excluderea totală a chirurgiei"],
        correct: 1,
        hint: "Parcurge tratamentul sistemic și local intens înainte ca bisturiul să atingă pacientul.",
        rationale: "RAPIDO a validat strategia de tratament total neoadjuvant, cu radioterapie scurtă urmată de chimioterapie înainte de intervenția chirurgicală."
      },
      {
        q: "Din punct de vedere radiobiologic, «Efectul FLASH» se referă la:",
        opts: ["Iradierea exclusivă cu protoni", "Folosirea agenților fotosensibilizatori", "Livrarea dozei la rate ultra-înalte (peste 40 Gy/sec) cu cruțarea țesutului normal", "Iradierea sincronizată cu respirația"],
        correct: 2,
        hint: "Are legătură cu livrarea fracțiunii în milisecunde, consumând oxigenul local din țesutul sănătos.",
        rationale: "FLASH presupune livrarea ultra-rapidă a dozei, cu posibilă reducere a toxicității în țesutul normal și menținerea efectului antitumoral."
      },
      {
