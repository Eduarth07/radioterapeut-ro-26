    const screens = {
      start: root.querySelector('[data-screen="start"]'),
      quiz: root.querySelector('[data-screen="quiz"]'),
      result: root.querySelector('[data-screen="result"]')
    };

    let currentQuizQuestions = [];
    let currentIndex = 0;
    let score = 0;
    let hasAnsweredCurrent = false;

    const qText = root.querySelector('[data-question-text]');
    const optContainer = root.querySelector('[data-options-container]');
    const currentQEl = root.querySelector('[data-current-q]');
    const totalQEl = root.querySelector('[data-total-q]');
    const progressFill = root.querySelector('[data-progress-fill]');
    const liveScore = root.querySelector('[data-live-score]');

    const feedbackContainer = root.querySelector('[data-feedback-container]');
    const feedbackBadge = root.querySelector('[data-feedback-badge]');
    const feedbackText = root.querySelector('[data-feedback-text]');
    
    const hintBox = root.querySelector('[data-hint-box]');
    const hintText = root.querySelector('[data-hint-text]');

    const btnStart = root.querySelector('[data-action="start"]');
    const btnNext = root.querySelector('[data-action="next"]');
    const btnHint = root.querySelector('[data-action="hint"]');
    const btnRestart = root.querySelector('[data-action="restart"]');

    const finalTitle = root.querySelector('[data-final-title]');
    const finalScore = root.querySelector('[data-final-score]');
    const scorePath = root.querySelector('[data-score-path]');
    const finalMessage = root.querySelector('[data-final-message]');

    const showScreen = (name) => {
      Object.entries(screens).forEach(([key, screen]) => {
        if (!screen) return;
        const isTarget = key === name;
        screen.hidden = !isTarget;
        screen.classList.toggle('is-active', isTarget);
      });
    };

    const shuffle = (array) => {
      const arr = [...array];
      for (let i = arr.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [arr[i], arr[j]] = [arr[j], arr[i]];
      }
      return arr;
    };

    const renderOptions = (question) => {
      if (!optContainer) return;
      optContainer.innerHTML = "";

      const letters = ["A", "B", "C", "D"];

      question.opts.forEach((optText, index) => {
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = "rt-quiz__option";
        btn.setAttribute("role", "listitem");
        btn.setAttribute("aria-pressed", "false");

        const marker = document.createElement("span");
        marker.className = "rt-quiz__option-marker";
        marker.textContent = letters[index] + ". ";

        const label = document.createElement("span");
        label.className = "rt-quiz__option-label";
        label.textContent = optText;

        btn.appendChild(marker);
        btn.appendChild(label);

        btn.addEventListener("click", () => handleOptionClick(index, btn));
        optContainer.appendChild(btn);
      });
    };

    const updateProgress = () => {
      if (currentQEl) currentQEl.textContent = String(currentIndex + 1);
      if (totalQEl) totalQEl.textContent = String(currentQuizQuestions.length);
      if (liveScore) liveScore.textContent = String(score);
      if (progressFill) {
        const pct = (currentIndex / currentQuizQuestions.length) * 100;
        progressFill.style.width = `${pct}%`;
      }
    };

    const loadQuestion = () => {
      hasAnsweredCurrent = false;

      const question = currentQuizQuestions[currentIndex];
      if (!question || !qText) return;

      qText.textContent = question.q;
      
      if (hintBox && hintText) {
        hintBox.hidden = true;
        hintText.textContent = question.hint || "Fără indiciu disponibil.";
        if (btnHint) {
            btnHint.textContent = "Afișează Indiciul";
            btnHint.disabled = false;
        }
      }

      updateProgress();
      renderOptions(question);

      if (feedbackContainer) {
        feedbackContainer.hidden = true;
        feedbackContainer.className = "rt-quiz__feedback";
      }

      if (btnNext) btnNext.disabled = true;
    };

    const handleOptionClick = (selectedIndex, clickedBtn) => {
      if (hasAnsweredCurrent || !optContainer) return;
      hasAnsweredCurrent = true;

      const question = currentQuizQuestions[currentIndex];
      const isCorrect = selectedIndex === question.correct;

      const allOptions = [...optContainer.querySelectorAll(".rt-quiz__option")];

      allOptions.forEach((opt, idx) => {
        opt.classList.add("is-disabled");
        opt.setAttribute("aria-disabled", "true");

        if (idx === question.correct) {
          opt.classList.add("is-correct"); 
        } else if (idx === selectedIndex && !isCorrect) {
          opt.classList.add("is-wrong"); 
        }
      });

      if (isCorrect) score += 1;
      if (liveScore) liveScore.textContent = String(score);

      if (feedbackContainer && feedbackBadge && feedbackText) {
        feedbackContainer.hidden = false;
        feedbackContainer.className = `rt-quiz__feedback ${isCorrect ? "is-correct" : "is-wrong"}`;
        feedbackBadge.textContent = isCorrect ? "CORECT" : "INCORECT";
        feedbackText.innerHTML = `<strong>Explicație:</strong> ${question.rationale}`;
      }

      if (btnNext) btnNext.disabled = false;
    };

    const endQuiz = () => {
      if (progressFill) progressFill.style.width = "100%";

      const percentage = Math.round((score / currentQuizQuestions.length) * 100);

      if (finalScore) finalScore.textContent = `${percentage}%`;

      requestAnimationFrame(() => {
        setTimeout(() => {
          if (scorePath) {
            scorePath.style.strokeDasharray = `${percentage}, 100`;
            scorePath.style.stroke =
              percentage >= 80 ? "var(--success)" : percentage >= 50 ? "var(--warning)" : "var(--danger)";
          }
        }, 180);
      });

      if (finalTitle && finalMessage) {
        if (percentage >= 90) {
          finalTitle.textContent = "Excelent!";
          finalMessage.innerHTML = `Performanță la nivel de specialist. Ai obținut <strong>${score} din ${currentQuizQuestions.length}</strong>.`;
        } else if (percentage >= 70) {
          finalTitle.textContent = "Foarte bine!";
          finalMessage.innerHTML = `Bază teoretică solidă. Ai obținut <strong>${score} din ${currentQuizQuestions.length}</strong>.`;
        } else if (percentage >= 50) {
          finalTitle.textContent = "Rezultat bun";
          finalMessage.innerHTML = `Ai o bază utilă, dar merită revizuite anumite concepte de nișă. Ai obținut <strong>${score} din ${currentQuizQuestions.length}</strong>.`;
        } else {
          finalTitle.textContent = "Necesită revizuire";
          finalMessage.innerHTML = `Recomandăm revizuirea ghidurilor clinice ESTRO și a radiobiologiei. Ai obținut <strong>${score} din ${currentQuizQuestions.length}</strong>.`;
        }
      }

      showScreen("result");
    };

    const initQuiz = () => {
      currentQuizQuestions = shuffle(questionPool).slice(0, QUESTION_COUNT);
      currentIndex = 0;
      score = 0;
      hasAnsweredCurrent = false;

      if (scorePath) {
        scorePath.style.strokeDasharray = "0, 100";
        scorePath.style.stroke = "var(--primary)";
      }

      loadQuestion();
      showScreen("quiz");
    };

    if (btnStart) {
      btnStart.addEventListener("click", initQuiz);
    }

    if (btnNext) {
      btnNext.addEventListener("click", () => {
        currentIndex += 1;
        if (currentIndex < currentQuizQuestions.length) {
          loadQuestion();
        } else {
          endQuiz();
        }
      });
    }

    if (btnHint && hintBox) {
      btnHint.addEventListener("click", () => {
        const isHidden = hintBox.hidden;
        hintBox.hidden = !isHidden;
        btnHint.textContent = isHidden ? "Ascunde Indiciul" : "Afișează Indiciul";
      });
    }

    if (btnRestart) {
      btnRestart.addEventListener("click", initQuiz);
    }

    showScreen("start");
  })();
</script>