---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const componentId = `contour-sim-pro-${Math.random().toString(36).slice(2, 9)}`;
const initialSlice = 8;
---
<BaseLayout
  title="Simulator de Conturaj | Dr. Cirimpei Tatiana"
  description="Demo educațional avansat pentru simulatorul de conturaj. Interfață mai realistă și funcții extinse."
>
  <Header />

<section class="contour-pro" data-contour-pro={componentId} aria-labelledby={`${componentId}-title`}>
  <div class="contour-pro__shell">
    <div class="contour-pro__header">
      <p class="contour-pro__eyebrow">Demo educațional avansat</p>
      <h2 id={`${componentId}-title`} class="contour-pro__title text-gray-800 dark:text-gray-50">
        Simulator de conturaj – interfață clinică și precizie
      </h2>
    </div>

    <div class="contour-pro__toolbar notranslate" translate="no">
      <div class="contour-pro__toolbar-group">
        <span class="contour-pro__toolbar-label">Tools</span>
        <button type="button" data-tool="draw" class="is-active">Draw (Pts)</button>
        <button type="button" data-tool="freehand">Freehand</button>
        <button type="button" data-tool="edit">Edit</button>
        <button type="button" data-tool="pan">Pan</button>
      </div>
      <div class="contour-pro__toolbar-divider"></div>
      <div class="contour-pro__toolbar-group">
        <span class="contour-pro__toolbar-label">Actions</span>
        <button type="button" data-close-contour>Close Contour</button>
        <button type="button" data-undo-point>Undo</button>
        <button type="button" data-clear-slice>Clear Slice</button>
      </div>
      <div class="contour-pro__toolbar-divider"></div>
      <div class="contour-pro__toolbar-group">
        <span class="contour-pro__toolbar-label">Slice Modifiers</span>
        <button type="button" data-clone-prev>Copy to Prev</button>
        <button type="button" data-clone-next>Copy to Next</button>
        <button type="button" data-interpolate>Interpolate</button>
      </div>
      <div class="contour-pro__toolbar-divider"></div>
      <div class="contour-pro__toolbar-group">
        <span class="contour-pro__toolbar-label">Advanced</span>
        <button type="button" data-smooth-contour>Smooth</button>
        <button type="button" data-auto-contour>Auto-Contour</button>
      </div>
    </div>

    <div class="contour-pro__layout">
      <aside class="contour-pro__sidebar">
        <div class="contour-pro__card">
          <div class="contour-pro__card-head">
            <h3>Demo Study</h3>
            <span class="contour-pro__tag">CT Thorax</span>
          </div>

          <div class="contour-pro__study-grid">
            <div><span>Patient</span><strong>Demo Patient</strong></div>
            <div><span>ID</span><strong>RT-EDU-001</strong></div>
            <div><span>Series</span><strong>16 slices</strong></div>
          </div>

          <div class="contour-pro__preset-wrap">
            <span>W/L Presets</span>
            <div class="contour-pro__preset-grid">
              <button type="button" data-wl-preset="lung">Lung</button>
              <button type="button" data-wl-preset="mediastin">Mediastin</button>
              <button type="button" data-wl-preset="osos">Bone</button>
            </div>
          </div>
        </div>

        <div class="contour-pro__card">
          <div class="contour-pro__card-head">
            <h3>ROI List</h3>
            <span class="contour-pro__tag" data-roi-count>4 visible</span>
          </div>

          <div class="contour-pro__roi-list" data-roi-list></div>

          <div class="contour-pro__roi-controls">
            <label class="contour-pro__field">
              <span>Active ROI Opacity</span>
              <input type="range" min="0.08" max="0.55" step="0.01" value="0.22" data-roi-opacity />
            </label>

            <div class="contour-pro__button-row">
              <button type="button" data-add-roi>Add ROI</button>
              <button type="button" data-rename-roi>Rename</button>
            </div>
          </div>
        </div>
      </aside>

      <div class="contour-pro__main">
        <div class="contour-pro__viewer-card">
          <div class="contour-pro__viewer-topbar">
            <div class="contour-pro__viewer-head-left">
              <span class="contour-pro__viewer-title">Axial CT Viewer</span>
              <span class="contour-pro__viewer-subtitle">Contouring workspace</span>
            </div>
            <div class="contour-pro__viewer-head-right">
              <span data-meta-wl>W 1500 / L -550</span>
              <span data-meta-zoom>Zoom 1.00x</span>
              <span data-meta-coords>X 0 | Y 0 | HU 0</span>
            </div>
          </div>

          <div class="contour-pro__workspace">
            <div class="contour-pro__viewer-wrap">
              <div class="contour-pro__viewer-stage">
                <div class="contour-pro__viewer" data-viewer>
                  <canvas width="512" height="512" data-image-canvas></canvas>
                  <svg viewBox="0 0 512 512" class="contour-pro__overlay" data-overlay>
                    <g data-pan-zoom-layer>
                      <g data-grid-layer></g>
                      <g data-contours-layer></g>
                      <g data-current-layer></g>
                      <g data-preview-layer></g>
                      <g data-annotation-layer></g>
                    </g>
                  </svg>
                  <div class="contour-pro__crosshair contour-pro__crosshair--v" data-cross-v hidden></div>
                  <div class="contour-pro__crosshair contour-pro__crosshair--h" data-cross-h hidden></div>

                  <div class="contour-pro__corner contour-pro__corner--lt">
                    <strong data-corner-roi>PTV</strong>
                    <span data-corner-mode>Draw mode</span>
                  </div>
                </div>

                <aside class="contour-pro__viewer-rail">
                  <div class="contour-pro__rail-card">
                    <div class="contour-pro__rail-head">
                      <strong>Slice</strong>
                      <span data-slice-label>Slice 8 / 15</span>
                    </div>
                    <label class="contour-pro__field contour-pro__field--compact">
                      <input type="range" min="0" max="15" step="1" value={initialSlice} data-slice-range />
                    </label>
                    <div class="contour-pro__rail-actions">
                      <button type="button" data-prev-slice>−</button>
                      <button type="button" data-play-slices>Play</button>
                      <button type="button" data-next-slice>+</button>
                    </div>
                  </div>

                  <div class="contour-pro__rail-card">
                    <div class="contour-pro__rail-head">
                      <strong>Zoom</strong>
                      <span data-rail-zoom>1.00x</span>
                    </div>
                    <label class="contour-pro__field contour-pro__field--compact">
                      <input type="range" min="1" max="4.5" step="0.05" value="1" data-zoom-range />
                    </label>
                    <div class="contour-pro__rail-actions">
                      <button type="button" data-zoom-out>−</button>
                      <button type="button" data-fit-view>Fit</button>
                      <button type="button" data-zoom-in>+</button>
                    </div>
                  </div>

                  <div class="contour-pro__rail-card">
                    <div class="contour-pro__rail-head">
                      <strong>Display</strong>
                    </div>
                    <label class="contour-pro__field contour-pro__field--compact">
                      <span>Window</span>
                      <input type="range" min="350" max="1800" step="10" value="1500" data-window-range />
                    </label>
                    <label class="contour-pro__field contour-pro__field--compact" style="margin-top: 0.35rem;">
                      <span>Level</span>
                      <input type="range" min="-900" max="400" step="10" value="-550" data-level-range />
                    </label>
                    <div class="contour-pro__rail-actions" style="margin-top: 0.8rem; grid-template-columns: 1fr;">
                      <button type="button" data-reset-view>Reset View</button>
                      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem;">
                        <button type="button" data-save-local>Save</button>
                        <button type="button" data-export-json>Export</button>
                      </div>
                    </div>
                  </div>
                </aside>
              </div>

              <div class="contour-pro__hint" data-hint>
                Click to add points. Click near the first point to close contour. Ctrl + Scroll to zoom.
              </div>
            </div>

            <aside class="contour-pro__scout-card">
              <div class="contour-pro__scout-head">
                <h3>Scout</h3>
              </div>
              <div class="contour-pro__scout-list" data-scout-list></div>
            </aside>
          </div>
        </div>

        <div class="contour-pro__bottom-grid">
          <div class="contour-pro__eval-card">
            <div class="contour-pro__card-head">
              <h3>Contour Evaluation</h3>
              <button type="button" data-evaluate class="contour-pro__eval-btn">Evaluate Current Slice</button>
            </div>
            <div class="contour-pro__eval-content" data-eval-results>
              <p class="contour-pro__hint">Press button to analyze accuracy, coverage, and node density for the current slice compared to AI reference.</p>
            </div>
          </div>

          <div class="contour-pro__timeline-card">
            <div class="contour-pro__card-head">
              <h3>Slice Timeline</h3>
              <span class="contour-pro__tag" data-timeline-caption>Active ROI: PTV</span>
            </div>
            <div class="contour-pro__timeline" data-timeline></div>
          </div>

          <div class="contour-pro__stats-card">
            <div class="contour-pro__card-head">
              <h3>Local Stats</h3>
              <span class="contour-pro__tag">Current</span>
            </div>
            <div class="contour-pro__stats-grid">
              <div><span>Active ROI</span><strong data-stat-roi>PTV</strong></div>
              <div><span>Active points</span><strong data-stat-points>0</strong></div>
              <div><span>Current area (px²)</span><strong data-stat-area>0</strong></div>
              <div><span>ROI contours / slice</span><strong data-stat-count>0</strong></div>
              <div><span>Total study contours</span><strong data-stat-total>0</strong></div>
              <div><span>Cursor</span><strong data-stat-cursor>—</strong></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
</BaseLayout>
<style>
  .contour-pro {
    --panel: rgba(15, 23, 42, 0.92);
    --panel-2: rgba(15, 23, 42, 0.76);
    --line: rgba(148, 163, 184, 0.18);
    --text: #e2e8f0;
    --muted: #94a3b8;
    --accent: #22d3ee;
    --accent-2: #67e8f9;
    --success: #84cc16;
    --warning: #facc15;
    --danger: #f43f5e;
    color: var(--text);
  }

  .contour-pro * { box-sizing: border-box; }

  .contour-pro__shell {
    max-width: 1640px;
    margin: 0 auto;
    padding: 1rem;
  }

  .contour-pro__header { margin-bottom: 1.5rem; }

  .contour-pro__eyebrow {
    display: inline-flex;
    margin: 0 0 0.85rem;
    border: 1px solid rgba(34, 211, 238, 0.28);
    border-radius: 999px;
    background: rgba(34, 211, 238, 0.1);
    padding: 0.42rem 0.8rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #0d7881;
  }

  .contour-pro__title {
    margin: 0;
    font-size: clamp(1.8rem, 2.5vw, 2.6rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .contour-pro__intro {
    max-width: 930px;
    margin: 0.95rem 0 0;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--muted);
  }

  .contour-pro__toolbar {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 0.85rem 1.25rem;
    margin-bottom: 1.25rem;
    background: linear-gradient(180deg, rgba(15,23,42,0.94), rgba(2,6,23,0.98));
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 1.2rem;
    box-shadow: 0 12px 30px rgba(0,0,0,0.25);
    backdrop-filter: blur(14px);
    overflow-x: auto;
  }

  .contour-pro__toolbar-group {
    display: flex;
    gap: 0.45rem;
    align-items: center;
    position: relative;
    padding-top: 1.2rem;
  }

  .contour-pro__toolbar-label {
    position: absolute;
    top: -0.1rem;
    left: 0.2rem;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(148, 163, 184, 0.6);
    font-weight: 700;
    pointer-events: none;
  }

  .contour-pro__toolbar button {
    white-space: nowrap;
    padding: 0.6rem 0.9rem;
    font-size: 0.85rem;
    font-weight: 600;
  }

  .contour-pro__toolbar-divider {
    width: 1px;
    height: 1.8rem;
    background: rgba(255,255,255,0.1);
    flex-shrink: 0;
    margin-top: 1.2rem;
  }

  .contour-pro__layout {
    display: grid;
    gap: 1.2rem;
  }

  .contour-pro__sidebar,
  .contour-pro__main {
    display: grid;
    gap: 1rem;
  }

  .contour-pro__card,
  .contour-pro__viewer-card,
  .contour-pro__timeline-card,
  .contour-pro__stats-card,
  .contour-pro__scout-card,
  .contour-pro__eval-card,
  .contour-pro__rail-card {
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 1.2rem;
    background: linear-gradient(180deg, rgba(15,23,42,0.94), rgba(2,6,23,0.98));
    box-shadow: 0 24px 60px rgba(0,0,0,0.28);
    backdrop-filter: blur(14px);
    padding: 1rem;
  }

  .contour-pro__card-head,
  .contour-pro__scout-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.9rem;
  }

  .contour-pro__card-head h3,
  .contour-pro__scout-head h3 {
    margin: 0;
    font-size: 1rem;
  }

  .contour-pro__tag {
    border-radius: 999px;
    border: 1px solid rgba(34,211,238,0.16);
    background: rgba(34,211,238,0.08);
    padding: 0.25rem 0.6rem;
    font-size: 0.72rem;
    font-weight: 700;
    color: #cffafe;
  }

  .contour-pro__study-grid,
  .contour-pro__stats-grid { display: grid; gap: 0.72rem; }
  .contour-pro__study-grid div,
  .contour-pro__stats-grid div { display: flex; align-items: center; justify-content: space-between; gap: 1rem; color: var(--muted); font-size: 0.9rem; }
  .contour-pro__study-grid strong,
  .contour-pro__stats-grid strong { color: var(--text); }

  .contour-pro__preset-wrap { margin-top: 1rem; display: grid; gap: 0.7rem; color: var(--muted); font-size: 0.9rem; }
  
  .contour-pro__preset-grid,
  .contour-pro__button-row,
  .contour-pro__rail-actions { display: grid; gap: 0.5rem; }

  .contour-pro__preset-grid,
  .contour-pro__rail-actions { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  .contour-pro__button-row { grid-template-columns: repeat(2, minmax(0, 1fr)); }

  .contour-pro__roi-list { display: grid; gap: 0.65rem; }
  .contour-pro__roi-item {
    display: grid; grid-template-columns: 1fr auto; gap: 0.6rem; align-items: center; width: 100%;
    padding: 0.7rem 0.75rem; border: 1px solid rgba(255,255,255,0.08); border-radius: 0.85rem;
    background: rgba(15,23,42,0.68); color: var(--text); cursor: pointer; text-align: left;
    transition: transform 140ms ease, border-color 140ms ease, background 140ms ease;
  }
  .contour-pro__roi-item:hover, .contour-pro__roi-item.is-active {
    transform: translateY(-1px); border-color: rgba(34,211,238,0.28); background: rgba(34,211,238,0.08);
  }
  .contour-pro__roi-main { display: flex; align-items: center; gap: 0.7rem; min-width: 0; }
  .contour-pro__roi-dot { width: 0.9rem; height: 0.9rem; border-radius: 999px; border: 2px solid rgba(255,255,255,0.6); flex: 0 0 auto; }
  .contour-pro__roi-name { font-weight: 700; font-size: 0.95rem; }
  .contour-pro__roi-meta { font-size: 0.75rem; color: var(--muted); }
  .contour-pro__roi-actions-side { display: flex; align-items: center; gap: 0.45rem; }
  .contour-pro__eye-btn { min-width: 2rem; width: 2rem; height: 2rem; padding: 0; border-radius: 0.6rem; font-size: 0.9rem; }

  .contour-pro__roi-controls { margin-top: 0.9rem; }
  .contour-pro__field { display: grid; gap: 0.45rem; color: var(--muted); font-size: 0.85rem; margin-top: 0.7rem; }
  .contour-pro__field--compact { margin-top: 0; }
  .contour-pro__field input[type='range'] { width: 100%; }

  .contour-pro button {
    border: 1px solid rgba(255,255,255,0.08); border-radius: 0.75rem; background: rgba(15,23,42,0.78);
    padding: 0.6rem 0.6rem; color: var(--text); font: inherit; cursor: pointer; font-size: 0.85rem;
    transition: transform 140ms ease, border-color 140ms ease, background 140ms ease;
  }
  .contour-pro button:hover { transform: translateY(-1px); border-color: rgba(34,211,238,0.28); background: rgba(34,211,238,0.08); }
  .contour-pro button.is-active {
    border-color: rgba(34,211,238,0.34); background: rgba(34,211,238,0.12); color: #cffafe;
  }

  .contour-pro__viewer-topbar { display: flex; justify-content: space-between; gap: 1rem; margin-bottom: 0.9rem; align-items: center; }
  .contour-pro__viewer-head-left, .contour-pro__viewer-head-right { display: flex; flex-wrap: wrap; gap: 0.8rem 1rem; align-items: center; }
  .contour-pro__viewer-title { font-size: 1rem; font-weight: 700; }
  .contour-pro__viewer-subtitle, .contour-pro__viewer-head-right span { color: var(--muted); font-size: 0.86rem; }

  .contour-pro__workspace, .contour-pro__bottom-grid { display: grid; gap: 1rem; }
  .contour-pro__viewer-wrap { display: grid; gap: 0.85rem; }
  .contour-pro__viewer-stage { display: grid; gap: 1rem; align-items: start; }

  .contour-pro__viewer {
    position: relative; width: 100%; aspect-ratio: 1 / 1; border-radius: 1rem; overflow: hidden;
    border: 1px solid rgba(255,255,255,0.08); background: #000; cursor: crosshair;
  }
  .contour-pro__viewer.is-pan { cursor: grab; }
  .contour-pro__viewer.is-pan.is-dragging { cursor: grabbing; }
  .contour-pro__viewer canvas, .contour-pro__overlay { position: absolute; inset: 0; width: 100%; height: 100%; display: block; }
  .contour-pro__overlay { pointer-events: none; }

  .contour-pro__viewer-rail { display: grid; gap: 0.9rem; align-content: start; }
  .contour-pro__rail-head { display: flex; justify-content: space-between; gap: 1rem; align-items: center; margin-bottom: 0.75rem; font-size: 0.9rem; }

  .contour-pro__crosshair { position: absolute; background: rgba(255,255,255,0.18); pointer-events: none; z-index: 4; }
  .contour-pro__crosshair--v { top: 0; bottom: 0; width: 1px; transform: translateX(-50%); }
  .contour-pro__crosshair--h { left: 0; right: 0; height: 1px; transform: translateY(-50%); }

  .contour-pro__corner { position: absolute; z-index: 5; display: grid; gap: 0.15rem; padding: 0.6rem 0.7rem; border-radius: 0.85rem; border: 1px solid rgba(255,255,255,0.08); background: rgba(2,6,23,0.72); backdrop-filter: blur(10px); }
  .contour-pro__corner strong { font-size: 0.82rem; }
  .contour-pro__corner span { font-size: 0.75rem; color: var(--muted); }
  .contour-pro__corner--lt { top: 0.8rem; left: 0.8rem; }

  .contour-pro__hint { color: var(--muted); font-size: 0.85rem; line-height: 1.5; }

  .contour-pro__scout-card { display: grid; gap: 0.8rem; align-content: start; }
  .contour-pro__scout-head h3 { font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--muted); }
  .contour-pro__scout-list { display: grid; gap: 0.35rem; }
  .contour-pro__scout-item {
    display: grid; grid-template-columns: 1.2rem 1fr 1rem; align-items: center; gap: 0.5rem; width: 100%;
    padding: 0.4rem 0.5rem; border-radius: 0.5rem; border: 1px solid rgba(255,255,255,0.05); background: rgba(15,23,42,0.5);
    color: var(--text); text-align: left; cursor: pointer; transition: background 140ms ease; font-size: 0.75rem;
  }
  .contour-pro__scout-item:hover, .contour-pro__scout-item.is-current { border-color: rgba(34,211,238,0.28); background: rgba(34,211,238,0.1); }
  .contour-pro__scout-index { font-weight: 700; color: #cbd5e1; text-align: center; }
  .contour-pro__scout-bar { height: 0.35rem; border-radius: 999px; background: rgba(71,85,105,0.4); overflow: hidden; }
  .contour-pro__scout-bar span { display: block; height: 100%; border-radius: inherit; background: linear-gradient(90deg, rgba(34,211,238,0.42), rgba(34,211,238,0.95)); }

  .contour-pro__eval-btn { width: 100%; border-color: rgba(34,211,238,0.4); background: rgba(34,211,238,0.15); color: #cffafe; font-weight: bold; padding: 0.7rem; }
  .contour-pro__eval-btn:hover { background: rgba(34,211,238,0.25); }
  .contour-pro__eval-content { margin-top: 1rem; }
  .contour-pro__eval-score { font-size: 2.2rem; font-weight: 800; line-height: 1; margin-bottom: 0.5rem; }
  .contour-pro__eval-details { display: grid; gap: 0.4rem; font-size: 0.85rem; color: var(--text); }
  .contour-pro__eval-details span { color: var(--muted); }

  .contour-pro__timeline { display: grid; gap: 0.5rem; grid-template-columns: repeat(8, minmax(0, 1fr)); }
  .contour-pro__slice-chip {
    border: 1px solid rgba(255,255,255,0.08); border-radius: 0.6rem; background: rgba(15,23,42,0.72); padding: 0.6rem 0.2rem;
    text-align: center; color: var(--muted); cursor: pointer; transition: transform 140ms ease, border-color 140ms ease; font-size: 0.85rem;
  }
  .contour-pro__slice-chip:hover, .contour-pro__slice-chip.is-current { border-color: rgba(34,211,238,0.28); }
  .contour-pro__slice-chip.has-data { background: rgba(34,211,238,0.08); color: #cffafe; }

  @media (min-width: 1220px) {
    .contour-pro__layout { grid-template-columns: 280px minmax(0, 1fr); align-items: start; }
    .contour-pro__sidebar { position: sticky; top: 1rem; }
    .contour-pro__workspace { grid-template-columns: minmax(0, 1fr) 130px; align-items: start; }
    .contour-pro__viewer-stage { grid-template-columns: minmax(0, 1fr) 230px; }
    .contour-pro__bottom-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }

  @media (max-width: 960px) {
    .contour-pro__toolbar { flex-wrap: wrap; padding-top: 1.5rem; }
    .contour-pro__timeline { grid-template-columns: repeat(8, minmax(0, 1fr)); }
    .contour-pro__bottom-grid { grid-template-columns: 1fr; }
    .contour-pro__viewer-stage, .contour-pro__workspace { grid-template-columns: 1fr; }
  }
</style>

<script define:vars={{ componentId, initialSlice }}>
  (() => {
    const root = document.querySelector(`[data-contour-pro="${componentId}"]`);
    if (!root) return;

    const viewer = root.querySelector('[data-viewer]');
    const canvas = root.querySelector('[data-image-canvas]');
    const ctx = canvas.getContext('2d');
    const panZoomLayer = root.querySelector('[data-pan-zoom-layer]');
    const gridLayer = root.querySelector('[data-grid-layer]');
    const contoursLayer = root.querySelector('[data-contours-layer]');
    const currentLayer = root.querySelector('[data-current-layer]');
    const previewLayer = root.querySelector('[data-preview-layer]');
    const annotationLayer = root.querySelector('[data-annotation-layer]');

    const roiList = root.querySelector('[data-roi-list]');
    const roiOpacity = root.querySelector('[data-roi-opacity]');
    const roiCount = root.querySelector('[data-roi-count]');

    const sliceRange = root.querySelector('[data-slice-range]');
    const windowRange = root.querySelector('[data-window-range]');
    const levelRange = root.querySelector('[data-level-range]');
    const zoomRange = root.querySelector('[data-zoom-range]');

    const metaWL = root.querySelector('[data-meta-wl]');
    const metaZoom = root.querySelector('[data-meta-zoom]');
    const metaCoords = root.querySelector('[data-meta-coords]');
    const railZoom = root.querySelector('[data-rail-zoom]');
    const hint = root.querySelector('[data-hint]');
    const timeline = root.querySelector('[data-timeline]');
    const timelineCaption = root.querySelector('[data-timeline-caption]');
    const scoutList = root.querySelector('[data-scout-list]');

    const evalBtn = root.querySelector('[data-evaluate]');
    const evalResults = root.querySelector('[data-eval-results]');

    const statRoi = root.querySelector('[data-stat-roi]');
    const statPoints = root.querySelector('[data-stat-points]');
    const statArea = root.querySelector('[data-stat-area]');
    const statCount = root.querySelector('[data-stat-count]');
    const statTotal = root.querySelector('[data-stat-total]');
    const statCursor = root.querySelector('[data-stat-cursor]');

    const cornerRoi = root.querySelector('[data-corner-roi]');
    const cornerMode = root.querySelector('[data-corner-mode]');
    const sliceLabel = root.querySelector('[data-slice-label]');

    const crossV = root.querySelector('[data-cross-v]');
    const crossH = root.querySelector('[data-cross-h]');

    const prevSliceBtn = root.querySelector('[data-prev-slice]');
    const nextSliceBtn = root.querySelector('[data-next-slice]');
    const playSlicesBtn = root.querySelector('[data-play-slices]');
    const zoomOutBtn = root.querySelector('[data-zoom-out]');
    const fitViewBtn = root.querySelector('[data-fit-view]');
    const zoomInBtn = root.querySelector('[data-zoom-in]');

    const addRoiBtn = root.querySelector('[data-add-roi]');
    const renameRoiBtn = root.querySelector('[data-rename-roi]');
    const closeContourBtn = root.querySelector('[data-close-contour]');
    const undoPointBtn = root.querySelector('[data-undo-point]');
    const clearSliceBtn = root.querySelector('[data-clear-slice]');
    const clonePrevBtn = root.querySelector('[data-clone-prev]');
    const cloneNextBtn = root.querySelector('[data-clone-next]');
    const interpolateBtn = root.querySelector('[data-interpolate]');
    const smoothContourBtn = root.querySelector('[data-smooth-contour]');
    const autoContourBtn = root.querySelector('[data-auto-contour]');
    const resetViewBtn = root.querySelector('[data-reset-view]');
    const saveLocalBtn = root.querySelector('[data-save-local]');
    const exportJsonBtn = root.querySelector('[data-export-json]');
    const presetButtons = Array.from(root.querySelectorAll('[data-wl-preset]'));
    const toolButtons = Array.from(root.querySelectorAll('[data-tool]'));

    const svgNS = 'http://www.w3.org/2000/svg';
    const imageSize = 512;
    const totalSlices = 16;
    const contourTolerance = 14;
    const storageKey = 'contour-sim-pro-demo-v7';
    const palette = ['#22d3ee', '#f97316', '#a78bfa', '#84cc16', '#f43f5e', '#facc15', '#38bdf8'];

    const rois = [
      { id: 'ptv', name: 'PTV', color: '#22d3ee', visible: true, opacity: 0.22 },
      { id: 'gtv', name: 'GTV', color: '#f97316', visible: true, opacity: 0.26 },
      { id: 'cord', name: 'Spinal Cord', color: '#a78bfa', visible: true, opacity: 0.2 },
      { id: 'body', name: 'Body', color: '#84cc16', visible: false, opacity: 0.12 },
    ];

    const state = {
      slice: Number(initialSlice), window: Number(windowRange.value), level: Number(levelRange.value), zoom: Number(zoomRange.value),
      panX: 0, panY: 0, tool: 'draw', activeRoiId: 'ptv',
      contours: {}, currentPoints: [], hoverPoint: null, draggingVertex: null,
      isPanning: false, panStart: null, isPlaying: false, playTimer: null,
      isFreehandDrawing: false,
    };

    const clamp = (value, min, max) => Math.min(max, Math.max(min, value));
    const distance = (a, b) => Math.hypot(a.x - b.x, a.y - b.y);
    const sliceKey = () => String(state.slice);
    const getActiveRoi = () => rois.find((roi) => roi.id === state.activeRoiId) || rois[0];
    const getSliceContours = () => state.contours[sliceKey()] || [];
    const getContoursForRoiOnSlice = (slice, roiId) => (state.contours[String(slice)] || []).filter((item) => item.roiId === roiId);
    const getFirstContourForRoiOnSlice = (slice, roiId) => getContoursForRoiOnSlice(slice, roiId)[0] || null;
    const escapeHtml = (value) => value.replaceAll('&', '&amp;').replaceAll('<', '&lt;').replaceAll('>', '&gt;').replaceAll('"', '&quot;').replaceAll("'", '&#039;');

    const polygonArea = (points) => {
      if (!points || points.length < 3) return 0;
      let area = 0;
      for (let i = 0; i < points.length; i += 1) {
        const p1 = points[i]; const p2 = points[(i + 1) % points.length];
        area += p1.x * p2.y - p2.x * p1.y;
      }
      return Math.abs(area / 2);
    };

    const anatomyForSlice = (slice) => {
      const t = slice / (totalSlices - 1);
      const bodyCx = 256; const bodyCy = 256;
      const bodyRx = 182 - Math.abs(0.5 - t) * 48;
      const bodyRy = 214 - Math.abs(0.5 - t) * 72;
      const lungRx = 54 - Math.abs(0.5 - t) * 8;
      const lungRy = 88 - Math.abs(0.5 - t) * 18;
      const lesionFactor = Math.max(0, 1 - Math.abs(slice - 8) / 4.8);

      return {
        bodyCx, bodyCy, bodyRx, bodyRy,
        lungLeftCx: bodyCx - 66, lungRightCx: bodyCx + 62, lungCy: bodyCy - 8, lungRx, lungRy,
        heartCx: bodyCx + 18, heartCy: bodyCy + 24, heartRx: 48 + Math.sin(t * Math.PI) * 8, heartRy: 44 + Math.sin(t * Math.PI) * 6,
        vertebraCx: bodyCx, vertebraCy: bodyCy + 80, vertebraRx: 28, vertebraRy: 22,
        canalCx: bodyCx, canalCy: bodyCy + 80, canalRx: 8, canalRy: 10,
        lesionCx: bodyCx + 84 - (0.5 - t) * 14, lesionCy: bodyCy - 6 + Math.sin(t * Math.PI) * 10, lesionRx: 18 + lesionFactor * 9, lesionRy: 16 + lesionFactor * 7,
        lesionFactor,
      };
    };

    const huAtPoint = (x, y, slice) => {
      const a = anatomyForSlice(slice);
      const baseNoise = (Math.sin(x * 0.11) + Math.sin(y * 0.09) + Math.sin((x + y) * 0.05) + Math.sin(x*0.3)*Math.sin(y*0.3)*0.5) * 14;
      
      const bodyDist = (((x - a.bodyCx) / a.bodyRx) ** 2) + (((y - a.bodyCy) / a.bodyRy) ** 2);
      const lungL = (((x - a.lungLeftCx) / a.lungRx) ** 2) + (((y - a.lungCy) / a.lungRy) ** 2);
      const lungR = (((x - a.lungRightCx) / a.lungRx) ** 2) + (((y - a.lungCy) / a.lungRy) ** 2);
      const heart = (((x - a.heartCx) / a.heartRx) ** 2) + (((y - a.heartCy) / a.heartRy) ** 2);
      
      const dxV = x - a.vertebraCx; const dyV = y - a.vertebraCy;
      const vertebraDist = Math.sqrt((dxV / a.vertebraRx)**2 + (dyV / a.vertebraRy)**2);
      const canal = (((x - a.canalCx) / a.canalRx) ** 2) + (((y - a.canalCy) / a.canalRy) ** 2);
      
      const dxL = x - a.lesionCx; const dyL = y - a.lesionCy;
      const angleL = Math.atan2(dyL, dxL);
      const lesionWobble = 1 + 0.15 * Math.sin(angleL * 7) + 0.1 * Math.sin(angleL * 13);
      const lesionDist = Math.sqrt((dxL / a.lesionRx)**2 + (dyL / a.lesionRy)**2) / lesionWobble;

      let hu = -980 + baseNoise * 0.4;
      if (bodyDist <= 1) hu = 32 + baseNoise * 0.4;
      
      if (lungL <= 1 || lungR <= 1) {
        const vesselNoise = Math.sin(x * 0.5) * Math.sin(y * 0.5) + Math.sin(x * 0.8 + y * 0.3);
        if (vesselNoise > 1.3) hu = 0 + baseNoise * 0.5;
        else hu = -780 + baseNoise * 0.6;
      }
      
      if (heart <= 1) hu = 58 + baseNoise * 0.35;
      if (vertebraDist <= 1) {
        if (vertebraDist > 0.75) hu = 450 + baseNoise * 0.8;
        else hu = 150 + baseNoise * 0.3;
      }
      if (canal <= 1) hu = 26 + baseNoise * 0.2;
      if (lesionDist <= 1 && a.lesionFactor > 0.05) {
         if (lesionDist < 0.4) hu = 20 + baseNoise * 0.2;
         else hu = 86 + a.lesionFactor * 24 + baseNoise * 0.3;
      }
      if (bodyDist > 1) hu = -1000 + baseNoise * 0.25;

      return hu;
    };

    const windowToGray = (hu) => {
      const lower = state.level - state.window / 2;
      const normalized = clamp((hu - lower) / state.window, 0, 1);
      return Math.round(normalized * 255);
    };

    const drawSlice = () => {
      const imageData = ctx.createImageData(imageSize, imageSize);
      const px = imageData.data;
      for (let y = 0; y < imageSize; y += 1) {
        for (let x = 0; x < imageSize; x += 1) {
          const hu = huAtPoint(x, y, state.slice);
          const gray = windowToGray(hu);
          const idx = (y * imageSize + x) * 4;
          px[idx] = gray; px[idx + 1] = gray; px[idx + 2] = gray; px[idx + 3] = 255;
        }
      }
      ctx.putImageData(imageData, 0, 0);
      ctx.strokeStyle = 'rgba(255,255,255,0.04)';
      ctx.lineWidth = 1;
      ctx.strokeRect(10.5, 10.5, imageSize - 21, imageSize - 21);
    };

    const createSvg = (tag, attrs = {}) => {
      const el = document.createElementNS(svgNS, tag);
      Object.entries(attrs).forEach(([key, value]) => el.setAttribute(key, String(value)));
      return el;
    };

    const clearNode = (node) => { while (node.firstChild) node.removeChild(node.firstChild); };
    const clampPan = () => { const minPan = imageSize - imageSize * state.zoom; state.panX = clamp(state.panX, minPan, 0); state.panY = clamp(state.panY, minPan, 0); };

    const setPanZoomTransform = () => {
      clampPan();
      const rect = viewer.getBoundingClientRect();
      const ratio = rect.width / imageSize;
      canvas.style.transformOrigin = 'top left';
      canvas.style.transform = `matrix(${state.zoom}, 0, 0, ${state.zoom}, ${state.panX * ratio}, ${state.panY * ratio})`;
      panZoomLayer.setAttribute('transform', `matrix(${state.zoom} 0 0 ${state.zoom} ${state.panX} ${state.panY})`);
      metaZoom.textContent = `Zoom ${state.zoom.toFixed(2)}x`;
      railZoom.textContent = `${state.zoom.toFixed(2)}x`;
    };

    const fitView = () => {
      state.zoom = 1; state.panX = 0; state.panY = 0; zoomRange.value = '1';
      setPanZoomTransform(); updateMetaAndStats(); renderContours();
    };

    const setZoom = (nextZoom, anchorX = imageSize / 2, anchorY = imageSize / 2) => {
      const clampedZoom = clamp(nextZoom, 1, 4.5);
      const oldZoom = state.zoom;
      if (clampedZoom === oldZoom) return;
      state.panX = anchorX - ((anchorX - state.panX) / oldZoom) * clampedZoom;
      state.panY = anchorY - ((anchorY - state.panY) / oldZoom) * clampedZoom;
      state.zoom = clampedZoom; zoomRange.value = clampedZoom.toFixed(2);
      setPanZoomTransform(); renderContours(); updateMetaAndStats(); autoSave();
    };

    const makePolygonPoints = (points) => points.map((p) => `${p.x},${p.y}`).join(' ');

    const renderGrid = () => {
      clearNode(gridLayer);
      for (let i = 64; i < imageSize; i += 64) {
        gridLayer.append(
          createSvg('line', { x1: i, y1: 0, x2: i, y2: imageSize, stroke: 'rgba(255,255,255,0.045)', 'stroke-width': 1 }),
          createSvg('line', { x1: 0, y1: i, x2: imageSize, y2: i, stroke: 'rgba(255,255,255,0.045)', 'stroke-width': 1 }),
        );
      }
    };

    const renderAnnotations = () => { clearNode(annotationLayer); };

    const renderContours = () => {
      clearNode(contoursLayer); clearNode(currentLayer); clearNode(previewLayer); renderAnnotations();
      
      const z = state.zoom;
      const strokeW = 2 / z;
      const activeStrokeW = 2.6 / z;
      const ptRadius = 4.6 / z;
      const ptRadiusActive = 5.8 / z;
      const editRadius = 5 / z;
      const editRadiusHover = 6.5 / z;

      const sliceContours = getSliceContours();
      sliceContours.forEach((contour, contourIndex) => {
        const roi = rois.find((item) => item.id === contour.roiId);
        if (!roi || !roi.visible) return;

        const polygon = createSvg('polygon', {
          points: makePolygonPoints(contour.points), fill: roi.color, 'fill-opacity': roi.opacity,
          stroke: roi.color, 'stroke-width': contour.roiId === state.activeRoiId ? activeStrokeW : strokeW, 'stroke-linejoin': 'round',
        });
        contoursLayer.appendChild(polygon);

        if (contour.roiId === state.activeRoiId && state.tool === 'edit') {
          contour.points.forEach((point, pointIndex) => {
            const isDragging = state.draggingVertex && state.draggingVertex.contourIndex === contourIndex && state.draggingVertex.pointIndex === pointIndex;
            currentLayer.appendChild(createSvg('circle', {
              cx: point.x, cy: point.y, r: isDragging ? editRadiusHover : editRadius,
              fill: roi.color, stroke: '#ffffff', 'stroke-width': 1.5 / z,
            }));
          });
        }
      });

      if (state.currentPoints.length > 0) {
        const activeRoi = getActiveRoi();
        if (state.currentPoints.length > 1) {
          currentLayer.appendChild(createSvg('polyline', {
            points: makePolygonPoints(state.currentPoints), fill: 'none', stroke: activeRoi.color, 'stroke-width': activeStrokeW, 'stroke-linejoin': 'round',
          }));
        }

        state.currentPoints.forEach((point, index) => {
          currentLayer.appendChild(createSvg('circle', {
            cx: point.x, cy: point.y, r: index === 0 ? ptRadiusActive : ptRadius,
            fill: index === 0 ? '#ffffff' : activeRoi.color, stroke: activeRoi.color, 'stroke-width': 1.5 / z,
          }));
        });
      }

      if (state.hoverPoint && (state.tool === 'draw' || state.tool === 'freehand') && state.currentPoints.length > 0) {
        const activeRoi = getActiveRoi();
        const last = state.currentPoints[state.currentPoints.length - 1];
        previewLayer.appendChild(createSvg('line', {
          x1: last.x, y1: last.y, x2: state.hoverPoint.x, y2: state.hoverPoint.y,
          stroke: activeRoi.color, 'stroke-width': 1.8 / z, 'stroke-dasharray': `${7/z} ${7/z}`,
        }));
      }
    };

    const updateMetaAndStats = () => {
      const activeRoi = getActiveRoi();
      const contoursOnSlice = getContoursForRoiOnSlice(state.slice, activeRoi.id);
      const lastContour = contoursOnSlice[contoursOnSlice.length - 1];
      const totalContours = Object.values(state.contours).flat().filter((item) => item.roiId === activeRoi.id).length;

      roiOpacity.value = String(activeRoi.opacity);
      sliceLabel.textContent = `Slice ${state.slice} / ${totalSlices - 1}`;
      metaWL.textContent = `W ${state.window} / L ${state.level}`;
      timelineCaption.textContent = `Active ROI: ${activeRoi.name}`;
      
      cornerRoi.textContent = activeRoi.name;
      cornerMode.textContent = state.tool === 'draw' ? 'Draw mode' : state.tool === 'freehand' ? 'Freehand mode' : state.tool === 'edit' ? 'Edit mode' : 'Pan mode';

      statRoi.textContent = activeRoi.name;
      statPoints.textContent = String(state.currentPoints.length);
      statArea.textContent = String(Math.round(lastContour ? polygonArea(lastContour.points) : 0));
      statCount.textContent = String(contoursOnSlice.length);
      statTotal.textContent = String(totalContours);
      roiCount.textContent = `${rois.filter((roi) => roi.visible).length} visible`;
      
      playSlicesBtn.textContent = state.isPlaying ? 'Stop' : 'Play';
      playSlicesBtn.classList.toggle('is-active', state.isPlaying);
      
      evalResults.innerHTML = '<p class="contour-pro__hint">Press button to analyze accuracy, coverage, and node density for the current slice compared to AI reference.</p>';
    };

    const renderHint = () => {
      const map = {
        draw: 'Click to add points. Click near the first point to close contour. Ctrl + Scroll to zoom.',
        freehand: 'Click and drag to draw freely. Release the mouse to auto-close the contour.',
        edit: 'Drag the points of an existing contour to adjust its shape.',
        pan: 'Click and drag to move the view.',
      };
      hint.textContent = map[state.tool];
      viewer.classList.toggle('is-pan', state.tool === 'pan');
      viewer.classList.toggle('is-dragging', state.isPanning);
    };

    const renderRoiList = () => {
      roiList.innerHTML = rois.map((roi) => {
        const count = Object.values(state.contours).flat().filter((item) => item.roiId === roi.id).length;
        return `
          <div class="contour-pro__roi-item ${roi.id === state.activeRoiId ? 'is-active' : ''}" data-roi-id="${escapeHtml(roi.id)}">
            <div class="contour-pro__roi-main">
              <span class="contour-pro__roi-dot" style="background:${escapeHtml(roi.color)}"></span>
              <span>
                <span class="contour-pro__roi-name">${escapeHtml(roi.name)}</span><br />
                <span class="contour-pro__roi-meta">${count} contours saved</span>
              </span>
            </div>
            <div class="contour-pro__roi-actions-side">
              <button type="button" class="contour-pro__eye-btn" data-toggle-visible="${escapeHtml(roi.id)}">${roi.visible ? '◉' : '○'}</button>
            </div>
          </div>
        `;
      }).join('');

      Array.from(roiList.querySelectorAll('[data-roi-id]')).forEach((row) => {
        row.addEventListener('click', () => { state.activeRoiId = row.getAttribute('data-roi-id'); state.currentPoints = []; renderAll(); });
      });

      Array.from(roiList.querySelectorAll('[data-toggle-visible]')).forEach((btn) => {
        btn.addEventListener('click', (event) => {
          event.stopPropagation();
          const roi = rois.find((item) => item.id === btn.getAttribute('data-toggle-visible'));
          if (!roi) return;
          roi.visible = !roi.visible;
          renderAll();
        });
      });
    };

    const renderTimeline = () => {
      timeline.innerHTML = '';
      for (let slice = 0; slice < totalSlices; slice += 1) {
        const contours = getContoursForRoiOnSlice(slice, state.activeRoiId);
        const hasData = contours.length > 0;
        const button = document.createElement('button');
        button.type = 'button';
        button.className = `contour-pro__slice-chip ${slice === state.slice ? 'is-current' : ''} ${hasData ? 'has-data' : ''}`;
        button.innerHTML = `<strong>${slice}</strong>`;
        button.addEventListener('click', () => { state.slice = slice; state.currentPoints = []; sliceRange.value = String(slice); renderAll(); });
        timeline.appendChild(button);
      }
    };

    const renderScout = () => {
      scoutList.innerHTML = '';
      const areas = Array.from({ length: totalSlices }, (_, slice) => {
        const contour = getFirstContourForRoiOnSlice(slice, state.activeRoiId);
        return contour ? polygonArea(contour.points) : 0;
      });
      const maxArea = Math.max(...areas, 1);

      for (let slice = 0; slice < totalSlices; slice += 1) {
        const contourCount = getContoursForRoiOnSlice(slice, state.activeRoiId).length;
        const widthPct = Math.round((areas[slice] / maxArea) * 100);
        const button = document.createElement('button');
        button.type = 'button';
        button.className = `contour-pro__scout-item ${slice === state.slice ? 'is-current' : ''}`;
        button.innerHTML = `
          <span class="contour-pro__scout-index">${slice}</span>
          <span class="contour-pro__scout-bar"><span style="width:${widthPct}%"></span></span>
          <span style="font-size:0.7rem; color:var(--muted); text-align:right;">${contourCount > 0 ? contourCount : ''}</span>
        `;
        button.addEventListener('click', () => { state.slice = slice; state.currentPoints = []; sliceRange.value = String(slice); renderAll(); });
        scoutList.appendChild(button);
      }
    };

    const renderAll = () => {
      drawSlice(); renderGrid(); renderContours(); renderRoiList(); renderTimeline(); renderScout(); updateMetaAndStats(); renderHint(); setPanZoomTransform(); autoSave();
    };

    const clientToImagePoint = (clientX, clientY) => {
      const rect = viewer.getBoundingClientRect();
      const xView = ((clientX - rect.left) / rect.width) * imageSize;
      const yView = ((clientY - rect.top) / rect.height) * imageSize;
      return {
        x: clamp((xView - state.panX) / state.zoom, 0, imageSize),
        y: clamp((yView - state.panY) / state.zoom, 0, imageSize),
      };
    };

    const setCrosshair = (clientX, clientY, imagePoint) => {
      const rect = viewer.getBoundingClientRect();
      const leftPct = ((clientX - rect.left) / rect.width) * 100;
      const topPct = ((clientY - rect.top) / rect.height) * 100;
      crossV.hidden = false; crossH.hidden = false;
      crossV.style.left = `${leftPct}%`; crossH.style.top = `${topPct}%`;
      const hu = Math.round(huAtPoint(imagePoint.x, imagePoint.y, state.slice));
      metaCoords.textContent = `X ${Math.round(imagePoint.x)} | Y ${Math.round(imagePoint.y)} | HU ${hu}`;
      statCursor.textContent = `${Math.round(imagePoint.x)}, ${Math.round(imagePoint.y)} | ${hu} HU`;
    };

    const clearCrosshair = () => { crossV.hidden = true; crossH.hidden = true; metaCoords.textContent = 'X 0 | Y 0 | HU 0'; statCursor.textContent = '—'; };

    const commitCurrentContour = () => {
      if (state.currentPoints.length < 3) return;
      const key = sliceKey();
      state.contours[key] = state.contours[key] || [];
      state.contours[key].push({ roiId: state.activeRoiId, points: state.currentPoints.map((point) => ({ ...point })) });
      state.currentPoints = []; renderAll();
    };

    const handleDrawClick = (point) => {
      const dynamicTol = contourTolerance / state.zoom;
      if (state.currentPoints.length >= 3 && distance(point, state.currentPoints[0]) < dynamicTol) {
        commitCurrentContour(); return;
      }
      state.currentPoints.push(point); renderContours(); updateMetaAndStats(); autoSave();
    };

    const findVertexAtPoint = (point) => {
      const contours = getSliceContours();
      const dynamicTol = 10 / state.zoom;
      for (let contourIndex = 0; contourIndex < contours.length; contourIndex += 1) {
        const contour = contours[contourIndex];
        if (contour.roiId !== state.activeRoiId) continue;
        for (let pointIndex = 0; pointIndex < contour.points.length; pointIndex += 1) {
          if (distance(point, contour.points[pointIndex]) <= dynamicTol) return { contourIndex, pointIndex };
        }
      }
      return null;
    };

    const runEvaluation = () => {
      const contour = getFirstContourForRoiOnSlice(state.slice, state.activeRoiId);
      if (!contour || contour.points.length < 3) {
        evalResults.innerHTML = '<span style="color:var(--danger)">Error: No closed contour found for this ROI on current slice.</span>'; return;
      }
      const a = anatomyForSlice(state.slice);
      let target = null; let targetName = "";

      if (state.activeRoiId === 'ptv' || state.activeRoiId === 'gtv') { target = { cx: a.lesionCx, cy: a.lesionCy, rx: a.lesionRx, ry: a.lesionRy }; targetName = "Target volume"; } 
      else if (state.activeRoiId === 'body') { target = { cx: a.bodyCx, cy: a.bodyCy, rx: a.bodyRx, ry: a.bodyRy }; targetName = "External Body"; } 
      else if (state.activeRoiId === 'cord') { target = { cx: a.canalCx, cy: a.canalCy, rx: a.canalRx, ry: a.canalRy }; targetName = "Spinal Cord"; }

      if (!target || target.rx <= 0 || a.lesionFactor <= 0.05 && (state.activeRoiId === 'ptv' || state.activeRoiId === 'gtv')) {
        evalResults.innerHTML = '<span style="color:var(--warning)">Target structure not present/evaluable on this slice.</span>'; return;
      }

      let cx = 0, cy = 0;
      contour.points.forEach(p => { cx+=p.x; cy+=p.y; });
      cx /= contour.points.length; cy /= contour.points.length;

      const dist = Math.hypot(cx - target.cx, cy - target.cy);
      const centerScore = Math.max(0, 100 - (dist / (target.rx * 0.5)) * 100);

      const userArea = polygonArea(contour.points);
      const trueArea = Math.PI * target.rx * target.ry;
      const areaScore = Math.max(0, 100 - (Math.abs(userArea - trueArea) / trueArea) * 100);

      const n = contour.points.length;
      let nodeScore = 100;
      if (n < 8) nodeScore -= 40;
      else if (n < 12) nodeScore -= 15;
      else if (n > 80) nodeScore -= 20;
      nodeScore = Math.max(0, nodeScore);

      const finalScore = Math.round((centerScore * 0.4) + (areaScore * 0.45) + (nodeScore * 0.15));
      let colorClass = finalScore >= 90 ? 'var(--success)' : finalScore >= 75 ? 'var(--warning)' : 'var(--danger)';

      evalResults.innerHTML = `
        <div class="contour-pro__eval-score" style="color: ${colorClass}">${finalScore}%</div>
        <div class="contour-pro__eval-details">
          <div><span>AI Reference:</span> ${targetName}</div>
          <div><span>Area Accuracy (Dice-like):</span> ${Math.round(areaScore)}%</div>
          <div><span>Isocenter alignment:</span> ${Math.round(centerScore)}%</div>
          <div><span>Node density (${n} pts):</span> ${Math.round(nodeScore)}%</div>
        </div>
      `;
    };
    evalBtn.addEventListener('click', runEvaluation);

    const resamplePolygon = (points, samples = 64) => {
      const closed = [...points, points[0]];
      const lengths = []; let perimeter = 0;
      for (let i = 0; i < closed.length - 1; i += 1) {
        const seg = distance(closed[i], closed[i + 1]);
        lengths.push(seg); perimeter += seg;
      }
      const step = perimeter / samples;
      const result = []; let segIndex = 0; let segAccum = 0;

      for (let s = 0; s < samples; s += 1) {
        const target = s * step;
        while (segIndex < lengths.length - 1 && segAccum + lengths[segIndex] < target) { segAccum += lengths[segIndex]; segIndex += 1; }
        const p1 = closed[segIndex]; const p2 = closed[segIndex + 1];
        const local = lengths[segIndex] === 0 ? 0 : (target - segAccum) / lengths[segIndex];
        result.push({ x: p1.x + (p2.x - p1.x) * local, y: p1.y + (p2.y - p1.y) * local });
      }
      return result;
    };

    const smoothPoints = (points) => points.map((point, index) => {
      const prev = points[(index - 1 + points.length) % points.length];
      const next = points[(index + 1) % points.length];
      return { x: (prev.x + point.x * 2 + next.x) / 4, y: (prev.y + point.y * 2 + next.y) / 4 };
    });

    const replaceActiveRoiContoursOnCurrentSlice = (newContour) => {
      const key = sliceKey();
      state.contours[key] = (state.contours[key] || []).filter((item) => item.roiId !== state.activeRoiId);
      if (newContour) state.contours[key].push({ roiId: state.activeRoiId, points: newContour.map((p) => ({ ...p })) });
    };

    const interpolateCurrentSlice = () => {
      let prevSlice = null; let nextSlice = null;
      for (let i = state.slice - 1; i >= 0; i -= 1) { if (getFirstContourForRoiOnSlice(i, state.activeRoiId)) { prevSlice = i; break; } }
      for (let i = state.slice + 1; i < totalSlices; i += 1) { if (getFirstContourForRoiOnSlice(i, state.activeRoiId)) { nextSlice = i; break; } }
      if (prevSlice === null || nextSlice === null || prevSlice === nextSlice) return;

      const prevContour = getFirstContourForRoiOnSlice(prevSlice, state.activeRoiId);
      const nextContour = getFirstContourForRoiOnSlice(nextSlice, state.activeRoiId);
      if (!prevContour || !nextContour) return;

      const a = resamplePolygon(prevContour.points, 64);
      const b = resamplePolygon(nextContour.points, 64);
      const t = (state.slice - prevSlice) / (nextSlice - prevSlice);
      const interpolated = a.map((p, idx) => ({ x: p.x + (b[idx].x - p.x) * t, y: p.y + (b[idx].y - p.y) * t }));
      replaceActiveRoiContoursOnCurrentSlice(interpolated); renderAll();
    };

    const cloneContourToSlice = (targetSlice) => {
      const current = getFirstContourForRoiOnSlice(state.slice, state.activeRoiId);
      if (!current || targetSlice < 0 || targetSlice > totalSlices - 1) return;
      const key = String(targetSlice);
      state.contours[key] = (state.contours[key] || []).filter((item) => item.roiId !== state.activeRoiId);
      state.contours[key].push({ roiId: state.activeRoiId, points: current.points.map((p) => ({ ...p })) });
      state.slice = targetSlice; sliceRange.value = String(state.slice); renderAll();
    };

    const smoothActiveContour = () => {
      const contour = getFirstContourForRoiOnSlice(state.slice, state.activeRoiId);
      if (!contour) return;
      contour.points = smoothPoints(contour.points); renderAll();
    };

    const autoContourDemo = () => {
      const a = anatomyForSlice(state.slice);
      if (a.lesionFactor <= 0.05) return;
      const points = [];
      const n = 24;
      for (let i = 0; i < n; i += 1) {
        const angle = (Math.PI * 2 * i) / n;
        const rWobble = 1 + 0.15 * Math.sin(angle * 7) + 0.1 * Math.sin(angle * 13);
        points.push({
          x: a.lesionCx + Math.cos(angle) * a.lesionRx * rWobble,
          y: a.lesionCy + Math.sin(angle) * a.lesionRy * rWobble,
        });
      }
      replaceActiveRoiContoursOnCurrentSlice(points); renderAll();
    };

    const autoSave = () => { try { localStorage.setItem(storageKey, JSON.stringify({ rois, contours: state.contours })); } catch {} };

    const loadLocal = () => {
      try {
        const raw = localStorage.getItem(storageKey);
        if (!raw) return;
        const parsed = JSON.parse(raw);
        if (Array.isArray(parsed.rois)) {
          parsed.rois.forEach((saved) => {
            const match = rois.find((roi) => roi.id === saved.id);
            if (match) { match.name = saved.name ?? match.name; match.color = saved.color ?? match.color; match.visible = saved.visible ?? match.visible; match.opacity = saved.opacity ?? match.opacity; }
          });
        }
        if (parsed.contours && typeof parsed.contours === 'object') state.contours = parsed.contours;
      } catch {}
    };

    const exportJson = () => {
      const payload = { study: 'Demo Patient / CT Thorax', sliceCount: totalSlices, activeRoi: getActiveRoi().name, rois, contours: state.contours };
      const blob = new Blob([JSON.stringify(payload, null, 2)], { type: 'application/json' });
      const url = URL.createObjectURL(blob);
      const link = document.createElement('a'); link.href = url; link.download = 'contour-demo-export.json';
      document.body.appendChild(link); link.click(); link.remove(); URL.revokeObjectURL(url);
    };

    const setPreset = (name) => {
      const presets = { lung: { window: 1500, level: -550 }, mediastin: { window: 400, level: 40 }, osos: { window: 1800, level: 350 } };
      const preset = presets[name];
      if (!preset) return;
      state.window = preset.window; state.level = preset.level; windowRange.value = String(preset.window); levelRange.value = String(preset.level); renderAll();
    };

    const stopPlayback = () => { if (state.playTimer) window.clearInterval(state.playTimer); state.playTimer = null; state.isPlaying = false; updateMetaAndStats(); };
    const startPlayback = () => {
      stopPlayback(); state.isPlaying = true;
      state.playTimer = window.setInterval(() => { state.slice = state.slice >= totalSlices - 1 ? 0 : state.slice + 1; sliceRange.value = String(state.slice); state.currentPoints = []; renderAll(); }, 500);
      updateMetaAndStats();
    };
    const togglePlayback = () => { if (state.isPlaying) stopPlayback(); else startPlayback(); };

    const onPointerDown = (event) => {
      const point = clientToImagePoint(event.clientX, event.clientY);
      if (state.tool === 'pan') { state.isPanning = true; state.panStart = { clientX: event.clientX, clientY: event.clientY, panX: state.panX, panY: state.panY }; renderHint(); return; }
      if (state.tool === 'edit') { const hit = findVertexAtPoint(point); if (hit) { state.draggingVertex = hit; renderContours(); } return; }
      
      // Logică nouă Freehand
      if (state.tool === 'freehand') {
        if (state.currentPoints.length > 0) commitCurrentContour(); 
        state.isFreehandDrawing = true;
        state.currentPoints.push(point);
        renderContours();
        return;
      }
      
      if (state.tool === 'draw') handleDrawClick(point);
    };

    const onPointerMove = (event) => {
      const point = clientToImagePoint(event.clientX, event.clientY);
      state.hoverPoint = point; setCrosshair(event.clientX, event.clientY, point);

      if (state.tool === 'pan' && state.isPanning && state.panStart) {
        const rect = viewer.getBoundingClientRect();
        state.panX = state.panStart.panX + (((event.clientX - state.panStart.clientX) / rect.width) * imageSize);
        state.panY = state.panStart.panY + (((event.clientY - state.panStart.clientY) / rect.height) * imageSize);
        setPanZoomTransform(); renderHint(); return;
      }

      if (state.tool === 'edit' && state.draggingVertex) {
        const contours = getSliceContours();
        const contour = contours[state.draggingVertex.contourIndex];
        if (contour) { contour.points[state.draggingVertex.pointIndex] = point; renderContours(); updateMetaAndStats(); renderTimeline(); renderScout(); autoSave(); }
        return;
      }
      
      // Logică nouă Freehand (verifică distanța)
      if (state.tool === 'freehand' && state.isFreehandDrawing) {
        const lastPoint = state.currentPoints[state.currentPoints.length - 1];
        const distThreshold = 4 / state.zoom; 
        
        if (distance(point, lastPoint) > distThreshold) {
          state.currentPoints.push(point);
          renderContours();
          updateMetaAndStats();
        }
        return;
      }

      renderContours();
    };

    const onPointerUp = () => {
      // Finalizare Freehand la eliberarea click-ului
      if (state.tool === 'freehand' && state.isFreehandDrawing) {
        state.isFreehandDrawing = false;
        if (state.currentPoints.length >= 3) {
          commitCurrentContour();
        } else {
          state.currentPoints = [];
          renderAll();
        }
      }
      
      state.draggingVertex = null; state.isPanning = false; state.panStart = null; renderAll();
    };

    viewer.addEventListener('pointerdown', onPointerDown);
    
viewer.addEventListener('wheel', (event) => {
      event.preventDefault();
      // Modificarea este aici: am adăugat || state.tool === 'pan'
      if (event.ctrlKey || event.metaKey || event.shiftKey || state.tool === 'pan') {
        const rect = viewer.getBoundingClientRect();
        const anchorX = ((event.clientX - rect.left) / rect.width) * imageSize;
        const anchorY = ((event.clientY - rect.top) / rect.height) * imageSize;
        const delta = event.deltaY < 0 ? 0.12 : -0.12;
        setZoom(state.zoom + delta, anchorX, anchorY);
      } else {
        if (event.deltaY > 0) state.slice = clamp(state.slice - 1, 0, totalSlices - 1);
        else state.slice = clamp(state.slice + 1, 0, totalSlices - 1);
        
        sliceRange.value = String(state.slice);
        state.currentPoints = [];
        renderAll();
      }
    }, { passive: false });

    window.addEventListener('pointermove', onPointerMove);
    window.addEventListener('pointerup', onPointerUp);
    window.addEventListener('pointercancel', onPointerUp);
    viewer.addEventListener('mouseleave', () => { 
      state.hoverPoint = null; 
      clearCrosshair(); 
      // Oprește freehand-ul dacă ieși de pe canvas
      if (state.tool === 'freehand' && state.isFreehandDrawing) onPointerUp();
      renderContours(); 
    });

    sliceRange.addEventListener('input', () => { state.slice = Number(sliceRange.value); state.currentPoints = []; renderAll(); });
    windowRange.addEventListener('input', () => { state.window = Number(windowRange.value); renderAll(); });
    levelRange.addEventListener('input', () => { state.level = Number(levelRange.value); renderAll(); });
    zoomRange.addEventListener('input', () => setZoom(Number(zoomRange.value)));

    roiOpacity.addEventListener('input', () => { const active = getActiveRoi(); active.opacity = Number(roiOpacity.value); renderContours(); renderRoiList(); autoSave(); });

    prevSliceBtn.addEventListener('click', () => { state.slice = clamp(state.slice - 1, 0, totalSlices - 1); sliceRange.value = String(state.slice); state.currentPoints = []; renderAll(); });
    nextSliceBtn.addEventListener('click', () => { state.slice = clamp(state.slice + 1, 0, totalSlices - 1); sliceRange.value = String(state.slice); state.currentPoints = []; renderAll(); });
    playSlicesBtn.addEventListener('click', togglePlayback);

    zoomOutBtn.addEventListener('click', () => setZoom(state.zoom - 0.1));
    zoomInBtn.addEventListener('click', () => setZoom(state.zoom + 0.1));
    fitViewBtn.addEventListener('click', fitView);

    addRoiBtn.addEventListener('click', () => {
      const name = window.prompt('Numele noii structuri:', `ROI ${rois.length + 1}`);
      if (!name) return;
      const id = `roi-${Date.now().toString(36)}`;
      rois.push({ id, name: name.trim(), color: palette[rois.length % palette.length], visible: true, opacity: 0.22 });
      state.activeRoiId = id; state.currentPoints = []; renderAll();
    });

    renameRoiBtn.addEventListener('click', () => { const active = getActiveRoi(); const name = window.prompt('Nume nou pentru ROI:', active.name); if (!name) return; active.name = name.trim(); renderAll(); });

    closeContourBtn.addEventListener('click', commitCurrentContour);
    undoPointBtn.addEventListener('click', () => { state.currentPoints.pop(); renderContours(); updateMetaAndStats(); autoSave(); });
    clearSliceBtn.addEventListener('click', () => { const key = sliceKey(); state.contours[key] = (state.contours[key] || []).filter((item) => item.roiId !== state.activeRoiId); state.currentPoints = []; renderAll(); });
    clonePrevBtn.addEventListener('click', () => cloneContourToSlice(state.slice - 1));
    cloneNextBtn.addEventListener('click', () => cloneContourToSlice(state.slice + 1));
    interpolateBtn.addEventListener('click', interpolateCurrentSlice);
    smoothContourBtn.addEventListener('click', smoothActiveContour);
    autoContourBtn.addEventListener('click', autoContourDemo);
    resetViewBtn.addEventListener('click', fitView);
    saveLocalBtn.addEventListener('click', autoSave);
    exportJsonBtn.addEventListener('click', exportJson);
    presetButtons.forEach((button) => button.addEventListener('click', () => setPreset(button.getAttribute('data-wl-preset'))));

    toolButtons.forEach((button) => {
      button.addEventListener('click', () => {
        state.tool = button.getAttribute('data-tool');
        toolButtons.forEach((item) => item.classList.toggle('is-active', item === button));
        renderHint(); renderContours(); updateMetaAndStats();
      });
    });

    window.addEventListener('keydown', (event) => {
      const tag = event.target && event.target.tagName;
      if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'BUTTON') return;
      if (event.key === 'ArrowUp') { event.preventDefault(); state.slice = clamp(state.slice + 1, 0, totalSlices - 1); sliceRange.value = String(state.slice); renderAll(); } 
      else if (event.key === 'ArrowDown') { event.preventDefault(); state.slice = clamp(state.slice - 1, 0, totalSlices - 1); sliceRange.value = String(state.slice); renderAll(); } 
      else if (event.key === '+' || event.key === '=') { event.preventDefault(); setZoom(state.zoom + 0.1); } 
      else if (event.key === '-') { event.preventDefault(); setZoom(state.zoom - 0.1); } 
      else if (event.key === 'Enter') { event.preventDefault(); commitCurrentContour(); }
    });

    window.addEventListener('resize', setPanZoomTransform);
    loadLocal(); fitView(); renderAll();
  })();
</script>