---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Servicii from "../components/Servicii.astro";
import Despre from "../components/Despre.astro";
import Faq from "../components/Faq.astro";
import Programare from "../components/Programare.astro";
import Footer from "../components/Footer.astro";

import { getAlternateLinks } from "../i18n/paths";
---

<BaseLayout
  title="Dr. Tatiana Cirimpei - Radioterapie"
  description="Consultații medicale și tratamente de radioterapie personalizate în Cluj-Napoca."
  locale="ro"
  canonicalPath="/"
  alternates={getAlternateLinks("/")}
>
  <Header locale="ro" currentPath="/" />
  <Hero locale="ro" />
  <Servicii locale="ro"/>
  <Despre locale="ro" />
  <Faq locale="ro"/>
  <Programare locale="ro" />
  <Footer locale="ro" />
</BaseLayout>