---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Servicii from "../components/Servicii.astro";
import Despre from "../components/Despre.astro";
import Faq from "../components/Faq.astro";
import Programare from "../components/Programare.astro";
import Footer from "../components/Footer.astro";

import { getAlternateLinks } from "../i18n/paths";

const homepageSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalWebPage",
  "name": "Consultații și Tratamente de Radioterapie în Cluj-Napoca | Dr. Tatiana Cirimpei",
  "description": "Consultații medicale de specialitate și tratamente de radioterapie personalizate pentru afecțiuni oncologice și non-oncologice, oferite de Dr. Tatiana Cirimpei în Cluj-Napoca.",
  "about": {
    "@type": "MedicalSpecialty",
    "name": "RadiationTherapy"
  },
  "audience": {
    "@type": "MedicalAudience",
    "audienceType": "Pacienți"
  }
};
---
<BaseLayout
  title="Dr. Tatiana Cirimpei - Medic Specialist Radioterapie Cluj-Napoca"
  description="Consultații medicale și tratamente de radioterapie personalizate în Cluj-Napoca. Programează o consultație la Dr. Tatiana Cirimpei pentru planuri de tratament oncologic."
  locale="ro"
  canonicalPath="/"
  alternates={getAlternateLinks("/")}
  structuredData={homepageSchema}
>
  <Header locale="ro" currentPath="/" />
  <Hero locale="ro" />
  <Servicii locale="ro"/>
  <Despre locale="ro" />
  <Faq locale="ro"/>
  <Programare locale="ro" />
  <Footer locale="ro" />
</BaseLayout>