---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ArticlesIndex from "../components/ArticlesIndex.astro";
import { getAlternateLinks } from "../i18n/paths";
---

<BaseLayout
  title="Blog Medical - Articole și Noutăți despre Radioterapie | Dr. Tatiana Cirimpei"
  description="Citește articole medicale scrise de Dr. Tatiana Cirimpei. Ghiduri, noutăți și informații esențiale despre radioterapie și tratamente oncologice pentru pacienți."
  locale="ro"
  canonicalPath="/articole"
  alternates={getAlternateLinks("/articole")}
>
  <Header locale="ro" currentPath="/articole" />
  <ArticlesIndex locale="ro" />
  <Footer locale="ro" />
</BaseLayout>