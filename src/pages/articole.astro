---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { articles, featuredArticleSlug } from "../data/articles";

const featuredArticle = articles.find((article) => article.slug === featuredArticleSlug) ?? articles[0];
const latestArticles = articles.filter((article) => article.slug !== featuredArticle.slug);
const categories = Array.from(new Set(articles.map((article) => article.category)));
---

<BaseLayout
  title="Articole | Dr. Cirimpei Tatiana - Radioterapie"
  description="Articole medicale despre radioterapie, oncologie și ghiduri utile pentru pacienți."
>
  <Header />

  <main class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
    <section class="mb-10 border-b border-(--rt-border) dark:border-cyan-700 pb-4 lg:mb-8">
      <h1 class="mt-2 text-4xl font-medium tracking-tight text-gray-900 dark:text-gray-200">
        Articole și informații utile despre radioterapie
      </h1>
      <p class="mt-5 text-base leading-relaxed dark:text-gray-300 sm:text-lg">
        Articolele de mai jos sunt gândite să vă ajute să înțelegeți mai bine tratamentul cu radioterapie și să vă susțină pe parcursul acestei etape – indiferent dacă sunteți pacient sau aparținător.
      </p>

      <div aria-label="Categorii articole" class="mt-6 flex flex-wrap items-center gap-2">
        <a
          href="/articole"
          data-category-chip
          data-category-value=""
          class="rt-btn-ghost px-4 py-2 text-xs font-semibold tracking-[0.12em] uppercase"
        >
          Toate categoriile
        </a>
        {categories.map((category) => (
          <a
            href={`/articole?categorie=${encodeURIComponent(category)}`}
            data-category-chip
            data-category-value={category}
            class="rt-btn-ghost px-4 py-2 text-xs font-semibold tracking-[0.12em] uppercase"
          >
            {category}
          </a>
        ))}
      </div>
    </section>

    <p class="mt-4 mb-2 text-base leading-relaxed text-ink sm:text-lg">
      Ultimul articol publicat
    </p>
    <section id="featured-article-section" data-featured-category={featuredArticle.category} class="mb-14 overflow-hidden rounded-2xl border border-(--rt-border) dark:bg-black  bg-surface-2 shadow-sm shadow-slate-200/45 dark:shadow-cyan-900">
      <div class="grid gap-0 md:grid-cols-2">
        <div class="relative min-h-[290px] md:min-h-[420px]">
          <a  href={`/articole/${featuredArticle.slug}`}>
          <img
            src={featuredArticle.coverImage}
            alt={featuredArticle.coverAlt}
            loading="eager"
            decoding="async"
            class="h-full w-full object-cover cursor-pointer"
          />
          </a>
        </div>

        <div class="flex flex-col justify-center p-6 sm:p-10 lg:p-12">
          <a
            href={`/articole?categorie=${encodeURIComponent(featuredArticle.category)}`}
            class="mb-4 inline-flex w-fit text-xs font-semibold tracking-[0.2em] text-cyan-700 transition-colors hover:text-cyan-800 dark:text-cyan-500 dark:hover:text-cyan-300 uppercase"
          >
            {featuredArticle.category}
            </a>
          <a  href={`/articole/${featuredArticle.slug}`}> 
          <h2 class="text-3xl font-semibold tracking-tight text-ink" >
            {featuredArticle.title}
          </h2>
          </a>
          <p class="mt-5 max-w-xl text-base leading-relaxed dark:text-gray-300">
            {featuredArticle.excerpt}
          </p>

          <div class="mt-8 flex flex-wrap items-end gap-4">
            <div>
              <p class="text-base font-semibold text-ink">{featuredArticle.author}</p>
              <p class="text-sm text-muted">Publicat pe {featuredArticle.date}</p>
            </div>
            <a
              href={`/articole/${featuredArticle.slug}`}
              class="rt-btn-ghost ml-auto px-5 py-3 text-base"
            >
              Citește articolul complet
            </a>
          </div>
        </div>
      </div>
    </section>

    <section aria-labelledby="articole-noi" class="pb-8">
      <div class="mb-8 flex flex-wrap items-end justify-between gap-4 border-b border-(--rt-border) dark:border-cyan-700 pb-4">
        <h2 id="articole-noi" class="text-2xl font-semibold tracking-tight text-ink dark:text-gray-200">Toate articolele</h2>
                <div id="active-category-state" class="hidden items-center gap-2 text-sm text-muted">
          <span>Filtru categorie:</span>
          <span id="active-category-label" class="rounded-full bg-surface-2 px-3 py-1 text-xs font-semibold text-ink"></span>
          <a href="/articole" class="text-xs font-semibold text-cyan-700 hover:text-cyan-800 dark:text-cyan-500 dark:hover:text-cyan-300">Resetează</a>
        </div>
      </div>

      <div id="articles-grid" class="grid grid-cols-1 gap-10 md:grid-cols-2">
        {latestArticles.map((article) => (
           <article data-article-card data-article-category={article.category} class="flex gap-6">
            <a href={`/articole/${article.slug}`} class="h-full w-32 shrink-0 overflow-hidden rounded-xl bg-surface-2 sm:w-52 shadow-sm ">
              <img
                src={article.coverImage}
                alt={article.coverAlt}
                loading="lazy"
                decoding="async"
                class="h-full min-h-[190px] w-full bg-surface-2 object-contain object-center"
              />
            </a>

            <div class="flex min-h-[190px] flex-1 flex-col">
              <a href={`/articole?categorie=${encodeURIComponent(article.category)}`} class="mb-2 inline-flex w-fit text-[10px] font-bold tracking-[0.18em] text-cyan-700 transition-colors hover:text-cyan-800 dark:text-cyan-500 dark:hover:text-cyan-300 uppercase">{article.category}</a>
              <h3 class="text-xl leading-tight font-semibold text-ink">
                <a href={`/articole/${article.slug}`} class="hover:underline dark:hover:text-cyan-300">{article.title}</a>
              </h3>
              <p class="mt-3 text-sm leading-relaxed dark:text-gray-300">{article.excerpt}</p>

              <div class="mt-auto pt-4 text-xs text-muted">
                <span class="font-semibold text-ink">{article.author}</span>
                <span aria-hidden="true" class="mx-2">•</span>
                <span>{article.readTime} citire</span>
              </div>
            </div>
          </article>
        ))}
      </div>

      <div class="mt-12 flex justify-center">
        <button
          id="load-more-articles"
          type="button"
          class="rt-btn-primary cursor-pointer px-8 py-3 text-xs font-bold tracking-[0.18em] uppercase"
        >
          Încarcă mai multe articole
        </button>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  const cards = Array.from(document.querySelectorAll("[data-article-card]"));
  const button = document.getElementById("load-more-articles");
  const featuredSection = document.getElementById("featured-article-section");
  const activeCategoryState = document.getElementById("active-category-state");
  const activeCategoryLabel = document.getElementById("active-category-label");
  const categoryChips = Array.from(document.querySelectorAll("[data-category-chip]"));
  const initialVisible = 4;
  const step = 4;
  const selectedCategory = new URLSearchParams(window.location.search).get("categorie");
  const normalizedSelectedCategory = selectedCategory ? selectedCategory.toLocaleLowerCase("ro-RO").trim() : "";

  let visible = initialVisible;

    const filteredCards = normalizedSelectedCategory
    ? cards.filter((card) => {
        const category = card.getAttribute("data-article-category");
        return category?.toLocaleLowerCase("ro-RO").trim() === normalizedSelectedCategory;
      })
    : cards;

  if (activeCategoryState && activeCategoryLabel) {
    const hasFilter = Boolean(selectedCategory);
    activeCategoryState.classList.toggle("hidden", !hasFilter);
    activeCategoryState.classList.toggle("inline-flex", hasFilter);
    activeCategoryLabel.textContent = selectedCategory ?? "";
  }

    categoryChips.forEach((chip) => {
    const category = chip.getAttribute("data-category-value") ?? "";
    const normalizedCategory = category.toLocaleLowerCase("ro-RO").trim();
    const isActive = normalizedSelectedCategory
      ? normalizedCategory === normalizedSelectedCategory
      : normalizedCategory === "";

    chip.classList.toggle("rt-btn-primary", isActive);
    chip.classList.toggle("rt-btn-ghost", !isActive);
  });

  if (featuredSection) {
    const featuredCategory = featuredSection.getAttribute("data-featured-category");
    const showFeatured =
      !normalizedSelectedCategory ||
      featuredCategory?.toLocaleLowerCase("ro-RO").trim() === normalizedSelectedCategory;
    featuredSection.classList.toggle("hidden", !showFeatured);
  }

  const render = () => {
    cards.forEach((card, index) => {
     const inFilteredList = filteredCards.includes(card);
      const filteredIndex = filteredCards.indexOf(card);
      card.classList.toggle("hidden", !inFilteredList || filteredIndex >= visible);
    });

    if (!button) return;

    const hasMore = visible < filteredCards.length;
    button.classList.toggle("hidden", !hasMore);
  };

  if (button) {
    button.addEventListener("click", () => {
      visible = Math.min(visible + step, filteredCards.length);
      render();
    });
  }

  render();
</script>
