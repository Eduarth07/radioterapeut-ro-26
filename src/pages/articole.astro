---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ArticlesIndex from "../components/ArticlesIndex.astro";
import { getAlternateLinks } from "../i18n/paths";
---

<BaseLayout
  title="Articole | Dr. Tatiana Cirimpei - Radioterapie"
  description="Articole medicale despre radioterapie, oncologie și ghiduri utile pentru pacienți."
  locale="ro"
  canonicalPath="/articole"
  alternates={getAlternateLinks("/articole")}
>
  <Header locale="ro" currentPath="/articole" />
  <ArticlesIndex locale="ro" />
  <Footer locale="ro" />
</BaseLayout>