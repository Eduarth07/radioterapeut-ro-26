---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { articles, defaultFeaturedArticleSlug } from "../data/articles";

const categories = Array.from(new Set(articles.map((article) => article.category)));

const featuredArticle =
  articles.find((article) => article.slug === defaultFeaturedArticleSlug) ?? articles[0];

const latestArticles = articles;
---

<BaseLayout
  title="Articole | Dr. Cirimpei Tatiana - Radioterapie"
  description="Articole medicale despre radioterapie, oncologie și ghiduri utile pentru pacienți."
>
  <Header />

  <main class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
    <section class="mb-4 border-b border-(--rt-border) pb-4 md:mb-10 lg:mb-8 dark:border-cyan-700">
      <h1 class="mt-2 text-center text-3xl font-medium tracking-tight text-gray-900 md:text-4xl lg:text-left dark:text-gray-200">
        Articole și informații utile despre radioterapie
      </h1>
      <p class="mt-5 text-base leading-relaxed sm:text-lg dark:text-gray-300">
        Articolele de mai jos sunt gândite să vă ajute să înțelegeți mai bine tratamentul cu radioterapie și să vă susțină pe parcursul acestei etape – indiferent dacă sunteți pacient sau aparținător.
      </p>
    </section>

    <p
      id="featured-article-label"
      class="my-2 text-base leading-relaxed text-gray-600 md:mt-4 md:text-lg dark:text-gray-300"
    >
      Ultimul articol publicat
    </p>

    <section
      id="featured-article-section"
      data-featured-slug={featuredArticle.slug}
      class="mb-8 overflow-hidden rounded-2xl border border-(--rt-border) bg-surface-2 shadow-sm shadow-slate-200/45 md:mb-14 dark:border-cyan-700 dark:bg-black dark:shadow-cyan-900"
    >
      <div class="grid gap-0 md:grid-cols-2">
        <div class="relative min-h-[150px] md:min-h-[420px]">
          <a href={`/articole/${featuredArticle.slug}`}>
            <img
              src={featuredArticle.bigImage ?? featuredArticle.coverImage}
              alt={featuredArticle.coverAlt}
              loading="eager"
              decoding="async"
              class="h-full w-full cursor-pointer object-cover"
            />
          </a>
        </div>

        <div class="flex flex-col justify-center p-4 md:p-6 sm:p-10 lg:p-12">
          <a
            href={`/articole?categorie=${encodeURIComponent(featuredArticle.category)}`}
            class="mb-4 inline-flex w-fit text-xs font-semibold uppercase tracking-[0.2em] text-cyan-700 hover:text-cyan-800 dark:text-cyan-500 dark:hover:text-cyan-300"
          >
            {featuredArticle.category}
          </a>

          <a href={`/articole/${featuredArticle.slug}`}>
            <h2 class="text-2xl font-semibold tracking-tight text-gray-800 md:text-3xl dark:text-gray-300">
              {featuredArticle.title}
            </h2>
          </a>

          <p class="mt-2 max-w-xl text-base leading-relaxed md:mt-5 dark:text-gray-300">
            {featuredArticle.excerpt}
          </p>

          <div class="mt-2 flex flex-wrap items-end gap-6 md:mt-8 md:gap-4">
            <div>
              <p class="text-base font-semibold text-gray-600 dark:text-gray-300">
                {featuredArticle.author}
              </p>
              <p class="text-sm text-muted">Publicat pe {featuredArticle.date}</p>
            </div>

            <a
              href={`/articole/${featuredArticle.slug}`}
              class="btn-secundar px-5 py-3 text-base mx-auto md:ml-auto md:mr-0"
            >
              Citește articolul complet
            </a>
          </div>
        </div>
      </div>
    </section>

    <section aria-labelledby="articole-noi" class="pb-8">
      <div class="mb-8 flex flex-col gap-4 border-b border-(--rt-border) pb-4 md:flex-row md:items-end md:justify-between dark:border-cyan-700">
        <h2 id="articole-noi" class="text-2xl font-semibold tracking-tight text-gray-600 dark:text-gray-300">
          Toate articolele
        </h2>

        <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:gap-3">
          <label for="category-filter" class="text-xs font-medium text-gray-600 dark:text-gray-300">
            Filtrează după categorie:
          </label>

          <div class="relative">
            <select
              id="category-filter"
              class="cursor-pointer appearance-none rounded-sm border border-(--rt-border) bg-surface-2 py-1 pl-2 pr-8 text-xs font-medium text-gray-700 shadow-sm outline-none focus:border-cyan-600 focus:ring-2 focus:ring-cyan-600/20 dark:border-cyan-800 dark:bg-black dark:text-gray-200"
            >
              <option value="">Toate categoriile</option>
              {categories.map((category) => (
                <option value={category}>{category}</option>
              ))}
            </select>

            <svg
              class="pointer-events-none absolute right-3 top-1/2 h-4 w-4 -translate-y-1/2 text-gray-500 dark:text-gray-400"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 20 20"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.51a.75.75 0 01-1.08 0l-4.25-4.51a.75.75 0 01.02-1.06z"
                clip-rule="evenodd"
              />
            </svg>
          </div>

          <a
            href="/articole"
            class="text-xs font-semibold text-cyan-700 hover:text-cyan-800 dark:text-cyan-500 dark:hover:text-cyan-300"
          >
            Resetează
          </a>
        </div>
      </div>

      <div id="articles-grid" class="grid grid-cols-1 gap-10 md:grid-cols-2">
        {latestArticles.map((article) => (
          <article
            data-article-card
            data-article-category={article.category}
            data-article-slug={article.slug}
            class="flex gap-6"
          >
            <a
              href={`/articole/${article.slug}`}
              class="h-47 w-32 shrink-0 overflow-hidden rounded-xl bg-surface-2 shadow-sm sm:w-52"
            >
              <img
                src={article.coverImage}
                alt={article.coverAlt}
                loading="lazy"
                decoding="async"
                class="h-full min-h-[190px] w-full bg-surface-2 object-cover object-center"
              />
            </a>

            <div class="flex min-h-[190px] flex-1 flex-col">
              <a
                href={`/articole?categorie=${encodeURIComponent(article.category)}`}
                class="mb-2 inline-flex w-fit text-[10px] font-bold uppercase tracking-[0.18em] text-cyan-700 hover:text-cyan-800 dark:text-cyan-500 dark:hover:text-cyan-300"
              >
                {article.category}
              </a>

              <h3 class="text-xl leading-tight font-semibold text-gray-800 dark:text-gray-300">
                <a
                  href={`/articole/${article.slug}`}
                  class="hover:underline dark:hover:text-cyan-500 dark:hover:no-underline"
                >
                  {article.title}
                </a>
              </h3>

              <p class="mt-3 text-sm leading-relaxed dark:text-gray-300">
                {article.excerpt}
              </p>

              <div class="mt-auto text-xs text-muted">
                <span class="font-semibold text-gray-600 dark:text-gray-300">{article.date}</span>
                <span aria-hidden="true" class="mx-2">•</span>
                <span>{article.readTime} citire</span>
              </div>
            </div>
          </article>
        ))}
      </div>

      <div class="mt-12 flex justify-center">
        <button
          id="load-more-articles"
          type="button"
          class="btn-primar cursor-pointer px-8 py-3 text-xs font-bold uppercase tracking-[0.18em]"
        >
          Încarcă mai multe articole
        </button>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  const cards = Array.from(document.querySelectorAll("[data-article-card]"));
  const button = document.getElementById("load-more-articles");
  const categoryFilter = document.getElementById("category-filter");
  const featuredSection = document.getElementById("featured-article-section");
  const featuredLabel = document.getElementById("featured-article-label");

  const featuredSlug = featuredSection?.getAttribute("data-featured-slug") ?? "";

  const initialVisible = 4;
  const step = 4;
  let visible = initialVisible;

  const getSelectedCategory = () => {
    const value = new URLSearchParams(window.location.search).get("categorie");
    return value ? value.trim() : "";
  };

  const updateUrl = (category) => {
    const url = new URL(window.location.href);

    if (category) {
      url.searchParams.set("categorie", category);
    } else {
      url.searchParams.delete("categorie");
    }

    window.history.replaceState({}, "", url);
  };

  const getFilteredCards = (category) => {
    const normalizedSelectedCategory = category
      ? category.toLocaleLowerCase("ro-RO").trim()
      : "";

    return cards.filter((card) => {
      const cardCategory = card.getAttribute("data-article-category") ?? "";
      const cardSlug = card.getAttribute("data-article-slug") ?? "";
      const normalizedCardCategory = cardCategory.toLocaleLowerCase("ro-RO").trim();

      if (!normalizedSelectedCategory) {
        return cardSlug !== featuredSlug;
      }

      return normalizedCardCategory === normalizedSelectedCategory;
    });
  };

  const render = () => {
    const selectedCategory = getSelectedCategory();
    const filteredCards = getFilteredCards(selectedCategory);

    cards.forEach((card) => {
      const index = filteredCards.indexOf(card);
      card.classList.toggle("hidden", index === -1 || index >= visible);
    });

    if (button) {
      button.classList.toggle("hidden", visible >= filteredCards.length);
    }

    const hasCategoryFilter = Boolean(selectedCategory);

    if (featuredSection) {
      featuredSection.classList.toggle("hidden", hasCategoryFilter);
    }

    if (featuredLabel) {
      featuredLabel.classList.toggle("hidden", hasCategoryFilter);
    }

    if (categoryFilter instanceof HTMLSelectElement) {
      categoryFilter.value = selectedCategory;
    }
  };

  if (categoryFilter instanceof HTMLSelectElement) {
    categoryFilter.addEventListener("change", () => {
      visible = initialVisible;
      updateUrl(categoryFilter.value);
      render();
    });
  }

  if (button) {
    button.addEventListener("click", () => {
      visible += step;
      render();
    });
  }

  render();
</script>