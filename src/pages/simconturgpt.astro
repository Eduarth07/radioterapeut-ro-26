      grid-template-columns: repeat(8, minmax(0, 1fr));
    }

    .contour-pro__bottom-grid {
      grid-template-columns: 1fr;
    }

    .contour-pro__viewer-stage {
      grid-template-columns: 1fr;
    }
  }
</style>

<script define:vars={{ componentId, initialSlice }}>
  (() => {
    const root = document.querySelector(`[data-contour-pro="${componentId}"]`);
    if (!root) return;

    const viewer = root.querySelector('[data-viewer]');
    const canvas = root.querySelector('[data-image-canvas]');
    const ctx = canvas.getContext('2d');
    const panZoomLayer = root.querySelector('[data-pan-zoom-layer]');
    const gridLayer = root.querySelector('[data-grid-layer]');
    const contoursLayer = root.querySelector('[data-contours-layer]');
    const currentLayer = root.querySelector('[data-current-layer]');
    const previewLayer = root.querySelector('[data-preview-layer]');
    const annotationLayer = root.querySelector('[data-annotation-layer]');

    const roiList = root.querySelector('[data-roi-list]');
    const roiOpacity = root.querySelector('[data-roi-opacity]');
    const roiCount = root.querySelector('[data-roi-count]');

    const sliceRange = root.querySelector('[data-slice-range]');
    const windowRange = root.querySelector('[data-window-range]');
    const levelRange = root.querySelector('[data-level-range]');
    const zoomRange = root.querySelector('[data-zoom-range]');

    const metaWL = root.querySelector('[data-meta-wl]');
    const metaZoom = root.querySelector('[data-meta-zoom]');
    const metaCoords = root.querySelector('[data-meta-coords]');
    const railZoom = root.querySelector('[data-rail-zoom]');
    const hint = root.querySelector('[data-hint]');
    const timeline = root.querySelector('[data-timeline]');
    const timelineCaption = root.querySelector('[data-timeline-caption]');
    const scoutList = root.querySelector('[data-scout-list]');
    const scoutCaption = root.querySelector('[data-scout-caption]');

    const evalBtn = root.querySelector('[data-evaluate]');
    const evalResults = root.querySelector('[data-eval-results]');

    const statRoi = root.querySelector('[data-stat-roi]');
    const statPoints = root.querySelector('[data-stat-points]');
    const statArea = root.querySelector('[data-stat-area]');
    const statCount = root.querySelector('[data-stat-count]');
    const statTotal = root.querySelector('[data-stat-total]');
    const statCursor = root.querySelector('[data-stat-cursor]');

    const toolLabel = root.querySelector('[data-tool-label]');
    const cornerRoi = root.querySelector('[data-corner-roi]');
    const cornerMode = root.querySelector('[data-corner-mode]');
    const sliceLabel = root.querySelector('[data-slice-label]');

    const crossV = root.querySelector('[data-cross-v]');
    const crossH = root.querySelector('[data-cross-h]');

    const prevSliceBtn = root.querySelector('[data-prev-slice]');
    const nextSliceBtn = root.querySelector('[data-next-slice]');
    const playSlicesBtn = root.querySelector('[data-play-slices]');
    const zoomOutBtn = root.querySelector('[data-zoom-out]');
    const fitViewBtn = root.querySelector('[data-fit-view]');
    const zoomInBtn = root.querySelector('[data-zoom-in]');

    const addRoiBtn = root.querySelector('[data-add-roi]');
    const renameRoiBtn = root.querySelector('[data-rename-roi]');
    const closeContourBtn = root.querySelector('[data-close-contour]');
    const undoPointBtn = root.querySelector('[data-undo-point]');
    const clearSliceBtn = root.querySelector('[data-clear-slice]');
    const clonePrevBtn = root.querySelector('[data-clone-prev]');
    const cloneNextBtn = root.querySelector('[data-clone-next]');
    const interpolateBtn = root.querySelector('[data-interpolate]');
    const smoothContourBtn = root.querySelector('[data-smooth-contour]');
    const autoContourBtn = root.querySelector('[data-auto-contour]');
    const resetViewBtn = root.querySelector('[data-reset-view]');
    const saveLocalBtn = root.querySelector('[data-save-local]');
    const exportJsonBtn = root.querySelector('[data-export-json]');
    const presetButtons = Array.from(root.querySelectorAll('[data-wl-preset]'));
    const toolButtons = Array.from(root.querySelectorAll('[data-tool]'));

    const svgNS = 'http://www.w3.org/2000/svg';
    const imageSize = 512;
    const totalSlices = 16;
    const contourTolerance = 14;
    const storageKey = 'contour-sim-pro-demo-v4';
    const palette = ['#22d3ee', '#f97316', '#a78bfa', '#84cc16', '#f43f5e', '#facc15', '#38bdf8'];

    const rois = [
      { id: 'ptv', name: 'PTV', color: '#22d3ee', visible: true, opacity: 0.22 },
      { id: 'gtv', name: 'GTV', color: '#f97316', visible: true, opacity: 0.26 },
      { id: 'cord', name: 'Măduvă', color: '#a78bfa', visible: true, opacity: 0.2 },
      { id: 'body', name: 'Body', color: '#84cc16', visible: false, opacity: 0.12 },
    ];

    const state = {
      slice: Number(initialSlice),
      window: Number(windowRange.value),
      level: Number(levelRange.value),
      zoom: Number(zoomRange.value),
      panX: 0,
      panY: 0,
      tool: 'draw',
      activeRoiId: 'ptv',
      contours: {},
      currentPoints: [],
      hoverPoint: null,
      draggingVertex: null,
      isPanning: false,
      panStart: null,
      isPlaying: false,
      playTimer: null,
    };

    const clamp = (value, min, max) => Math.min(max, Math.max(min, value));
    const distance = (a, b) => Math.hypot(a.x - b.x, a.y - b.y);
    const sliceKey = () => String(state.slice);
    const getActiveRoi = () => rois.find((roi) => roi.id === state.activeRoiId) || rois[0];
    const getSliceContours = () => state.contours[sliceKey()] || [];
    const getContoursForRoiOnSlice = (slice, roiId) => (state.contours[String(slice)] || []).filter((item) => item.roiId === roiId);
    const getFirstContourForRoiOnSlice = (slice, roiId) => getContoursForRoiOnSlice(slice, roiId)[0] || null;
    const escapeHtml = (value) =>
      value
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#039;');

    const polygonArea = (points) => {
      if (!points || points.length < 3) return 0;
      let area = 0;
      for (let i = 0; i < points.length; i += 1) {
        const p1 = points[i];
        const p2 = points[(i + 1) % points.length];
        area += p1.x * p2.y - p2.x * p1.y;
      }
      return Math.abs(area / 2);
    };

    const anatomyForSlice = (slice) => {
      const t = slice / (totalSlices - 1);
      const chestPhase = Math.sin(t * Math.PI);

      const bodyCx = 256;
      const bodyCy = 256;
      const bodyRx = 178 + chestPhase * 10 - Math.abs(0.5 - t) * 30;
      const bodyRy = 216 - Math.abs(0.5 - t) * 76;

      const lungRx = 56 - Math.abs(0.5 - t) * 10;
      const lungRy = 92 - Math.abs(0.5 - t) * 20;
      const lungCy = bodyCy - 10 + chestPhase * 3;

      const lesionFactor = Math.max(0, 1 - Math.abs(slice - 8) / 4.6);

      const ribRows = Array.from({ length: 5 }, (_, i) => {
        const yOffset = -92 + i * 46 + chestPhase * 3;
        const lateral = 118 - Math.abs(yOffset) * 0.12;
        return [
          { cx: bodyCx - lateral, cy: bodyCy + yOffset, rx: 15, ry: 9 },
          { cx: bodyCx + lateral, cy: bodyCy + yOffset, rx: 15, ry: 9 },
        ];
      }).flat();

      return {
        bodyCx,
        bodyCy,
        bodyRx,
        bodyRy,
        lungLeftCx: bodyCx - 67,
        lungRightCx: bodyCx + 61,
        lungCy,
        lungRx,
        lungRy,
        heartCx: bodyCx + 20,
        heartCy: bodyCy + 26,
        heartRx: 50 + chestPhase * 8,
        heartRy: 44 + chestPhase * 6,
        aortaCx: bodyCx + 42,
        aortaCy: bodyCy - 18,
        aortaRx: 13,
        aortaRy: 14,
        tracheaCx: bodyCx - 2,
        tracheaCy: bodyCy - 96,
        tracheaRx: 13,
        tracheaRy: 16,
        sternumCx: bodyCx,
        sternumCy: bodyCy - 100,
        sternumRx: 13,
        sternumRy: 10,
        vertebraCx: bodyCx,
        vertebraCy: bodyCy + 82,
        vertebraRx: 30,
        vertebraRy: 24,
        canalCx: bodyCx,
        canalCy: bodyCy + 82,
        canalRx: 8,
        canalRy: 10,
        lesionCx: bodyCx + 82 - (0.5 - t) * 16,
        lesionCy: bodyCy - 4 + chestPhase * 9,
        lesionRx: 19 + lesionFactor * 9,
        lesionRy: 16 + lesionFactor * 7,
        lesionFactor,
        ribRows,
      };
    };

    const huAtPoint = (x, y, slice) => {
      const a = anatomyForSlice(slice);

      const baseNoise =
        (Math.sin(x * 0.11) +
          Math.sin(y * 0.09) +
          Math.sin((x + y) * 0.05) +
          Math.sin(x * 0.32) * Math.cos(y * 0.28) * 0.7) * 10;

      const microTexture =
        (Math.sin(x * 0.8 + y * 0.15) +
          Math.cos(y * 0.75 - x * 0.18) +
          Math.sin((x - y) * 0.42)) * 2.4;

      const softNoise = baseNoise + microTexture;

      const bodyDist = (((x - a.bodyCx) / a.bodyRx) ** 2) + (((y - a.bodyCy) / a.bodyRy) ** 2);
      const bodyNorm = Math.sqrt(bodyDist);

      const lungL = (((x - a.lungLeftCx) / a.lungRx) ** 2) + (((y - a.lungCy) / a.lungRy) ** 2);
      const lungR = (((x - a.lungRightCx) / a.lungRx) ** 2) + (((y - a.lungCy) / a.lungRy) ** 2);
      const heart = (((x - a.heartCx) / a.heartRx) ** 2) + (((y - a.heartCy) / a.heartRy) ** 2);
      const aorta = (((x - a.aortaCx) / a.aortaRx) ** 2) + (((y - a.aortaCy) / a.aortaRy) ** 2);
      const trachea = (((x - a.tracheaCx) / a.tracheaRx) ** 2) + (((y - a.tracheaCy) / a.tracheaRy) ** 2);

      const sternumVal = (((x - a.sternumCx) / a.sternumRx) ** 2) + (((y - a.sternumCy) / a.sternumRy) ** 2);
      const sternumDist = Math.sqrt(sternumVal);

      const dxV = x - a.vertebraCx;
      const dyV = y - a.vertebraCy;
      const vertebraDist = Math.sqrt((dxV / a.vertebraRx) ** 2 + (dyV / a.vertebraRy) ** 2);
      const canal = (((x - a.canalCx) / a.canalRx) ** 2) + (((y - a.canalCy) / a.canalRy) ** 2);

      const dxL = x - a.lesionCx;
      const dyL = y - a.lesionCy;
      const angleL = Math.atan2(dyL, dxL);
      const lesionWobble = 1 + 0.18 * Math.sin(angleL * 6) + 0.08 * Math.sin(angleL * 11 + 0.7);
      const lesionDist = Math.sqrt((dxL / a.lesionRx) ** 2 + (dyL / a.lesionRy) ** 2) / lesionWobble;

      let hu = -1000 + softNoise * 0.18;

      if (bodyDist <= 1) {
        hu = 38 + softNoise * 0.35;

        if (bodyNorm > 0.93) {
          hu = -95 + softNoise * 0.28;
        } else if (bodyNorm > 0.84) {
          hu = 14 + softNoise * 0.32;
        }
      }

      if (lungL <= 1 || lungR <= 1) {
        hu = -790 + softNoise * 0.55;

        const vesselField =
          Math.sin(x * 0.22) * Math.cos(y * 0.17) +
          Math.sin((x + y) * 0.12) +
          Math.cos((x - y) * 0.09);

        if (vesselField > 1.55) hu = -40 + softNoise * 0.28;
        if (vesselField > 2.05) hu = 28 + softNoise * 0.22;

        const pleuraBand =
          Math.min(Math.abs(Math.sqrt(lungL) - 1), Math.abs(Math.sqrt(lungR) - 1));

        if (pleuraBand < 0.045) hu = Math.max(hu, -620 + softNoise * 0.18);
      }

      if (heart <= 1) hu = 55 + softNoise * 0.26;
      if (aorta <= 1) hu = 72 + softNoise * 0.22;
      if (trachea <= 1) hu = -970 + softNoise * 0.12;

      if (vertebraDist <= 1) {
        hu = vertebraDist > 0.72 ? 620 + softNoise * 0.45 : 165 + softNoise * 0.22;
      }

      if (canal <= 1) hu = 24 + softNoise * 0.12;

      if (sternumVal <= 1) {
        hu = sternumDist > 0.68 ? 610 + softNoise * 0.42 : 175 + softNoise * 0.22;
      }

      for (const rib of a.ribRows) {
        const ribDist = Math.sqrt(((x - rib.cx) / rib.rx) ** 2 + ((y - rib.cy) / rib.ry) ** 2);
        if (ribDist <= 1) {
          hu = ribDist > 0.7 ? 640 + softNoise * 0.45 : 170 + softNoise * 0.2;
          break;
        }
      }

      if (lesionDist <= 1 && a.lesionFactor > 0.05) {
        if (lesionDist < 0.32) hu = 24 + softNoise * 0.12;
        else if (lesionDist < 0.82) hu = 84 + a.lesionFactor * 24 + softNoise * 0.18;
        else hu = 98 + a.lesionFactor * 28 + softNoise * 0.15;
      } else if (lesionDist <= 1.16 && a.lesionFactor > 0.05 && (lungL <= 1 || lungR <= 1)) {
        hu = Math.max(hu, -660 + softNoise * 0.15);
      }

      if (bodyDist > 1) hu = -1000 + softNoise * 0.16;

      return hu;
    };

    const windowToGray = (hu) => {
      const lower = state.level - state.window / 2;
      const normalized = clamp((hu - lower) / state.window, 0, 1);
      return Math.round(normalized * 255);
    };

    const drawSlice = () => {
      const imageData = ctx.createImageData(imageSize, imageSize);
      const px = imageData.data;

      for (let y = 0; y < imageSize; y += 1) {
        for (let x = 0; x < imageSize; x += 1) {
          const hu = huAtPoint(x, y, state.slice);
          const gray = windowToGray(hu);
          const idx = (y * imageSize + x) * 4;
          px[idx] = gray;
          px[idx + 1] = gray;
          px[idx + 2] = gray;
          px[idx + 3] = 255;
        }
      }

      ctx.putImageData(imageData, 0, 0);
      ctx.strokeStyle = 'rgba(255,255,255,0.04)';
      ctx.lineWidth = 1;
      ctx.strokeRect(10.5, 10.5, imageSize - 21, imageSize - 21);
    };

    const createSvg = (tag, attrs = {}) => {
      const el = document.createElementNS(svgNS, tag);
      Object.entries(attrs).forEach(([key, value]) => el.setAttribute(key, String(value)));
      return el;
    };

    const clearNode = (node) => {
      while (node.firstChild) node.removeChild(node.firstChild);
    };

    const clampPan = () => {
      const minPan = imageSize - imageSize * state.zoom;
      state.panX = clamp(state.panX, minPan, 0);
      state.panY = clamp(state.panY, minPan, 0);
    };

    const setPanZoomTransform = () => {
      clampPan();
      const rect = viewer.getBoundingClientRect();
      const ratio = rect.width / imageSize;
      canvas.style.transformOrigin = 'top left';
      canvas.style.transform = `matrix(${state.zoom}, 0, 0, ${state.zoom}, ${state.panX * ratio}, ${state.panY * ratio})`;
      panZoomLayer.setAttribute('transform', `matrix(${state.zoom} 0 0 ${state.zoom} ${state.panX} ${state.panY})`);
      metaZoom.textContent = `Zoom ${state.zoom.toFixed(2)}x`;
      railZoom.textContent = `${state.zoom.toFixed(2)}x`;
    };

    const fitView = () => {
      state.zoom = 1;
      state.panX = 0;
      state.panY = 0;
      zoomRange.value = '1';
      setPanZoomTransform();
      updateMetaAndStats();
      renderContours();
    };

    const setZoom = (nextZoom, anchorX = imageSize / 2, anchorY = imageSize / 2) => {
      const clampedZoom = clamp(nextZoom, 1, 4.5);
      const oldZoom = state.zoom;
      if (clampedZoom === oldZoom) return;
      state.panX = anchorX - ((anchorX - state.panX) / oldZoom) * clampedZoom;
      state.panY = anchorY - ((anchorY - state.panY) / oldZoom) * clampedZoom;
      state.zoom = clampedZoom;
      zoomRange.value = clampedZoom.toFixed(2);
      setPanZoomTransform();
      renderContours();
      updateMetaAndStats();
      autoSave();
    };

    const makePolygonPoints = (points) => points.map((p) => `${p.x},${p.y}`).join(' ');

    const renderGrid = () => {
      clearNode(gridLayer);
      for (let i = 64; i < imageSize; i += 64) {
        gridLayer.append(
          createSvg('line', { x1: i, y1: 0, x2: i, y2: imageSize, stroke: 'rgba(255,255,255,0.045)', 'stroke-width': 1 }),
          createSvg('line', { x1: 0, y1: i, x2: imageSize, y2: i, stroke: 'rgba(255,255,255,0.045)', 'stroke-width': 1 }),
        );
      }
    };

    const renderAnnotations = () => {
      clearNode(annotationLayer);
    };

    const renderContours = () => {
      clearNode(contoursLayer);
      clearNode(currentLayer);
      clearNode(previewLayer);
      renderAnnotations();

      const z = state.zoom;
      const strokeW = 2 / z;
      const activeStrokeW = 2.6 / z;
      const ptRadius = 4.6 / z;
      const ptRadiusActive = 5.8 / z;
      const editRadius = 5 / z;
      const editRadiusHover = 6.5 / z;

      const sliceContours = getSliceContours();
      sliceContours.forEach((contour, contourIndex) => {
        const roi = rois.find((item) => item.id === contour.roiId);
        if (!roi || !roi.visible) return;

        const polygon = createSvg('polygon', {
          points: makePolygonPoints(contour.points),
          fill: roi.color,
          'fill-opacity': roi.opacity,
          stroke: roi.color,
          'stroke-width': contour.roiId === state.activeRoiId ? activeStrokeW : strokeW,
          'stroke-linejoin': 'round',
        });
        contoursLayer.appendChild(polygon);

        if (contour.roiId === state.activeRoiId && state.tool === 'edit') {
          contour.points.forEach((point, pointIndex) => {
            const isDragging =
              state.draggingVertex &&
              state.draggingVertex.contourIndex === contourIndex &&
              state.draggingVertex.pointIndex === pointIndex;

            currentLayer.appendChild(
              createSvg('circle', {
                cx: point.x,
                cy: point.y,
                r: isDragging ? editRadiusHover : editRadius,
                fill: roi.color,
                stroke: '#ffffff',
                'stroke-width': 1.5 / z,
              }),
            );
          });
        }
      });

      if (state.currentPoints.length > 0) {
        const activeRoi = getActiveRoi();
        if (state.currentPoints.length > 1) {
          currentLayer.appendChild(
            createSvg('polyline', {
              points: makePolygonPoints(state.currentPoints),
              fill: 'none',
              stroke: activeRoi.color,
              'stroke-width': activeStrokeW,
              'stroke-linejoin': 'round',
            }),
          );
        }

        state.currentPoints.forEach((point, index) => {
          currentLayer.appendChild(
            createSvg('circle', {
              cx: point.x,
              cy: point.y,
              r: index === 0 ? ptRadiusActive : ptRadius,
              fill: index === 0 ? '#ffffff' : activeRoi.color,
              stroke: activeRoi.color,
              'stroke-width': 1.5 / z,
            }),
          );
        });
      }

      if (state.hoverPoint && state.tool === 'draw' && state.currentPoints.length > 0) {
        const activeRoi = getActiveRoi();
        const last = state.currentPoints[state.currentPoints.length - 1];
        previewLayer.appendChild(
          createSvg('line', {
            x1: last.x,
            y1: last.y,
            x2: state.hoverPoint.x,
            y2: state.hoverPoint.y,
            stroke: activeRoi.color,
            'stroke-width': 1.8 / z,
            'stroke-dasharray': `${7 / z} ${7 / z}`,
          }),
        );
      }
    };

    const updateMetaAndStats = () => {
      const activeRoi = getActiveRoi();
      const contoursOnSlice = getContoursForRoiOnSlice(state.slice, activeRoi.id);
      const lastContour = contoursOnSlice[contoursOnSlice.length - 1];
      const totalContours = Object.values(state.contours).flat().filter((item) => item.roiId === activeRoi.id).length;

      roiOpacity.value = String(activeRoi.opacity);
      sliceLabel.textContent = `Slice ${state.slice} / ${totalSlices - 1}`;
      metaWL.textContent = `W ${state.window} / L ${state.level}`;
      timelineCaption.textContent = `Active ROI: ${activeRoi.name}`;
      scoutCaption.textContent = `${activeRoi.name} overview`;
      toolLabel.textContent = state.tool === 'draw' ? 'Draw' : state.tool === 'edit' ? 'Edit' : 'Pan';
      cornerRoi.textContent = activeRoi.name;
      cornerMode.textContent = state.tool === 'draw' ? 'Draw mode' : state.tool === 'edit' ? 'Edit mode' : 'Pan mode';

      statRoi.textContent = activeRoi.name;
      statPoints.textContent = String(state.currentPoints.length);
      statArea.textContent = `${Math.round(lastContour ? polygonArea(lastContour.points) : 0)} px²`;
      statCount.textContent = String(contoursOnSlice.length);
      statTotal.textContent = String(totalContours);
      roiCount.textContent = `${rois.filter((roi) => roi.visible).length} vizibile`;

      playSlicesBtn.textContent = state.isPlaying ? 'Stop' : 'Play';
      playSlicesBtn.classList.toggle('is-active', state.isPlaying);

      evalResults.innerHTML =
        '<p class="contour-pro__hint">Press to analyze accuracy, coverage and point density on the current slice compared with the AI reference.</p>';
    };

    const renderHint = () => {
      const map = {
        draw: 'Click to add points. Click near the first point to close the contour. Ctrl + wheel = zoom.',
        edit: 'Drag existing vertices for the active ROI. Smooth afterwards if needed.',
        pan: 'Hold click and drag to move the view.',
      };
      hint.textContent = map[state.tool];
      viewer.classList.toggle('is-pan', state.tool === 'pan');
      viewer.classList.toggle('is-dragging', state.isPanning);
    };

    const renderRoiList = () => {
      roiList.innerHTML = rois
        .map((roi) => {
          const count = Object.values(state.contours).flat().filter((item) => item.roiId === roi.id).length;
          return `
          <div class="contour-pro__roi-item ${roi.id === state.activeRoiId ? 'is-active' : ''}" data-roi-id="${escapeHtml(roi.id)}">
            <div class="contour-pro__roi-main">
              <span class="contour-pro__roi-dot" style="background:${escapeHtml(roi.color)}"></span>
              <span>
                <span class="contour-pro__roi-name">${escapeHtml(roi.name)}</span><br />
                <span class="contour-pro__roi-meta">${count} contururi salvate</span>
              </span>
            </div>
            <div class="contour-pro__roi-actions-side">
              <button type="button" class="contour-pro__eye-btn" data-toggle-visible="${escapeHtml(roi.id)}">${roi.visible ? '◉' : '○'}</button>
            </div>
          </div>
        `;
        })
        .join('');

      Array.from(roiList.querySelectorAll('[data-roi-id]')).forEach((row) => {
        row.addEventListener('click', () => {
          state.activeRoiId = row.getAttribute('data-roi-id');
          state.currentPoints = [];
          renderAll();
        });
      });

      Array.from(roiList.querySelectorAll('[data-toggle-visible]')).forEach((btn) => {
        btn.addEventListener('click', (event) => {
          event.stopPropagation();
          const roi = rois.find((item) => item.id === btn.getAttribute('data-toggle-visible'));
          if (!roi) return;
          roi.visible = !roi.visible;
          renderAll();
        });
      });
    };

    const renderTimeline = () => {
      timeline.innerHTML = '';
      for (let slice = 0; slice < totalSlices; slice += 1) {
        const contours = getContoursForRoiOnSlice(slice, state.activeRoiId);
        const hasData = contours.length > 0;
        const button = document.createElement('button');
        button.type = 'button';
        button.className = `contour-pro__slice-chip ${slice === state.slice ? 'is-current' : ''} ${hasData ? 'has-data' : ''}`;
        button.innerHTML = `<strong>${slice}</strong><br /><span>${hasData ? contours.length : '—'}</span>`;
        button.addEventListener('click', () => {
          state.slice = slice;
          state.currentPoints = [];
          sliceRange.value = String(slice);
          renderAll();
        });
        timeline.appendChild(button);
      }
    };

    const renderScout = () => {
      scoutList.innerHTML = '';
      const areas = Array.from({ length: totalSlices }, (_, slice) => {
        const contour = getFirstContourForRoiOnSlice(slice, state.activeRoiId);
        return contour ? polygonArea(contour.points) : 0;
      });
      const maxArea = Math.max(...areas, 1);

      for (let slice = 0; slice < totalSlices; slice += 1) {
        const contourCount = getContoursForRoiOnSlice(slice, state.activeRoiId).length;
        const widthPct = Math.round((areas[slice] / maxArea) * 100);
        const button = document.createElement('button');
        button.type = 'button';
        button.className = `contour-pro__scout-item ${slice === state.slice ? 'is-current' : ''}`;
        button.innerHTML = `
          <span class="contour-pro__scout-index">${slice}</span>
          <span class="contour-pro__scout-bar"><span style="width:${widthPct}%"></span></span>
          <span>${contourCount}</span>
        `;
        button.addEventListener('click', () => {
          state.slice = slice;
          state.currentPoints = [];
          sliceRange.value = String(slice);
          renderAll();
        });
        scoutList.appendChild(button);
      }
    };

    const renderAll = () => {
      drawSlice();
      renderGrid();
      renderContours();
      renderRoiList();
      renderTimeline();
      renderScout();
      updateMetaAndStats();
      renderHint();
      setPanZoomTransform();
      autoSave();
    };

    const clientToImagePoint = (clientX, clientY) => {
      const rect = viewer.getBoundingClientRect();
      const xView = ((clientX - rect.left) / rect.width) * imageSize;
      const yView = ((clientY - rect.top) / rect.height) * imageSize;
      return {
        x: clamp((xView - state.panX) / state.zoom, 0, imageSize),
        y: clamp((yView - state.panY) / state.zoom, 0, imageSize),
      };
    };

    const setCrosshair = (clientX, clientY, imagePoint) => {
      const rect = viewer.getBoundingClientRect();
      const leftPct = ((clientX - rect.left) / rect.width) * 100;
      const topPct = ((clientY - rect.top) / rect.height) * 100;
      crossV.hidden = false;
      crossH.hidden = false;
      crossV.style.left = `${leftPct}%`;
      crossH.style.top = `${topPct}%`;
      const hu = Math.round(huAtPoint(imagePoint.x, imagePoint.y, state.slice));
      metaCoords.textContent = `X ${Math.round(imagePoint.x)} | Y ${Math.round(imagePoint.y)} | HU ${hu}`;
      statCursor.textContent = `${Math.round(imagePoint.x)}, ${Math.round(imagePoint.y)} | ${hu} HU`;
    };

    const clearCrosshair = () => {
      crossV.hidden = true;
      crossH.hidden = true;
      metaCoords.textContent = 'X 0 | Y 0 | HU 0';
      statCursor.textContent = '—';
    };

    const commitCurrentContour = () => {
      if (state.currentPoints.length < 3) return;
      const key = sliceKey();
      state.contours[key] = state.contours[key] || [];
      state.contours[key].push({
        roiId: state.activeRoiId,
        points: state.currentPoints.map((point) => ({ ...point })),
      });
      state.currentPoints = [];
      renderAll();
    };

    const handleDrawClick = (point) => {
      const dynamicTol = contourTolerance / state.zoom;
      if (state.currentPoints.length >= 3 && distance(point, state.currentPoints[0]) < dynamicTol) {
        commitCurrentContour();
        return;
      }
      state.currentPoints.push(point);
      renderContours();
      updateMetaAndStats();
      autoSave();
    };

    const findVertexAtPoint = (point) => {
      const contours = getSliceContours();
      const dynamicTol = 10 / state.zoom;
      for (let contourIndex = 0; contourIndex < contours.length; contourIndex += 1) {
        const contour = contours[contourIndex];
        if (contour.roiId !== state.activeRoiId) continue;
        for (let pointIndex = 0; pointIndex < contour.points.length; pointIndex += 1) {
          if (distance(point, contour.points[pointIndex]) <= dynamicTol) return { contourIndex, pointIndex };
        }
      }
      return null;
    };

    const runEvaluation = () => {
      const contour = getFirstContourForRoiOnSlice(state.slice, state.activeRoiId);
      if (!contour || contour.points.length < 3) {
        evalResults.innerHTML = '<span style="color:var(--danger)">Error: There is no closed contour on this slice.</span>';
        return;
      }

      const a = anatomyForSlice(state.slice);
      let target = null;
      let targetName = '';

      if (state.activeRoiId === 'ptv' || state.activeRoiId === 'gtv') {
        target = { cx: a.lesionCx, cy: a.lesionCy, rx: a.lesionRx, ry: a.lesionRy };
        targetName = 'Target lesion';
      } else if (state.activeRoiId === 'body') {
        target = { cx: a.bodyCx, cy: a.bodyCy, rx: a.bodyRx, ry: a.bodyRy };
        targetName = 'External body contour';
      } else if (state.activeRoiId === 'cord') {
        target = { cx: a.canalCx, cy: a.canalCy, rx: a.canalRx, ry: a.canalRy };
        targetName = 'Spinal canal';
      }

      if (!target || (target.rx <= 0) || (a.lesionFactor <= 0.05 && (state.activeRoiId === 'ptv' || state.activeRoiId === 'gtv'))) {
        evalResults.innerHTML = '<span style="color:var(--warning)">The selected structure is not evaluable on this slice.</span>';
        return;
      }

      let cx = 0;
      let cy = 0;
      contour.points.forEach((p) => {
        cx += p.x;
        cy += p.y;
      });
      cx /= contour.points.length;
      cy /= contour.points.length;

      const dist = Math.hypot(cx - target.cx, cy - target.cy);
      const centerScore = Math.max(0, 100 - (dist / (target.rx * 0.5)) * 100);

      const userArea = polygonArea(contour.points);
      const trueArea = Math.PI * target.rx * target.ry;
      const areaScore = Math.max(0, 100 - (Math.abs(userArea - trueArea) / trueArea) * 100);

      const n = contour.points.length;
      let nodeScore = 100;
      if (n < 8) nodeScore -= 40;
      else if (n < 12) nodeScore -= 15;
      else if (n > 80) nodeScore -= 20;
      nodeScore = Math.max(0, nodeScore);

      const finalScore = Math.round((centerScore * 0.4) + (areaScore * 0.45) + (nodeScore * 0.15));
      const colorClass = finalScore >= 90 ? 'var(--success)' : finalScore >= 75 ? 'var(--warning)' : 'var(--danger)';

      evalResults.innerHTML = `
        <div class="contour-pro__eval-score" style="color: ${colorClass}">${finalScore}%</div>
        <div class="contour-pro__eval-details">
          <div><span>Reference target:</span> ${targetName}</div>
          <div><span>Area accuracy:</span> ${Math.round(areaScore)}%</div>
          <div><span>Centering:</span> ${Math.round(centerScore)}%</div>
          <div><span>Node precision (${n}):</span> ${Math.round(nodeScore)}%</div>
        </div>
      `;
    };

    evalBtn.addEventListener('click', runEvaluation);

    const resamplePolygon = (points, samples = 64) => {
      const closed = [...points, points[0]];
      const lengths = [];
      let perimeter = 0;

      for (let i = 0; i < closed.length - 1; i += 1) {
        const seg = distance(closed[i], closed[i + 1]);
        lengths.push(seg);
        perimeter += seg;
      }

      const step = perimeter / samples;
      const result = [];
      let segIndex = 0;
      let segAccum = 0;

      for (let s = 0; s < samples; s += 1) {
        const target = s * step;
        while (segIndex < lengths.length - 1 && segAccum + lengths[segIndex] < target) {
          segAccum += lengths[segIndex];
          segIndex += 1;
        }
        const p1 = closed[segIndex];
        const p2 = closed[segIndex + 1];
        const local = lengths[segIndex] === 0 ? 0 : (target - segAccum) / lengths[segIndex];
        result.push({
          x: p1.x + (p2.x - p1.x) * local,
          y: p1.y + (p2.y - p1.y) * local,
        });
      }
      return result;
    };

    const smoothPoints = (points) =>
      points.map((point, index) => {
        const prev = points[(index - 1 + points.length) % points.length];
        const next = points[(index + 1) % points.length];
        return {
          x: (prev.x + point.x * 2 + next.x) / 4,
          y: (prev.y + point.y * 2 + next.y) / 4,
        };
      });

    const replaceActiveRoiContoursOnCurrentSlice = (newContour) => {
      const key = sliceKey();
      state.contours[key] = (state.contours[key] || []).filter((item) => item.roiId !== state.activeRoiId);
      if (newContour) {
        state.contours[key].push({
          roiId: state.activeRoiId,
          points: newContour.map((p) => ({ ...p })),
        });
      }
    };

    const interpolateCurrentSlice = () => {
      let prevSlice = null;
      let nextSlice = null;

      for (let i = state.slice - 1; i >= 0; i -= 1) {
        if (getFirstContourForRoiOnSlice(i, state.activeRoiId)) {
          prevSlice = i;
          break;
        }
      }

      for (let i = state.slice + 1; i < totalSlices; i += 1) {
        if (getFirstContourForRoiOnSlice(i, state.activeRoiId)) {
          nextSlice = i;
          break;
        }
      }

      if (prevSlice === null || nextSlice === null || prevSlice === nextSlice) return;

      const prevContour = getFirstContourForRoiOnSlice(prevSlice, state.activeRoiId);
      const nextContour = getFirstContourForRoiOnSlice(nextSlice, state.activeRoiId);
      if (!prevContour || !nextContour) return;

      const a = resamplePolygon(prevContour.points, 64);
      const b = resamplePolygon(nextContour.points, 64);
      const t = (state.slice - prevSlice) / (nextSlice - prevSlice);
      const interpolated = a.map((p, idx) => ({
        x: p.x + (b[idx].x - p.x) * t,
        y: p.y + (b[idx].y - p.y) * t,
      }));

      replaceActiveRoiContoursOnCurrentSlice(interpolated);
      renderAll();
    };

    const cloneContourToSlice = (targetSlice) => {
      const current = getFirstContourForRoiOnSlice(state.slice, state.activeRoiId);
      if (!current || targetSlice < 0 || targetSlice > totalSlices - 1) return;
      const key = String(targetSlice);
      state.contours[key] = (state.contours[key] || []).filter((item) => item.roiId !== state.activeRoiId);
      state.contours[key].push({
        roiId: state.activeRoiId,
        points: current.points.map((p) => ({ ...p })),
      });
      state.slice = targetSlice;
      sliceRange.value = String(state.slice);
      renderAll();
    };

    const smoothActiveContour = () => {
      const contour = getFirstContourForRoiOnSlice(state.slice, state.activeRoiId);
      if (!contour) return;
      contour.points = smoothPoints(contour.points);
      renderAll();
    };

    const autoContourDemo = () => {
      const a = anatomyForSlice(state.slice);
      if (a.lesionFactor <= 0.05) return;
      const points = [];
      const n = 24;
      for (let i = 0; i < n; i += 1) {
        const angle = (Math.PI * 2 * i) / n;
        const rWobble = 1 + 0.15 * Math.sin(angle * 7) + 0.1 * Math.sin(angle * 13);
        points.push({
          x: a.lesionCx + Math.cos(angle) * a.lesionRx * rWobble,
          y: a.lesionCy + Math.sin(angle) * a.lesionRy * rWobble,
        });
      }
      replaceActiveRoiContoursOnCurrentSlice(points);
      renderAll();
    };

    const autoSave = () => {
      try {
        localStorage.setItem(storageKey, JSON.stringify({ rois, contours: state.contours }));
      } catch {}
    };

    const loadLocal = () => {
      try {
        const raw = localStorage.getItem(storageKey);
        if (!raw) return;
        const parsed = JSON.parse(raw);

        if (Array.isArray(parsed.rois)) {
          parsed.rois.forEach((saved) => {
            const match = rois.find((roi) => roi.id === saved.id);
            if (match) {
              match.name = saved.name ?? match.name;
              match.color = saved.color ?? match.color;
              match.visible = saved.visible ?? match.visible;
              match.opacity = saved.opacity ?? match.opacity;
            }
          });
        }

        if (parsed.contours && typeof parsed.contours === 'object') {
          state.contours = parsed.contours;
        }
      } catch {}
    };

    const exportJson = () => {
      const payload = {
        study: 'Demo Patient / CT Thorax',
        sliceCount: totalSlices,
        activeRoi: getActiveRoi().name,
        rois,
        contours: state.contours,
      };
      const blob = new Blob([JSON.stringify(payload, null, 2)], { type: 'application/json' });
      const url = URL.createObjectURL(blob);
      const link = document.createElement('a');
      link.href = url;
      link.download = 'contour-demo-export.json';
      document.body.appendChild(link);
      link.click();
      link.remove();
      URL.revokeObjectURL(url);
    };

    const setPreset = (name) => {
      const presets = {
        lung: { window: 1500, level: -550 },
        mediastin: { window: 400, level: 40 },
        osos: { window: 1800, level: 350 },
      };
      const preset = presets[name];
      if (!preset) return;
      state.window = preset.window;
      state.level = preset.level;
      windowRange.value = String(preset.window);
      levelRange.value = String(preset.level);
      renderAll();
    };

    const stopPlayback = () => {
      if (state.playTimer) window.clearInterval(state.playTimer);
      state.playTimer = null;
      state.isPlaying = false;
      updateMetaAndStats();
    };

    const startPlayback = () => {
      stopPlayback();
      state.isPlaying = true;
      state.playTimer = window.setInterval(() => {
        state.slice = state.slice >= totalSlices - 1 ? 0 : state.slice + 1;
        sliceRange.value = String(state.slice);
        state.currentPoints = [];
        renderAll();
      }, 500);
      updateMetaAndStats();
    };

    const togglePlayback = () => {
      if (state.isPlaying) stopPlayback();
      else startPlayback();
    };

    const onPointerDown = (event) => {
      const point = clientToImagePoint(event.clientX, event.clientY);

      if (state.tool === 'pan') {
        state.isPanning = true;
        state.panStart = {
          clientX: event.clientX,
          clientY: event.clientY,
          panX: state.panX,
          panY: state.panY,
        };
        renderHint();
        return;
      }

      if (state.tool === 'edit') {
        const hit = findVertexAtPoint(point);
        if (hit) {
          state.draggingVertex = hit;
          renderContours();
        }
        return;
      }

      if (state.tool === 'draw') handleDrawClick(point);
    };

    const onPointerMove = (event) => {
      const point = clientToImagePoint(event.clientX, event.clientY);
      state.hoverPoint = point;
      setCrosshair(event.clientX, event.clientY, point);

      if (state.tool === 'pan' && state.isPanning && state.panStart) {
        const rect = viewer.getBoundingClientRect();
        state.panX = state.panStart.panX + (((event.clientX - state.panStart.clientX) / rect.width) * imageSize);
        state.panY = state.panStart.panY + (((event.clientY - state.panStart.clientY) / rect.height) * imageSize);
        setPanZoomTransform();
        renderHint();
        return;
      }

      if (state.tool === 'edit' && state.draggingVertex) {
        const contours = getSliceContours();
        const contour = contours[state.draggingVertex.contourIndex];
        if (contour) {
          contour.points[state.draggingVertex.pointIndex] = point;
          renderContours();
          updateMetaAndStats();
          renderTimeline();
          renderScout();
          autoSave();
        }
        return;
      }

      renderContours();
    };

    const onPointerUp = () => {
      state.draggingVertex = null;
      state.isPanning = false;
      state.panStart = null;
      renderAll();
    };

    viewer.addEventListener('pointerdown', onPointerDown);

    viewer.addEventListener(
      'wheel',
      (event) => {
        event.preventDefault();

        if (event.ctrlKey || event.metaKey || event.shiftKey) {
          const rect = viewer.getBoundingClientRect();
          const anchorX = ((event.clientX - rect.left) / rect.width) * imageSize;
          const anchorY = ((event.clientY - rect.top) / rect.height) * imageSize;
          const delta = event.deltaY < 0 ? 0.12 : -0.12;
          setZoom(state.zoom + delta, anchorX, anchorY);
        } else {
          if (event.deltaY > 0) state.slice = clamp(state.slice - 1, 0, totalSlices - 1);
          else state.slice = clamp(state.slice + 1, 0, totalSlices - 1);

          sliceRange.value = String(state.slice);
          state.currentPoints = [];
          renderAll();
        }
      },
      { passive: false },
    );

    window.addEventListener('pointermove', onPointerMove);
    window.addEventListener('pointerup', onPointerUp);
    window.addEventListener('pointercancel', onPointerUp);

    viewer.addEventListener('mouseleave', () => {
      state.hoverPoint = null;
      clearCrosshair();
      renderContours();
    });

    sliceRange.addEventListener('input', () => {
      state.slice = Number(sliceRange.value);
      state.currentPoints = [];
      renderAll();
    });

    windowRange.addEventListener('input', () => {
      state.window = Number(windowRange.value);
      renderAll();
    });

    levelRange.addEventListener('input', () => {
      state.level = Number(levelRange.value);
      renderAll();
    });

    zoomRange.addEventListener('input', () => setZoom(Number(zoomRange.value)));

    roiOpacity.addEventListener('input', () => {
      const active = getActiveRoi();
      active.opacity = Number(roiOpacity.value);
      renderContours();
      renderRoiList();
      autoSave();
    });

    prevSliceBtn.addEventListener('click', () => {
      state.slice = clamp(state.slice - 1, 0, totalSlices - 1);
      sliceRange.value = String(state.slice);
      state.currentPoints = [];
      renderAll();
    });

    nextSliceBtn.addEventListener('click', () => {
      state.slice = clamp(state.slice + 1, 0, totalSlices - 1);
      sliceRange.value = String(state.slice);
      state.currentPoints = [];
      renderAll();
    });

    playSlicesBtn.addEventListener('click', togglePlayback);

    zoomOutBtn.addEventListener('click', () => setZoom(state.zoom - 0.1));
    zoomInBtn.addEventListener('click', () => setZoom(state.zoom + 0.1));
    fitViewBtn.addEventListener('click', fitView);

    addRoiBtn.addEventListener('click', () => {
      const name = window.prompt('Numele noii structuri:', `ROI ${rois.length + 1}`);
      if (!name) return;
      const id = `roi-${Date.now().toString(36)}`;
      rois.push({
        id,
        name: name.trim(),
        color: palette[rois.length % palette.length],
        visible: true,
        opacity: 0.22,
      });
      state.activeRoiId = id;
      state.currentPoints = [];
      renderAll();
    });

    renameRoiBtn.addEventListener('click', () => {
      const active = getActiveRoi();
      const name = window.prompt('Nume nou pentru ROI:', active.name);
      if (!name) return;
      active.name = name.trim();
      renderAll();
    });

    closeContourBtn.addEventListener('click', commitCurrentContour);

    undoPointBtn.addEventListener('click', () => {
      state.currentPoints.pop();
      renderContours();
      updateMetaAndStats();
      autoSave();
    });

    clearSliceBtn.addEventListener('click', () => {
      const key = sliceKey();
      state.contours[key] = (state.contours[key] || []).filter((item) => item.roiId !== state.activeRoiId);
      state.currentPoints = [];
      renderAll();
    });

    clonePrevBtn.addEventListener('click', () => cloneContourToSlice(state.slice - 1));
    cloneNextBtn.addEventListener('click', () => cloneContourToSlice(state.slice + 1));
    interpolateBtn.addEventListener('click', interpolateCurrentSlice);
    smoothContourBtn.addEventListener('click', smoothActiveContour);
    autoContourBtn.addEventListener('click', autoContourDemo);
    resetViewBtn.addEventListener('click', fitView);
    saveLocalBtn.addEventListener('click', autoSave);
    exportJsonBtn.addEventListener('click', exportJson);
    presetButtons.forEach((button) =>
      button.addEventListener('click', () => setPreset(button.getAttribute('data-wl-preset'))),
    );

    toolButtons.forEach((button) => {
      button.addEventListener('click', () => {
        state.tool = button.getAttribute('data-tool');
        toolButtons.forEach((item) => item.classList.toggle('is-active', item === button));
        renderHint();
        renderContours();
        updateMetaAndStats();
      });
    });

    window.addEventListener('keydown', (event) => {
      const tag = event.target && event.target.tagName;
      if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'BUTTON') return;

      if (event.key === 'ArrowUp') {
        event.preventDefault();
        state.slice = clamp(state.slice + 1, 0, totalSlices - 1);
        sliceRange.value = String(state.slice);
        renderAll();
      } else if (event.key === 'ArrowDown') {
        event.preventDefault();
        state.slice = clamp(state.slice - 1, 0, totalSlices - 1);
        sliceRange.value = String(state.slice);
        renderAll();
      } else if (event.key === '+' || event.key === '=') {
        event.preventDefault();
        setZoom(state.zoom + 0.1);
      } else if (event.key === '-') {
        event.preventDefault();
        setZoom(state.zoom - 0.1);
      } else if (event.key === 'Enter') {
        event.preventDefault();
        commitCurrentContour();
      }
    });

    window.addEventListener('resize', setPanZoomTransform);

    loadLocal();
    fitView();
    renderAll();
  })();
</script>