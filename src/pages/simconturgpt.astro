---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
const componentId = `contour-sim-pro-${Math.random().toString(36).slice(2, 9)}`;
const initialSlice = 8;
---

<BaseLayout
  title="Simulator de Conturaj | Dr. Cirimpei Tatiana"
  description="Demo educațional avansat pentru simulatorul de conturaj. Interfață mai realistă și funcții extinse."
>
  <Header />

  <section class="contour-pro" data-contour-pro={componentId} aria-labelledby={`${componentId}-title`}>
    <div class="contour-pro__shell">
      <div class="contour-pro__header">
        <p class="contour-pro__eyebrow">Demo educațional avansat</p>
        <h2 id={`${componentId}-title`} class="contour-pro__title text-gray-950 dark:text-gray-50">
          Simulator de conturaj – interfață mai realistă și funcții extinse
        </h2>
      </div>

      <div class="contour-pro__top-tools">
        <div class="contour-pro__card contour-pro__toolbar-card">
          <div class="contour-pro__card-head">
            <h3>Tools & contouring actions</h3>
            <span class="contour-pro__tag" data-tool-label>Draw</span>
          </div>

          <div class="contour-pro__toolbar-grid">
            <div class="contour-pro__toolbar-block">
              <span class="contour-pro__toolbar-label">Tools</span>
              <div class="contour-pro__tool-list">
                <button type="button" data-tool="draw" class="is-active">Draw</button>
                <button type="button" data-tool="edit">Edit</button>
                <button type="button" data-tool="pan">Pan</button>
              </div>
            </div>

            <div class="contour-pro__toolbar-block contour-pro__toolbar-block--wide">
              <span class="contour-pro__toolbar-label">Contour actions</span>
              <div class="contour-pro__action-grid contour-pro__action-grid--toolbar">
                <button type="button" data-close-contour>Close contour</button>
                <button type="button" data-undo-point>Undo point</button>
                <button type="button" data-clear-slice>Clear ROI on slice</button>
                <button type="button" data-clone-prev>Copy to previous</button>
                <button type="button" data-clone-next>Copy to next</button>
                <button type="button" data-interpolate>Interpolate</button>
                <button type="button" data-smooth-contour>Smooth contour</button>
                <button type="button" data-auto-contour>Auto-contour demo</button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="contour-pro__layout">
        <aside class="contour-pro__sidebar">
          <div class="contour-pro__card">
            <div class="contour-pro__card-head">
              <h3>Studiu demo</h3>
              <span class="contour-pro__tag">CT Thorax</span>
            </div>

            <div class="contour-pro__study-grid">
              <div><span>Pacient</span><strong>Demo Patient</strong></div>
              <div><span>ID</span><strong>RT-EDU-001</strong></div>
              <div><span>Serii</span><strong>16 slice-uri</strong></div>
            </div>
          </div>

          <div class="contour-pro__card">
            <div class="contour-pro__card-head">
              <h3>ROI-uri</h3>
              <span class="contour-pro__tag" data-roi-count>4 vizibile</span>
            </div>

            <div class="contour-pro__roi-list" data-roi-list></div>

            <div class="contour-pro__roi-controls">
              <label class="contour-pro__field">
                <span>Opacitate ROI activ</span>
                <input type="range" min="0.08" max="0.55" step="0.01" value="0.22" data-roi-opacity />
              </label>

              <div class="contour-pro__button-row">
                <button type="button" data-add-roi>Adaugă ROI</button>
                <button type="button" data-rename-roi>Redenumește</button>
              </div>
            </div>
          </div>
        </aside>

        <div class="contour-pro__main">
          <div class="contour-pro__viewer-card">
            <div class="contour-pro__viewer-topbar">
              <div class="contour-pro__viewer-head-left">
                <span class="contour-pro__viewer-title">Axial CT Viewer</span>
                <span class="contour-pro__viewer-subtitle">Contouring workspace</span>
              </div>
              <div class="contour-pro__viewer-head-right">
                <span data-meta-wl>W 1500 / L -550</span>
                <span data-meta-zoom>Zoom 1.00x</span>
                <span data-meta-coords>X 0 | Y 0 | HU 0</span>
              </div>
            </div>

            <div class="contour-pro__workspace">
              <div class="contour-pro__viewer-wrap">
                <div class="contour-pro__viewer-stage">
                  <div class="contour-pro__viewer" data-viewer>
                    <canvas width="512" height="512" data-image-canvas></canvas>
                    <svg viewBox="0 0 512 512" class="contour-pro__overlay" data-overlay>
                      <g data-pan-zoom-layer>
                        <g data-grid-layer></g>
                        <g data-contours-layer></g>
                        <g data-current-layer></g>
                        <g data-preview-layer></g>
                        <g data-annotation-layer></g>
                      </g>
                    </svg>
                    <div class="contour-pro__crosshair contour-pro__crosshair--v" data-cross-v hidden></div>
                    <div class="contour-pro__crosshair contour-pro__crosshair--h" data-cross-h hidden></div>

                    <div class="contour-pro__corner contour-pro__corner--lt">
                      <strong data-corner-roi>PTV</strong>
                      <span data-corner-mode>Draw mode</span>
                    </div>
                  </div>

                  <aside class="contour-pro__viewer-rail">
                    <div class="contour-pro__rail-card">
                      <div class="contour-pro__rail-head">
                        <strong>Slice</strong>
                        <span data-slice-label>Slice 8 / 15</span>
                      </div>
                      <label class="contour-pro__field contour-pro__field--compact">
                        <span>Navigation</span>
                        <input type="range" min="0" max="15" step="1" value={initialSlice} data-slice-range />
                      </label>
                      <div class="contour-pro__rail-actions">
                        <button type="button" data-prev-slice>−</button>
                        <button type="button" data-play-slices>Play</button>
                        <button type="button" data-next-slice>+</button>
                      </div>
                    </div>

                    <div class="contour-pro__rail-card">
                      <div class="contour-pro__rail-head">
                        <strong>Zoom</strong>
                        <span data-rail-zoom>1.00x</span>
                      </div>
                      <label class="contour-pro__field contour-pro__field--compact">
                        <span>Magnification</span>
                        <input type="range" min="1" max="4.5" step="0.05" value="1" data-zoom-range />
                      </label>
                      <div class="contour-pro__rail-actions">
                        <button type="button" data-zoom-out>−</button>
                        <button type="button" data-fit-view>Fit</button>
                        <button type="button" data-zoom-in>+</button>
                      </div>
                    </div>

                    <div class="contour-pro__rail-card contour-pro__rail-card--display">
                      <div class="contour-pro__rail-head">
                        <strong>Display</strong>
                        <span>Viewer</span>
                      </div>

                      <div class="contour-pro__preset-wrap contour-pro__preset-wrap--rail">
                        <span>WL preset</span>
                        <div class="contour-pro__preset-grid contour-pro__preset-grid--rail">
                          <button type="button" data-wl-preset="lung">Lung</button>
                          <button type="button" data-wl-preset="mediastin">Mediastinum</button>
                          <button type="button" data-wl-preset="osos">Bone</button>
                        </div>
                      </div>

                      <label class="contour-pro__field">
                        <span>Window</span>
                        <input type="range" min="350" max="1800" step="10" value="1500" data-window-range />
                      </label>

                      <label class="contour-pro__field">
                        <span>Level</span>
                        <input type="range" min="-900" max="400" step="10" value="-550" data-level-range />
                      </label>

                      <div class="contour-pro__display-actions">
                        <button type="button" data-reset-view>Reset view</button>
                        <button type="button" data-save-local>Save local</button>
                        <button type="button" data-export-json>Export JSON</button>
                      </div>
                    </div>
                  </aside>
                </div>

                <div class="contour-pro__hint" data-hint>
                  Click to add points. Click near the first point to close the contour.
                </div>
              </div>

              <aside class="contour-pro__scout-card">
                <div class="contour-pro__scout-head">
                  <h3>ROI overview</h3>
                  <span data-scout-caption>PTV overview</span>
                </div>
                <div class="contour-pro__scout-list" data-scout-list></div>
              </aside>
            </div>
          </div>

          <div class="contour-pro__bottom-grid">
            <div class="contour-pro__eval-card">
              <div class="contour-pro__card-head">
                <h3>Contour evaluation</h3>
                <button type="button" data-evaluate class="contour-pro__eval-btn">Evaluate current slice</button>
              </div>
              <div class="contour-pro__eval-content" data-eval-results>
                <p class="contour-pro__hint">Press to analyze accuracy, coverage and point density on the current slice compared with the AI reference.</p>
              </div>
            </div>

            <div class="contour-pro__timeline-card">
              <div class="contour-pro__card-head">
                <h3>Slice summary</h3>
                <span class="contour-pro__tag" data-timeline-caption>Active ROI: PTV</span>
              </div>
              <div class="contour-pro__timeline" data-timeline></div>
            </div>

            <div class="contour-pro__stats-card">
              <div class="contour-pro__card-head">
                <h3>Local statistics</h3>
                <span class="contour-pro__tag">Current</span>
              </div>
              <div class="contour-pro__stats-grid">
                <div><span>Active ROI</span><strong data-stat-roi>PTV</strong></div>
                <div><span>Current points</span><strong data-stat-points>0</strong></div>
                <div><span>Last contour area</span><strong data-stat-area>0 px²</strong></div>
                <div><span>Contours on slice</span><strong data-stat-count>0</strong></div>
                <div><span>Total study contours</span><strong data-stat-total>0</strong></div>
                <div><span>Cursor position</span><strong data-stat-cursor>—</strong></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contour-pro {
    --panel: rgba(15, 23, 42, 0.92);
    --panel-2: rgba(15, 23, 42, 0.76);
    --line: rgba(148, 163, 184, 0.18);
    --text: #e2e8f0;
    --muted: #94a3b8;
    --accent: #22d3ee;
    --accent-2: #67e8f9;
    --success: #84cc16;
    --warning: #facc15;
    --danger: #f43f5e;
    color: var(--text);
  }

  .contour-pro * {
    box-sizing: border-box;
  }

  .contour-pro__shell {
    max-width: 1600px;
    margin: 0 auto;
    padding: 1rem;
  }

  .contour-pro__header {
    margin-bottom: 1.5rem;
  }

  .contour-pro__eyebrow {
    display: inline-flex;
    margin: 0 0 0.85rem;
    border: 1px solid rgba(34, 211, 238, 0.28);
    border-radius: 999px;
    background: rgba(34, 211, 238, 0.1);
    padding: 0.42rem 0.8rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #cffafe;
  }

  .contour-pro__title {
    margin: 0;
    font-size: clamp(2rem, 2.7vw, 3rem);
    line-height: 1.05;
    letter-spacing: -0.035em;
  }

  .contour-pro__intro {
    max-width: 930px;
    margin: 0.95rem 0 0;
    font-size: 1rem;
    line-height: 1.72;
    color: var(--muted);
  }

  .contour-pro__top-tools {
    margin-bottom: 1rem;
  }

  .contour-pro__layout {
    display: grid;
    gap: 1.2rem;
  }

  .contour-pro__sidebar,
  .contour-pro__main {
    display: grid;
    gap: 1rem;
  }

  .contour-pro__card,
  .contour-pro__viewer-card,
  .contour-pro__timeline-card,
  .contour-pro__stats-card,
  .contour-pro__scout-card,
  .contour-pro__eval-card,
  .contour-pro__rail-card {
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1.35rem;
    background: linear-gradient(180deg, rgba(15, 23, 42, 0.94), rgba(2, 6, 23, 0.98));
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.28);
    backdrop-filter: blur(14px);
    padding: 1rem;
  }

  .contour-pro__toolbar-card {
    padding: 1rem 1.05rem 1.05rem;
  }

  .contour-pro__card-head,
  .contour-pro__scout-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.9rem;
  }

  .contour-pro__card-head h3,
  .contour-pro__scout-head h3 {
    margin: 0;
    font-size: 1rem;
  }

  .contour-pro__tag {
    border-radius: 999px;
    border: 1px solid rgba(34, 211, 238, 0.16);
    background: rgba(34, 211, 238, 0.08);
    padding: 0.28rem 0.6rem;
    font-size: 0.74rem;
    font-weight: 700;
    color: #cffafe;
  }

  .contour-pro__study-grid,
  .contour-pro__stats-grid {
    display: grid;
    gap: 0.72rem;
  }

  .contour-pro__study-grid div,
  .contour-pro__stats-grid div {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    color: var(--muted);
    font-size: 0.92rem;
  }

  .contour-pro__study-grid strong,
  .contour-pro__stats-grid strong {
    color: var(--text);
  }

  .contour-pro__preset-wrap {
    margin-top: 1rem;
    display: grid;
    gap: 0.7rem;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .contour-pro__preset-wrap--rail {
    margin-top: 0;
  }

  .contour-pro__preset-grid,
  .contour-pro__button-row,
  .contour-pro__display-actions,
  .contour-pro__rail-actions,
  .contour-pro__tool-list,
  .contour-pro__action-grid {
    display: grid;
    gap: 0.7rem;
  }

  .contour-pro__preset-grid,
  .contour-pro__display-actions,
  .contour-pro__rail-actions {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .contour-pro__preset-grid--rail {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .contour-pro__button-row {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .contour-pro__tool-list {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .contour-pro__action-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: 0.85rem;
  }

  .contour-pro__toolbar-grid {
    display: grid;
    gap: 1rem;
  }

  .contour-pro__toolbar-block {
    min-width: 0;
  }

  .contour-pro__toolbar-label {
    display: block;
    margin-bottom: 0.65rem;
    font-size: 0.74rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .contour-pro__action-grid--toolbar {
    margin-top: 0;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .contour-pro__roi-list {
    display: grid;
    gap: 0.65rem;
  }

  .contour-pro__roi-item {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.6rem;
    align-items: center;
    width: 100%;
    padding: 0.7rem 0.75rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1rem;
    background: rgba(15, 23, 42, 0.68);
    color: var(--text);
    cursor: pointer;
    text-align: left;
    transition: transform 140ms ease, border-color 140ms ease, background 140ms ease;
  }

  .contour-pro__roi-item:hover,
  .contour-pro__roi-item.is-active {
    transform: translateY(-1px);
    border-color: rgba(34, 211, 238, 0.28);
    background: rgba(34, 211, 238, 0.08);
  }

  .contour-pro__roi-main {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    min-width: 0;
  }

  .contour-pro__roi-dot {
    width: 1rem;
    height: 1rem;
    border-radius: 999px;
    border: 2px solid rgba(255, 255, 255, 0.6);
    flex: 0 0 auto;
  }

  .contour-pro__roi-name {
    font-weight: 700;
  }

  .contour-pro__roi-meta {
    font-size: 0.78rem;
    color: var(--muted);
  }

  .contour-pro__roi-actions-side {
    display: flex;
    align-items: center;
    gap: 0.45rem;
  }

  .contour-pro__eye-btn {
    min-width: 2.1rem;
    width: 2.1rem;
    height: 2.1rem;
    padding: 0;
    border-radius: 0.75rem;
    font-size: 1rem;
  }

  .contour-pro__roi-controls {
    margin-top: 0.9rem;
  }

  .contour-pro__field {
    display: grid;
    gap: 0.45rem;
    color: var(--muted);
    font-size: 0.92rem;
    margin-top: 0.7rem;
  }

  .contour-pro__field--compact {
    margin-top: 0;
  }

  .contour-pro__field input[type='range'] {
    width: 100%;
  }

  .contour-pro button {
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 0.92rem;
    background: rgba(15, 23, 42, 0.78);
    padding: 0.78rem 0.8rem;
    color: var(--text);
    font: inherit;
    cursor: pointer;
    transition: transform 140ms ease, border-color 140ms ease, background 140ms ease;
  }

  .contour-pro button:hover {
    transform: translateY(-1px);
    border-color: rgba(34, 211, 238, 0.28);
    background: rgba(34, 211, 238, 0.08);
  }

  .contour-pro__tool-list button.is-active,
  .contour-pro__rail-actions button.is-active {
    border-color: rgba(34, 211, 238, 0.34);
    background: rgba(34, 211, 238, 0.12);
    color: #cffafe;
  }

  .contour-pro__viewer-topbar {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.9rem;
  }

  .contour-pro__viewer-head-left,
  .contour-pro__viewer-head-right {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem 1rem;
    align-items: center;
  }

  .contour-pro__viewer-title {
    font-size: 1rem;
    font-weight: 700;
  }

  .contour-pro__viewer-subtitle,
  .contour-pro__viewer-head-right span,
  .contour-pro__scout-head span,
  .contour-pro__rail-head span {
    color: var(--muted);
    font-size: 0.86rem;
  }

  .contour-pro__workspace,
  .contour-pro__bottom-grid {
    display: grid;
    gap: 1rem;
  }

  .contour-pro__viewer-wrap {
    display: grid;
    gap: 0.85rem;
  }

  .contour-pro__viewer-stage {
    display: grid;
    gap: 1rem;
    align-items: start;
  }

  .contour-pro__viewer {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 1rem;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: #000;
    cursor: crosshair;
  }

  .contour-pro__viewer.is-pan {
    cursor: grab;
  }

  .contour-pro__viewer.is-pan.is-dragging {
    cursor: grabbing;
  }

  .contour-pro__viewer canvas,
  .contour-pro__overlay {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  .contour-pro__overlay {
    pointer-events: none;
  }

  .contour-pro__viewer-rail {
    display: grid;
    gap: 0.9rem;
    align-content: start;
  }

  .contour-pro__rail-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .contour-pro__rail-card--display .contour-pro__display-actions {
    grid-template-columns: 1fr;
  }

  .contour-pro__crosshair {
    position: absolute;
    background: rgba(255, 255, 255, 0.18);
    pointer-events: none;
    z-index: 4;
  }

  .contour-pro__crosshair--v {
    top: 0;
    bottom: 0;
    width: 1px;
    transform: translateX(-50%);
  }

  .contour-pro__crosshair--h {
    left: 0;
    right: 0;
    height: 1px;
    transform: translateY(-50%);
  }

  .contour-pro__corner {
    position: absolute;
    z-index: 5;
    display: grid;
    gap: 0.15rem;
    padding: 0.6rem 0.7rem;
    border-radius: 0.85rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(2, 6, 23, 0.72);
    backdrop-filter: blur(10px);
  }

  .contour-pro__corner strong {
    font-size: 0.82rem;
  }

  .contour-pro__corner span {
    font-size: 0.75rem;
    color: var(--muted);
  }

  .contour-pro__corner--lt {
    top: 0.8rem;
    left: 0.8rem;
  }

  .contour-pro__hint {
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.6;
  }

  .contour-pro__scout-card {
    display: grid;
    gap: 0.8rem;
    align-content: start;
    padding: 0.85rem;
  }

  .contour-pro__scout-list {
    display: grid;
    gap: 0.45rem;
  }

  .contour-pro__scout-item {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.65rem;
    width: 100%;
    padding: 0.5rem 0.55rem;
    border-radius: 0.85rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(15, 23, 42, 0.68);
    color: var(--text);
    text-align: left;
    cursor: pointer;
    transition: transform 140ms ease, border-color 140ms ease, background 140ms ease;
  }

  .contour-pro__scout-item:hover,
  .contour-pro__scout-item.is-current {
    transform: translateY(-1px);
    border-color: rgba(34, 211, 238, 0.28);
  }

  .contour-pro__scout-index {
    font-weight: 700;
    color: #cbd5e1;
    font-size: 0.82rem;
  }

  .contour-pro__scout-bar {
    height: 0.55rem;
    border-radius: 999px;
    background: rgba(71, 85, 105, 0.7);
    overflow: hidden;
  }

  .contour-pro__scout-bar span {
    display: block;
    height: 100%;
    border-radius: inherit;
